@model GV23_Notice.Models.Workflow.ViewModels.Step2EmailSuccessVm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = Model.IsApproval ? "Approval Sent" : "Correction Sent";
    string noticeFull = Model.Notice switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection &amp; Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => "Section 52 — Appeal Notices",
        NoticeKind.S53 => "Section 53 — Appeal Period",
        NoticeKind.DJ => "Dear Johnny Notice",
        NoticeKind.IN => "Invalid Notice",
        NoticeKind.S78 => "Section 78 — Review Period",
        _ => Model.Notice.ToString()
    };
    string sentAt = Model.ApprovedAtUtc?.ToLocalTime().ToString("dd MMMM yyyy HH:mm") ?? DateTime.Now.ToString("dd MMMM yyyy HH:mm");
    string byUser = Model.ApprovedBy.Contains('\\') ? Model.ApprovedBy.Split('\\').Last() : Model.ApprovedBy;
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />

<link href="~/css/admincss/successcss.css" rel="stylesheet" />
<div class="sv-root">

    <!-- TOP BAR -->
    <div class="sv-topbar">
        <div class="sv-topbar-left">
            <div class="sv-logo">VNS</div>
            <div class="sv-topbar-div"></div>
            <div>
                <div class="sv-page-title">
                    @(Model.IsApproval ? "Step 2 — Approval Sent" : "Step 2 — Correction Sent")
                </div>
                <div class="sv-page-sub">Email dispatched to the Data Team</div>
            </div>
        </div>
        <div class="sv-topbar-right">
            <a class="sv-topbar-link" asp-controller="Home" asp-action="Index">
                ← Dashboard
            </a>
        </div>
    </div>

    <!-- SUCCESS HERO -->
    <div class="sv-hero @(Model.IsApproval ? "sv-hero-approve" : "sv-hero-correct")">
        <div class="sv-hero-icon-wrap">
            @if (Model.IsApproval)
            {
                <div class="sv-hero-icon sv-icon-approve">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                </div>
            }
            else
            {
                <div class="sv-hero-icon sv-icon-correct">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                </div>
            }
        </div>
        <div class="sv-hero-text">
            <div class="sv-hero-title">
                @(Model.IsApproval ? "Workflow Approved" : "Correction Requested")
            </div>
            <div class="sv-hero-sub">
                @if (Model.IsApproval)
                {
                    <text>The approval email with the secure Step 3 kickoff link has been sent to the Data Team.</text>
                }
                else
                {
                    <text>The correction request email has been sent. The Data Team must update the configuration and re-submit.</text>
                }
            </div>
        </div>
    </div>

    <div class="sv-body">

        <!-- Email summary card -->
        <div class="sv-card">
            <div class="sv-card-header">
                <div class="sv-card-icon">✉</div>
                <div>
                    <div class="sv-card-title">Email Dispatched</div>
                    <div class="sv-card-sub">Sent and archived to disk</div>
                </div>
            </div>
            <div class="sv-detail-grid">
                <div class="sv-row">
                    <span class="sv-label">Type</span>
                    <span class="sv-val">
                        @if (Model.IsApproval)
                        {
                            <span class="sv-badge sv-badge-approve">Approval</span>
                        }
                        else
                        {
                            <span class="sv-badge sv-badge-correct">Correction Request</span>
                        }
                    </span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.EmailSubject))
                {
                    <div class="sv-row">
                        <span class="sv-label">Subject</span>
                        <span class="sv-val sv-subject">@Model.EmailSubject</span>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.RecipientList))
                {
                    <div class="sv-row">
                        <span class="sv-label">Sent To</span>
                        <span class="sv-val sv-mono">@Model.RecipientList</span>
                    </div>
                }
                <div class="sv-row">
                    <span class="sv-label">Sent By</span>
                    <span class="sv-val">@byUser</span>
                </div>
                <div class="sv-row">
                    <span class="sv-label">Sent At</span>
                    <span class="sv-val sv-mono">@sentAt</span>
                </div>
            </div>
        </div>

        <!-- Workflow context card -->
        <div class="sv-card">
            <div class="sv-card-header">
                <div class="sv-card-icon">⊞</div>
                <div>
                    <div class="sv-card-title">Workflow Context</div>
                    <div class="sv-card-sub">Configuration that was processed</div>
                </div>
            </div>
            <div class="sv-detail-grid">
                <div class="sv-row">
                    <span class="sv-label">Notice</span>
                    <span class="sv-val">@Html.Raw(noticeFull)</span>
                </div>
                <div class="sv-row">
                    <span class="sv-label">Roll</span>
                    <span class="sv-val">
                        <span class="sv-code-chip">@Model.RollShortCode</span>
                        @Model.RollName
                    </span>
                </div>
                <div class="sv-row">
                    <span class="sv-label">Version</span>
                    <span class="sv-val"><span class="sv-badge sv-badge-ver">v@Model.Version</span></span>
                </div>
                <div class="sv-row">
                    <span class="sv-label">Settings ID</span>
                    <span class="sv-val sv-mono">#@Model.SettingsId</span>
                </div>
            </div>
        </div>

        <!-- Next steps card -->
        <div class="sv-card">
            <div class="sv-card-header">
                <div class="sv-card-icon">→</div>
                <div>
                    <div class="sv-card-title">
                        @(Model.IsApproval ? "What Happens Next" : "Action Required")
                    </div>
                </div>
            </div>
            <div class="sv-steps-list">
                @if (Model.IsApproval)
                {
                    <div class="sv-step-item">
                        <div class="sv-step-num">1</div>
                        <div class="sv-step-text">The Data Team receives the email with a secure kickoff link</div>
                    </div>
                    <div class="sv-step-item">
                        <div class="sv-step-num">2</div>
                        <div class="sv-step-text">They click the link → land on the Step 3 Landing Page to review the config</div>
                    </div>
                    <div class="sv-step-item">
                        <div class="sv-step-num">3</div>
                        <div class="sv-step-text">They click "Start Processing" → create batches → print PDFs → send emails to ratepayers</div>
                    </div>
                }
                else
                {
                    <div class="sv-step-item sv-step-warn">
                        <div class="sv-step-num sv-num-warn">!</div>
                        <div class="sv-step-text">The configuration must be corrected before the workflow can proceed</div>
                    </div>
                    <div class="sv-step-item">
                        <div class="sv-step-num">1</div>
                        <div class="sv-step-text">Go back to Step 1 and update the configuration as requested</div>
                    </div>
                    <div class="sv-step-item">
                        <div class="sv-step-num">2</div>
                        <div class="sv-step-text">Re-confirm → return to Step 2 for a new preview and approval</div>
                    </div>
                }
            </div>
        </div>

        <!-- Action buttons -->
        <div class="sv-actions">
            <a class="sv-btn sv-btn-primary" asp-controller="Home" asp-action="Index">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                Go to Dashboard
            </a>

            @if (Model.IsCorrection)
            {
                <a class="sv-btn sv-btn-secondary"
                   asp-controller="Workflow" asp-action="Step1"
                   asp-route-settingsId="@Model.SettingsId">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                    </svg>
                    Edit Configuration
                </a>
            }

            <a class="sv-btn sv-btn-ghost"
               asp-controller="Workflow" asp-action="SettingsLibrary">
                View Settings Library
            </a>
        </div>

    </div>
</div>
