@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep1Vm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 1 — Notice Configuration";
    var rolls = ViewBag.Rolls as List<SelectListItem> ?? new List<SelectListItem>();
    var isEdit = Model.SettingsId.HasValue;
}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="~/css/step1/step1css.css" rel="stylesheet" />


<div id="wf-loader" role="status">
    <div class="wf-spinner"></div>
    <div>
        <div class="wf-loader-text" id="wf-loader-text">Loading…</div>
        <div class="wf-loader-sub"  id="wf-loader-sub">Please wait</div>
    </div>
</div>

<div id="wf-toast-container" aria-live="polite"></div>

<div class="s1-root">

    <!-- TOP BAR -->
    <div class="s1-topbar">
        <div class="s1-topbar-left">
            <div class="s1-logo-mark">VNS</div>
            <div class="s1-topbar-divider"></div>
            <div>
                <div class="s1-page-title">Notice Configuration</div>
                <div class="s1-page-sub">Step 1 — Date Configuration</div>
            </div>
        </div>
        <div class="s1-topbar-right">
          @*   <a class="s1-topbar-link" asp-controller="Workflow" asp-action="SettingsLibrary">
                ← Settings Library
            </a> *@
            @if (isEdit)
            {
                <a class="s1-topbar-link s1-topbar-link-gold"
                   asp-controller="Workflow" asp-action="Step1Summary"
                   asp-route-settingsId="@Model.SettingsId">
                    View Summary →
                </a>
            }
        </div>
    </div>

    <!-- STEPPER -->
    <div class="s1-stepper">
        <div class="s1-step s1-step-active">
            <div class="s1-step-num">1</div>
            <div class="s1-step-label">Configure Dates</div>
        </div>
        <div class="s1-step-line"></div>
        <div class="s1-step">
            <div class="s1-step-num">2</div>
            <div class="s1-step-label">Preview</div>
        </div>
        <div class="s1-step-line"></div>
        <div class="s1-step">
            <div class="s1-step-num">3</div>
            <div class="s1-step-label">Start Step 3</div>
        </div>
    </div>

    <form id="wf-form" asp-action="Step1" asp-controller="Workflow"
          method="post" enctype="multipart/form-data" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SettingsId" />

        <div class="s1-layout">

            <!-- SIDEBAR NAV -->
            <div class="s1-sidebar">
                <div class="s1-sidebar-section">
                    <div class="s1-sidebar-label">Sections</div>

                    <div class="s1-sidebar-item active" id="nav-period" onclick="scrollTo('card-period')">
                        <div class="s1-sidebar-num">01</div>
                        Period &amp; Roll
                        <span class="s1-sidebar-req" id="nav-req-period">✕ required</span>
                    </div>
                    <div class="s1-sidebar-item" id="nav-common" onclick="scrollTo('card-common')">
                        <div class="s1-sidebar-num">02</div>
                        Common Fields
                    </div>
                    <div class="s1-sidebar-item" id="nav-notice" onclick="scrollTo('card-notice')">
                        <div class="s1-sidebar-num">03</div>
                        Notice-Specific
                    </div>
                </div>
                <div style="padding:0 20px">
                    <div class="s1-sidebar-label">Notice</div>
                    <div style="font-size:13px;color:var(--s1-text-m);padding:8px 12px;background:var(--s1-surface);border-radius:7px;">
                        <span id="sb-notice-label" style="font-family:var(--fm);font-weight:600;color:var(--s1-text)">S49</span><br>
                        <span id="sb-notice-desc" style="font-size:11.5px;">Section 49 Notice</span>
                    </div>
                </div>
            </div>

            <!-- MAIN -->
            <div class="s1-main">

                <!-- Validation Banner -->
                <div class="s1-val-banner" id="valBanner">
                    <div class="s1-val-banner-icon">⚠</div>
                    <div>
                        <div class="s1-val-banner-title">Please fix the following before continuing</div>
                        <ul class="s1-val-banner-list" id="valBannerList"></ul>
                    </div>
                </div>

                <!-- ══ CARD 1 — Period & Roll ═══════════════════════════ -->
                <div class="s1-card" id="card-period">
                    <div class="s1-card-header">
                        <div class="s1-card-header-left">
                            <div class="s1-card-num">01</div>
                            <div>
                                <div class="s1-card-title">Period &amp; Roll</div>
                                <div class="s1-card-sub">Select valuation period, financial year, roll and notice type</div>
                            </div>
                        </div>
                        <div class="s1-required-note"><span class="s1-req-star">*</span> Required</div>
                    </div>
                    <div class="s1-fields">

                        <div class="s1-row s1-row-2">
                            <div class="s1-field" id="field-ValuationPeriodCode">
                                <label class="s1-label">Valuation Period <span class="s1-req-star">*</span></label>
                                <select asp-for="ValuationPeriodCode"
                                        asp-items="ViewBag.ValuationPeriods"
                                        id="valuationPeriod" class="s1-select"
                                        onchange="onValuationPeriodChange()">
                                    <option value="">— Select period —</option>
                                </select>
                                <div class="s1-val-msg" id="err-ValuationPeriodCode">
                                    <span asp-validation-for="ValuationPeriodCode"></span>
                                </div>
                            </div>

                            <div class="s1-field" id="field-FinancialYear">
                                <label class="s1-label">
                                    Financial Year <span class="s1-req-star">*</span>
                                    <span class="s1-hint-inline">(1 July – 30 June)</span>
                                </label>
                                <select id="financialYearSelect" class="s1-select"
                                        onchange="onFinancialYearChange()" disabled>
                                    <option value="">— Select valuation period first —</option>
                                </select>
                                <input type="hidden" asp-for="FinancialYearStart" id="fyStart" />
                                <input type="hidden" asp-for="FinancialYearEnd"   id="fyEnd"   />
                                <input type="hidden" asp-for="FinancialYearsText" id="fyText"  />
                                <div class="s1-val-msg" id="err-FinancialYear">
                                    <span asp-validation-for="FinancialYearStart"></span>
                                </div>
                            </div>
                        </div>

                        <div class="s1-row s1-row-3">
                            <div class="s1-field" id="field-RollId">
                                <label class="s1-label">Roll <span class="s1-req-star">*</span></label>
                                <select asp-for="RollId" asp-items="rolls"
                                        id="rollSelect" class="s1-select">
                                    <option value="0">— Select roll —</option>
                                </select>
                                <div class="s1-val-msg" id="err-RollId">
                                    <span asp-validation-for="RollId"></span>
                                </div>
                            </div>

                            <div class="s1-field" id="field-Notice">
                                <label class="s1-label">Notice Type <span class="s1-req-star">*</span></label>

                                <select id="noticeSelect" name="Notice"
                                        class="s1-select" onchange="runAll()">
                                    <option value="S49" selected="@(Model.Notice == NoticeKind.S49)">Section 49 Notice</option>
                                    <option value="S51" selected="@(Model.Notice == NoticeKind.S51)">Section 51 Notice</option>
                                    <option value="S52" selected="@(Model.Notice == NoticeKind.S52)">Appeal Notices</option>
                                    <option value="S53" selected="@(Model.Notice == NoticeKind.S53)">Section 53 Notice</option>
                                    <option value="DJ" selected="@(Model.Notice == NoticeKind.DJ)">Dear Jonny Notice</option>
                                    <option value="IN" selected="@(Model.Notice == NoticeKind.IN)">Invalidity Notices</option>
                                    @*   <option value="S78" selected="@(Model.Notice == NoticeKind.S78)">Section 78 (S78)</option> *@
                                </select>
                              
                                <input type="hidden" asp-for="Notice" id="noticeHidden" />
                                <div class="s1-val-msg" id="err-Notice">
                                    <span asp-validation-for="Notice"></span>
                                </div>
                            </div>

                            <div class="s1-field">
                                <label class="s1-label">Batch Mode</label>
                                <select asp-for="Mode" id="modeSelect" class="s1-select"
                                        onchange="runAll()">
                                    <option value="@BatchMode.Single">Single</option>
                                    <option value="@BatchMode.Bulk">Bulk</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══ CARD 2 — Common Fields ═══════════════════════════ -->
                <div class="s1-card" id="card-common">
                    <div class="s1-card-header">
                        <div class="s1-card-header-left">
                            <div class="s1-card-num">02</div>
                            <div>
                                <div class="s1-card-title">Common Fields</div>
                                <div class="s1-card-sub">Letter date, portal URL and shared settings</div>
                            </div>
                        </div>
                    </div>
                    <div class="s1-fields">
                        <div class="s1-row s1-row-2">
                            <div class="s1-field">
                                <label class="s1-label">Letter Date</label>
                                <input type="date" asp-for="LetterDate" id="letterDate"
                                       class="s1-input" onchange="runAll()" />
                            </div>
                            <div class="s1-field" id="letterOverrideBlock" style="display:none">
                                <label class="s1-label">
                                    Override Reason <span class="s1-req-star">*</span>
                                    <span class="s1-hint-inline">(required when date changed)</span>
                                </label>
                                <input type="text" asp-for="LetterDateOverrideReason"
                                       class="s1-input" placeholder="State reason for the date change…" />
                                <div class="s1-val-msg">
                                    <span asp-validation-for="LetterDateOverrideReason"></span>
                                </div>
                            </div>
                        </div>
                        <div class="s1-row s1-row-2">
                            <div class="s1-field">
                                <label class="s1-label">Portal URL <span class="s1-opt">(optional)</span></label>
                                <input type="url" asp-for="PortalUrl" class="s1-input"
                                       placeholder="https://objections.joburg.org.za/" />
                            </div>
                            <div class="s1-field">
                                <label class="s1-label">Enquiries Line <span class="s1-opt">(optional)</span></label>
                                <input type="text" asp-for="EnquiriesLine" class="s1-input"
                                       placeholder="e.g. 0800 123 456" />
                            </div>
                        </div>
                        <div class="s1-row s1-row-2">
                            <div class="s1-field">
                                <label class="s1-label">City Manager Sign Date <span class="s1-opt">(optional)</span></label>
                                <input type="date" asp-for="CityManagerSignDate" class="s1-input" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══ CARD 3 — Notice-Specific ════════════════════════ -->
                <div class="s1-card" id="card-notice">
                    <div class="s1-card-header">
                        <div class="s1-card-header-left">
                            <div class="s1-card-num">03</div>
                            <div>
                                <div class="s1-card-title">Notice-Specific Configuration</div>
                                <div class="s1-card-sub" id="noticeSpecificSub">Section 49 — objection window, inspection dates and signature</div>
                            </div>
                        </div>
                        <div class="s1-notice-badge s1-badge-s49" id="noticeBadge">S49</div>
                    </div>
                    <div class="s1-fields">

                        <!-- S49 -->
                        <div id="blockS49" class="notice-block">
                            <div class="s1-notice-header s1-notice-s49">Section 49 — Inspection &amp; Objection Window</div>
                            <div class="s1-row s1-row-3">
                                <div class="s1-field">
                                    <label class="s1-label">Objection Start Date</label>
                                    <input type="date" asp-for="ObjectionStartDate" class="s1-input" />
                                </div>
                                <div class="s1-field">
                                    <label class="s1-label">Objection End Date</label>
                                    <input type="date" asp-for="ObjectionEndDate" class="s1-input" />
                                </div>
                                <div class="s1-field">
                                    <label class="s1-label">Extension Date <span class="s1-opt">(optional)</span></label>
                                    <input type="date" asp-for="ExtensionDate" class="s1-input" />
                                </div>
                            </div>
                            <div class="s1-row s1-row-2" style="margin-top:4px">
                                <div class="s1-field">
                                    <label class="s1-label">Signature Upload <span class="s1-hint-inline">(required before Approve)</span></label>
                                    <input type="file" name="signatureFile" class="s1-file" accept="image/*,.pdf" />
                                    @if (!string.IsNullOrWhiteSpace(Model.ExistingSignaturePath))
                                    {
                                        <div class="s1-existing-file">
                                            📎 @System.IO.Path.GetFileName(Model.ExistingSignaturePath)
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- S51 -->
                        <div id="blockS51" class="notice-block">
                            <div class="s1-notice-header s1-notice-s51">Section 51 — Objection Decision</div>
                            <div class="s1-row s1-row-2">
                                <div class="s1-field">
                                    <label class="s1-label">Evidence Closing Date <span class="s1-hint-inline">(auto = Letter Date + 30)</span></label>
                                    <input type="date" asp-for="EvidenceCloseDate"
                                           id="evidenceCloseDate" class="s1-input" readonly />
                                    <div class="s1-info-note" style="margin-top:6px">Calculated automatically from the letter date.</div>
                                </div>
                            </div>
                        </div>

                        <!-- S52 -->
                        <div id="blockS52" class="notice-block">
                            <div class="s1-notice-header s1-notice-s52">Section 52 — Appeal Notices</div>
                            <div class="s1-field" style="margin-bottom:16px">
                                <label class="s1-label">Sub-type <span class="s1-req-star">*</span></label>
                                <div class="s1-radio-group">
                                    <label class="s1-radio-opt">
                                        <input type="radio" name="S52SendMode" value="1"
                                               @(Model.S52SendMode == S52SendMode.ReviewOnly ? "checked" : "")
                                               onchange="onS52ModeChange(this)" />
                                        <div class="s1-radio-body">
                                            <div class="s1-radio-title">Section 52 Review</div>
                                            <div class="s1-radio-desc">Municipal Valuer review of objection outcome</div>
                                        </div>
                                    </label>
                                    <label class="s1-radio-opt">
                                        <input type="radio" name="S52SendMode" value="2"
                                               @(Model.S52SendMode == S52SendMode.AppealDecisionOnly ? "checked" : "")
                                               onchange="onS52ModeChange(this)" />
                                        <div class="s1-radio-body">
                                            <div class="s1-radio-title">Appeal Decision</div>
                                            <div class="s1-radio-desc">Valuation Appeal Board decision outcome</div>
                                        </div>
                                    </label>
                                    <label class="s1-radio-opt">
                                        <input type="radio" name="S52SendMode" value="3"
                                               @((int)Model.S52SendMode == 3 || (int)Model.S52SendMode == 0 ? "checked" : "")
                                               onchange="onS52ModeChange(this)" />
                                        <div class="s1-radio-body">
                                            <div class="s1-radio-title">Both</div>
                                            <div class="s1-radio-desc">Send S52 Review AND Appeal Decision notices</div>
                                        </div>
                                    </label>
                                </div>
                                <input type="hidden" asp-for="S52SendMode" id="s52SendModeHidden" />
                            </div>
                            <div id="blockS52Review" style="display:none">
                                <div class="s1-subblock-header">Section 52 Review — Date Range</div>
                                <div class="s1-row s1-row-2">
                                    <div class="s1-field"><label class="s1-label">From Date</label><input type="date" asp-for="BulkFromDate" class="s1-input" /></div>
                                    <div class="s1-field"><label class="s1-label">To Date</label><input type="date" asp-for="BulkToDate" class="s1-input" /></div>
                                </div>
                            </div>
                            <div id="blockS52Appeal" style="display:none">
                                <div class="s1-subblock-header">Appeal Decision — Date Range</div>
                                <div class="s1-row s1-row-2">
                                    <div class="s1-field"><label class="s1-label">From Date</label><input type="date" asp-for="BulkFromDate" class="s1-input" /></div>
                                    <div class="s1-field"><label class="s1-label">To Date</label><input type="date" asp-for="BulkToDate" class="s1-input" /></div>
                                </div>
                            </div>
                        </div>

                        <!-- S53 -->
                        <div id="blockS53" class="notice-block">
                            <div class="s1-notice-header s1-notice-s53">Section 53 — Appeal Period</div>
                            <div class="s1-row s1-row-3">
                                <div class="s1-field">
                                    <label class="s1-label">Batch Date <span class="s1-opt">(default Today)</span></label>
                                    <input type="date" asp-for="BatchDate" class="s1-input" />
                                </div>
                                <div class="s1-field">
                                    <label class="s1-label">Appeal Close Date <span class="s1-hint-inline">(auto calculated)</span></label>
                                    <input type="date" asp-for="AppealCloseDate" id="appealCloseDate" class="s1-input" />
                                    <div class="s1-val-msg"><span asp-validation-for="AppealCloseDate"></span></div>
                                </div>
                                <div class="s1-field s1-field-center">
                                    <label class="s1-label" style="visibility:hidden">x</label>
                                    <label class="s1-checkbox-row">
                                        <input type="checkbox" asp-for="AppealCloseOverridden"
                                               id="overrideS53" onchange="runAll()" />
                                        <span>Override Appeal Close Date</span>
                                    </label>
                                </div>
                            </div>
                            <div class="s1-override-block" id="blockS53Override">
                                <div class="s1-row s1-row-2">
                                    <div class="s1-field">
                                        <label class="s1-label">Override Reason <span class="s1-req-star">*</span></label>
                                        <input type="text" asp-for="AppealCloseOverrideReason"
                                               class="s1-input" placeholder="State reason…" />
                                        <div class="s1-val-msg"><span asp-validation-for="AppealCloseOverrideReason"></span></div>
                                    </div>
                                    <div class="s1-field">
                                        <label class="s1-label">Evidence Upload <span class="s1-req-star">*</span></label>
                                        <input type="file" name="overrideEvidenceFile" class="s1-file" />
                                        @if (!string.IsNullOrWhiteSpace(Model.ExistingOverrideEvidencePath))
                                        {
                                            <div class="s1-existing-file">📎 @System.IO.Path.GetFileName(Model.ExistingOverrideEvidencePath)</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="s1-info-note" style="margin-top:12px">
                                Appeal close = Letter Date + 45 calendar days, adjusted past weekends &amp; public holidays.
                            </div>
                        </div>

                        <!-- DJ / IN -->
                        <div id="blockDJIN" class="notice-block">
                            <div class="s1-notice-header s1-notice-dj" id="djinHeader">Dear Johnny Notice</div>
                            <div id="blockINSubType" style="display:none; margin-top:4px">
                                <div class="s1-field" style="margin-bottom:0">
                                    <label class="s1-label">Sub-type <span class="s1-req-star">*</span></label>
                                    <div class="s1-radio-group">
                                        <label class="s1-radio-opt">
                                            <input type="radio" name="INSendMode" value="InvalidObjectionOnly"
                                                   id="inSubOBJ" @(Model.INSendMode == INSendMode.InvalidObjectionOnly ? "checked" : "") />
                                            <div class="s1-radio-body">
                                                <div class="s1-radio-title">Invalid Objection Only</div>
                                                <div class="s1-radio-desc">Pending-Invalid Objection status</div>
                                            </div>
                                        </label>
                                        <label class="s1-radio-opt">
                                            <input type="radio" name="INSendMode" value="InvalidOmissionOnly"
                                                   id="inSubOMI" @(Model.INSendMode == INSendMode.InvalidOmissionOnly ? "checked" : "") />
                                            <div class="s1-radio-body">
                                                <div class="s1-radio-title">Invalid Omission Only</div>
                                                <div class="s1-radio-desc">Pending-Invalid Omission status</div>
                                            </div>
                                        </label>
                                        <label class="s1-radio-opt">
                                            <input type="radio" name="INSendMode" value="Both"
                                                   id="inSubBOTH" @(Model.INSendMode == INSendMode.Both ? "checked" : "") />
                                            <div class="s1-radio-body">
                                                <div class="s1-radio-title">Both</div>
                                                <div class="s1-radio-desc">Creates two batches — one per sub-type</div>
                                            </div>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <div class="s1-info-note" id="djinNote" style="margin-top:12px">
                                Only the Letter Date and common fields are required for Dear Johnny.
                            </div>
                        </div>

                        <!-- S78 -->
                        <div id="blockS78" class="notice-block">
                            <div class="s1-notice-header s1-notice-s78">Section 78 — Review Period</div>
                            <div class="s1-row s1-row-3">
                                <div class="s1-field"><label class="s1-label">Extraction Date</label><input type="date" asp-for="ExtractionDate" class="s1-input" /></div>
                                <div class="s1-field">
                                    <label class="s1-label">Extract Period <span class="s1-opt">(days)</span></label>
                                    <input type="number" asp-for="ExtractPeriodDays" class="s1-input" min="1" max="365" placeholder="e.g. 30" />
                                    <div class="s1-val-msg"><span asp-validation-for="ExtractPeriodDays"></span></div>
                                </div>
                                <div class="s1-field"><label class="s1-label">Review Open Date</label><input type="date" asp-for="ReviewOpenDate" class="s1-input" /></div>
                            </div>
                            <div class="s1-row s1-row-2" style="margin-top:4px">
                                <div class="s1-field"><label class="s1-label">Review Close Date</label><input type="date" asp-for="ReviewCloseDate" class="s1-input" /></div>
                            </div>
                        </div>

                    </div>
                </div>

            </div><!-- /s1-main -->
        </div><!-- /s1-layout -->

        <!-- ACTION BAR -->
        <div class="s1-action-bar">
            <button type="submit" class="s1-btn s1-btn-primary" id="wf-submit-btn">
                <span class="s1-btn-spinner"></span>
                <span class="s1-btn-label">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    Save &amp; Review Summary
                </span>
            </button>
            @if (isEdit)
            {
                <a class="s1-btn s1-btn-secondary"
                   asp-controller="Workflow" asp-action="Step1Summary"
                   asp-route-settingsId="@Model.SettingsId">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                    View Summary
                </a>
            }
            <a class="s1-btn s1-btn-outline"
               asp-controller="Workflow" asp-action="SettingsLibrary">
                ← Settings Library
            </a>
        </div>

    </form>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
/* ── Toast ─────────────────────────────────────── */
const WfToast = (() => {
    const c = document.getElementById('wf-toast-container');
    const ICONS  = {success:'✓',error:'✕',warning:'!',info:'i'};
    const TITLES = {success:'Success',error:'Error',warning:'Warning',info:'Info'};
    function show(type, msg, title) {
        const t = document.createElement('div');
        t.className = `wf-toast t-${type}`;
        t.innerHTML = `<div class="wf-toast-main"><div class="wf-toast-stripe"></div>
            <div class="wf-toast-body"><div class="wf-toast-icon">${ICONS[type]}</div>
            <div class="wf-toast-content"><div class="wf-toast-title">${title||TITLES[type]}</div>
            <div class="wf-toast-msg">${msg}</div></div></div>
            <button class="wf-toast-close" aria-label="Dismiss">×</button></div>
            <div class="wf-toast-progress"><div class="wf-toast-bar"></div></div>`;
        c.appendChild(t);
        requestAnimationFrame(() => requestAnimationFrame(() => {
            t.classList.add('show');
            const bar = t.querySelector('.wf-toast-bar');
            bar.style.transition = 'transform 5000ms linear';
            bar.style.transform  = 'scaleX(0)';
        }));
        const timer = setTimeout(() => dismiss(t), 5000);
        t.querySelector('.wf-toast-close').onclick = () => { clearTimeout(timer); dismiss(t); };
    }
    function dismiss(t) {
        t.classList.replace('show','hide');
        t.addEventListener('transitionend', () => t.remove(), {once:true});
    }
    return {success:(m,t)=>show('success',m,t), error:(m,t)=>show('error',m,t),
            warning:(m,t)=>show('warning',m,t), info:(m,t)=>show('info',m,t)};
})();

/* ── Loader ─────────────────────────────────────── */
const WfLoader = (() => {
    const el=document.getElementById('wf-loader'),
          tx=document.getElementById('wf-loader-text'),
          sb=document.getElementById('wf-loader-sub');
    return {
        show:(m,h)=>{tx.textContent=m||'Loading…';sb.textContent=h||'Please wait';el.classList.add('active');},
        hide:()=>el.classList.remove('active')
    };
})();

