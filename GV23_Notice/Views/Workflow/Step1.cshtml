/* ── Client validation ──────────────────────────── */
const REQUIRED = [
    { id:'field-ValuationPeriodCode', errId:'err-ValuationPeriodCode', label:'Valuation Period',
      check:()=>{ const v=document.getElementById('valuationPeriod')?.value; return v&&v!==''; }},
    { id:'field-FinancialYear', errId:'err-FinancialYear', label:'Financial Year',
      check:()=>{ const v=document.getElementById('fyStart')?.value; return v&&v!==''; }},
    { id:'field-RollId', errId:'err-RollId', label:'Roll',
      check:()=>{ const v=document.getElementById('rollSelect')?.value; return v&&v!=='0'&&v!==''; }},
    { id:'field-Notice', errId:'err-Notice', label:'Notice Type',
      check:()=>{ const v=document.getElementById('noticeSelect')?.value; return v&&v!==''; }},
];

function setFieldErr(fieldId, errId, msg) {
    document.getElementById(fieldId)?.classList.toggle('s1-field-invalid', !!msg);
    const el = document.getElementById(errId);
    if (el) el.innerHTML = msg
        ? `<span class="s1-err-text"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> ${msg}</span>`
        : '';
}

function validateAll() {
    const errs = [];
    let hasPeriodErr = false;
    for (const f of REQUIRED) {
        if (!f.check()) { setFieldErr(f.id,f.errId,`${f.label} is required.`); errs.push(f.label); if(f.id.includes('Period')||f.id.includes('Financial')) hasPeriodErr=true; }
        else setFieldErr(f.id,f.errId,null);
    }
    // Sidebar error indicator
    document.getElementById('nav-period')?.classList.toggle('has-error', hasPeriodErr);
    return errs;
}

document.addEventListener('DOMContentLoaded', () => {
    ['valuationPeriod','financialYearSelect','rollSelect','noticeSelect'].forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('change', () => {
            const map = {valuationPeriod:'field-ValuationPeriodCode,err-ValuationPeriodCode',
                         financialYearSelect:'field-FinancialYear,err-FinancialYear',
                         rollSelect:'field-RollId,err-RollId',
                         noticeSelect:'field-Notice,err-Notice'};
            const [fid,eid] = (map[id]||'').split(',');
            if (fid) setFieldErr(fid, eid, null);
        });
    });

    document.getElementById('wf-form').addEventListener('submit', e => {
        const errs = validateAll();
        if (errs.length > 0) {
            e.preventDefault();
            const banner = document.getElementById('valBanner');
            const list   = document.getElementById('valBannerList');
            list.innerHTML = errs.map(x=>`<li>${x} is required</li>`).join('');
            banner.style.display = 'flex';
            banner.scrollIntoView({behavior:'smooth', block:'nearest'});
            WfToast.error('Fix the required fields before continuing.', 'Validation Failed');
            return;
        }
        document.getElementById('valBanner').style.display = 'none';
        document.getElementById('wf-submit-btn').classList.add('loading');
        WfLoader.show('Saving settings…', 'Submitting your notice configuration');
    });
});

function scrollTo(id) {
    document.getElementById(id)?.scrollIntoView({behavior:'smooth', block:'start'});
}

/* ── Notice blocks ──────────────────────────────── */
const NOTICE_DESCS = {
    S49:'Section 49 — objection window, inspection dates and signature',
    S51:'Section 51 — objection decision, evidence close date',
    S52:'Section 52 — appeal notices, backlog processing by date range',
    S53:'Section 53 — appeal period, close date with weekend / holiday adjustment',
    DJ: 'Dear Johnny — only letter date required',
    IN: 'Invalid notice — objection or omission sub-type',
    S78:'Section 78 — review period and extraction settings',
};
const NOTICE_BADGE = {S49:'s1-badge-s49',S51:'s1-badge-s51',S52:'s1-badge-s52',S53:'s1-badge-s53',DJ:'s1-badge-dj',IN:'s1-badge-in',S78:'s1-badge-s78'};

function toIsoDate(d){ return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
function getTodayIso(){ return toIsoDate(new Date()); }

function showBlocks() {
    const notice = document.getElementById('noticeSelect')?.value || 'S49';
    const mode   = document.getElementById('modeSelect')?.value   || '2';

    document.getElementById('noticeHidden').value = notice;

    // Badge + subtitle
    const badge = document.getElementById('noticeBadge');
    if (badge) { badge.textContent = notice; badge.className = `s1-notice-badge ${NOTICE_BADGE[notice]||''}`; }
    const sub = document.getElementById('noticeSpecificSub');
    if (sub && NOTICE_DESCS[notice]) sub.textContent = NOTICE_DESCS[notice];

    // Sidebar notice label
    const sbl = document.getElementById('sb-notice-label');
    const sbd = document.getElementById('sb-notice-desc');
    if (sbl) sbl.textContent = notice;
    if (sbd) sbd.textContent = NOTICE_DESCS[notice]||'';

    // Hide all
    document.querySelectorAll('.notice-block').forEach(b => b.style.display='none');

    const map = {S49:'blockS49',S51:'blockS51',S52:'blockS52',S53:'blockS53',S78:'blockS78'};
    if (map[notice]) document.getElementById(map[notice]).style.display = 'block';
    if (notice==='DJ'||notice==='IN') {
        document.getElementById('blockDJIN').style.display = 'block';
        const hdr  = document.getElementById('djinHeader');
        const note = document.getElementById('djinNote');
        const inSub = document.getElementById('blockINSubType');
        if (notice==='IN') {
            if(hdr)  { hdr.textContent='Invalid Notice'; hdr.className='s1-notice-header s1-notice-in'; }
            if(note) note.style.display='none';
            if(inSub) inSub.style.display='block';
        } else {
            if(hdr)  { hdr.textContent='Dear Johnny Notice'; hdr.className='s1-notice-header s1-notice-dj'; }
            if(note) note.style.display='block';
            if(inSub) inSub.style.display='none';
        }
    }

    const chk   = document.getElementById('overrideS53');
    const ovBlk = document.getElementById('blockS53Override');
    const ap    = document.getElementById('appealCloseDate');
    if (chk) {
        if(ovBlk) ovBlk.style.display = chk.checked?'block':'none';
        if(ap)    ap.readOnly = !chk.checked;
    }

    const letter  = document.getElementById('letterDate')?.value;
    const ovLetter = document.getElementById('letterOverrideBlock');
    if (ovLetter)
        ovLetter.style.display = (notice==='S49'&&letter&&letter!==getTodayIso()) ? 'block':'none';
}

function calcS51EvidenceClose() {
    if (document.getElementById('noticeSelect')?.value!=='S51') return;
    const letter = document.getElementById('letterDate')?.value;
    const out    = document.getElementById('evidenceCloseDate');
    if (!letter||!out) return;
    const dt = new Date(letter+'T00:00:00');
    dt.setDate(dt.getDate()+30);
    out.value = toIsoDate(dt);
}

async function calcS53AppealClose() {
    if (document.getElementById('noticeSelect')?.value!=='S53') return;
    if (document.getElementById('overrideS53')?.checked) return;
    const rollId = document.getElementById('rollSelect')?.value;
    const letter = document.getElementById('letterDate')?.value;
    const out    = document.getElementById('appealCloseDate');
    if (!rollId||rollId==='0'||!letter||!out) return;
    WfLoader.show('Calculating appeal date…','Checking weekends and public holidays');
    try {
        const res = await fetch(`/Workflow/CalcS53AppealCloseDate?rollId=${encodeURIComponent(rollId)}&letterDate=${encodeURIComponent(letter)}`,
            {headers:{'Accept':'application/json'}});
        if (!res.ok) { WfToast.warning('Could not calculate appeal close date.','Calculation Failed'); return; }
        const data = await res.json();
        if (data?.appealCloseDate) { out.value=data.appealCloseDate; WfToast.info(`Appeal close date set to ${data.appealCloseDate}.`,'Date Calculated'); }
    } catch { WfToast.error('Network error.','Error'); }
    finally  { WfLoader.hide(); }
}

async function runAll() {
    showBlocks(); calcS51EvidenceClose(); await calcS53AppealClose();
}

document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('noticeSelect')?.addEventListener('change', runAll);
    document.getElementById('modeSelect')?.addEventListener('change', runAll);
    document.getElementById('rollSelect')?.addEventListener('change', runAll);
    document.getElementById('letterDate')?.addEventListener('change', runAll);
    document.getElementById('overrideS53')?.addEventListener('change', runAll);
    runAll();
});

/* ── Financial year cascade ─────────────────────── */
async function onValuationPeriodChange() {
    const fySelect = document.getElementById('financialYearSelect');
    const code = document.getElementById('valuationPeriod')?.value;
    fySelect.innerHTML = '<option value="">— Select —</option>';
    fySelect.disabled  = true;
    document.getElementById('fyStart').value = '';
    document.getElementById('fyEnd').value   = '';
    document.getElementById('fyText').value  = '';
    setFieldErr('field-FinancialYear','err-FinancialYear',null);
    if (!code) return;
    WfLoader.show('Loading financial years…','Fetching available periods');
    try {
        const res  = await fetch(`/Workflow/FinancialYears?valuationPeriodCode=${encodeURIComponent(code)}`);
        if (!res.ok) { WfToast.error('Failed to load financial years.','Load Error'); return; }
        const list = await res.json();
        const savedStart = document.getElementById('fyStart').value;
        for (const item of list) {
            const opt = document.createElement('option');
            opt.value = `${item.start}|${item.end}|${item.text}`;
            opt.textContent = item.text;
            if (savedStart && item.start && item.start.startsWith(savedStart.substring(0,4))) opt.selected = true;
            fySelect.appendChild(opt);
        }
        fySelect.disabled = false;
        if (list.length) { WfToast.success(`${list.length} year(s) loaded.`,'Loaded'); fySelect.dispatchEvent(new Event('change')); }
    } catch { WfToast.error('Network error.','Error'); }
    finally  { WfLoader.hide(); }
}

function onFinancialYearChange() {
    const v = document.getElementById('financialYearSelect')?.value;
    if (!v) return;
    const [start,end,text] = v.split('|');
    document.getElementById('fyStart').value = start;
    document.getElementById('fyEnd').value   = end;
    document.getElementById('fyText').value  = text;
    setFieldErr('field-FinancialYear','err-FinancialYear',null);
}

document.addEventListener('DOMContentLoaded', async () => {
    const vp = document.getElementById('valuationPeriod')?.value;
    if (vp) await onValuationPeriodChange();
});

/* ── S52 radio ──────────────────────────────────── */
function onS52ModeChange(radio) {
    if (radio) document.getElementById('s52SendModeHidden').value = radio.value;
    const val = parseInt(document.getElementById('s52SendModeHidden').value||'3');
    document.getElementById('blockS52Review').style.display = (val===1||val===3)?'block':'none';
    document.getElementById('blockS52Appeal').style.display = (val===2||val===3)?'block':'none';
    document.querySelectorAll('input[name="S52SendMode"]').forEach(r => r.checked=parseInt(r.value)===val);
}
document.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('blockS52')?.style.display!=='none') onS52ModeChange(null);
});
</script>
}
