@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep2Vm
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Unified Workflow - Step 2 (Preview)";

    bool isInvalid = Model.Notice == NoticeKind.IN;
    bool isS52 = Model.Notice == NoticeKind.S52;
    bool isS53 = Model.Notice == NoticeKind.S53;

    bool supportsSingleEmailMulti =
        Model.Notice == NoticeKind.S49 ||
        Model.Notice == NoticeKind.S51 ||
        Model.Notice == NoticeKind.S53 ||
        Model.Notice == NoticeKind.S78 ||
        Model.Notice == NoticeKind.S52; // keep for S52

    string selectedMode = string.IsNullOrWhiteSpace(Model.SelectedMode)
        ? "single"
        : Model.SelectedMode.Trim().ToLowerInvariant();

    // normalise old "multi" to "emailmulti" (in case old links are used)
    if (selectedMode == "multi") selectedMode = "emailmulti";

    string selectedVariant = string.IsNullOrWhiteSpace(Model.SelectedVariant)
        ? "Default"
        : Model.SelectedVariant.Trim();

    string Step2Link(string variant, string mode)
        => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = variant, mode = mode }) ?? "#";

    string Step2LinkKeepVariant(string mode)
        => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = selectedVariant, mode = mode }) ?? "#";

    bool hasSignature = !string.IsNullOrWhiteSpace(Model.SignaturePath);

    bool isDJ = Model.Notice == NoticeKind.DJ;

    bool allowSplitPdf = !isInvalid && !isDJ;
}


<h2>Unified Notice Workflow - Step 2 (Preview + Approval)</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <div><b>Roll:</b> @Model.RollShortCode - @Model.RollName</div>
    <div><b>Notice:</b> @Model.Notice</div>
    <div><b>Recipient:</b> @Model.RecipientName (@Model.RecipientEmail)</div>
    <div><b>Selected:</b> Variant = <code>@selectedVariant</code>, Mode = <code>@selectedMode</code></div>
</div>

<!-- ======================
     TOP NOTICE VARIANT TABS
     ====================== -->
@if (isInvalid)
{
    <ul class="nav nav-tabs mb-2">
        <li class="nav-item">
            <a class="nav-link @(selectedVariant == "InvalidOmission" ? "active" : "")"
               href="@Step2Link("InvalidOmission", "single")">
                Invalid Omission
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @((selectedVariant == "InvalidObjection" || selectedVariant == "Default") ? "active" : "")"
               href="@Step2Link("InvalidObjection", "single")">
                Invalid Objection
            </a>
        </li>
    </ul>
}
else if (isS52)
{
    <ul class="nav nav-tabs mb-2">
        <li class="nav-item">
            <a class="nav-link @((selectedVariant == "S52Appeal" || selectedVariant == "Default") ? "active" : "")"
               href="@Step2Link("S52Appeal", selectedMode)">
                Appeal Decision
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(selectedVariant == "S52Review" ? "active" : "")"
               href="@Step2Link("S52Review", selectedMode)">
                Section 52 Review
            </a>
        </li>
    </ul>

    <!-- Sub tabs: Single / Email Multi -->
    <ul class="nav nav-pills mb-3">
        <li class="nav-item">
            <a class="nav-link @(selectedMode == "single" ? "active" : "")" href="@Step2LinkKeepVariant("single")">Single</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(selectedMode == "emailmulti" ? "active" : "")" href="@Step2LinkKeepVariant("emailmulti")">Email Multi</a>
        </li>
    </ul>
}
else if (supportsSingleEmailMulti && !isInvalid)
{
    <ul class="nav nav-pills mb-3">
        <li class="nav-item">
            <a class="nav-link @(selectedMode == "single" ? "active" : "")"
               href="@Step2LinkKeepVariant("single")">
                Single
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(selectedMode == "emailmulti" ? "active" : "")"
               href="@Step2LinkKeepVariant("emailmulti")">
                Email Multi
            </a>
        </li>

        @* ✅ Split for ALL notices except DJ/IN *@
        @if (allowSplitPdf)
        {
            <li class="nav-item">
                <a class="nav-link @(selectedMode == "splitpdf" ? "active" : "")"
                   href="@Step2LinkKeepVariant("splitpdf")">
                    Split PDF
                </a>
            </li>
        }
    </ul>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <b>PDF Preview</b>
                <a class="btn btn-sm btn-outline-secondary"
                   href="@Model.PdfUrl"
                   target="_blank">
                    Open PDF in new tab
                </a>
            </div>

            <div class="card-body" style="height:78vh;">
                <iframe src="@Model.PdfUrl" style="width:100%; height:100%; border:1px solid #ddd;"></iframe>
            </div>

            <div class="card-footer text-muted">
                <small>
                    Mode controls:
                    <b>Single</b> = normal preview,
                    <b>Email Multi</b> = recipient has many properties (email grouping),
                    <b>Split PDF</b> (S53) = split rows (Multipurpose total + component categories).
                </small>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <!-- Step1 Snapshot (Dates + Signature) -->
        <div class="card mb-3">
            <div class="card-header"><b>Step 1 Snapshot (Dates & Signature)</b></div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6"><b>Letter Date:</b> @Model.LetterDate.ToString("yyyy-MM-dd")</div>
                    <div class="col-6"><b>City Manager Sign Date:</b> @(Model.CityManagerSignDate?.ToString("yyyy-MM-dd") ?? "-")</div>

                    <div class="col-6"><b>Objection Start:</b> @(Model.ObjectionStartDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Objection End:</b> @(Model.ObjectionEndDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Extension Date:</b> @(Model.ExtensionDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Evidence Close:</b> @(Model.EvidenceCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>

                    <div class="col-6"><b>Bulk From:</b> @(Model.BulkFromDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Bulk To:</b> @(Model.BulkToDate?.ToString("yyyy-MM-dd") ?? "-")</div>

                    <div class="col-6"><b>Batch Date:</b> @(Model.BatchDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Appeal Close:</b> @(Model.AppealCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>

                    <div class="col-6"><b>Extraction Date:</b> @(Model.ExtractionDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Extract Days:</b> @(Model.ExtractPeriodDays?.ToString() ?? "-")</div>
                    <div class="col-6"><b>Review Open:</b> @(Model.ReviewOpenDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-6"><b>Review Close:</b> @(Model.ReviewCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <b>Signature:</b>
                        @if (hasSignature)
                        {
                            <span class="badge bg-success">Uploaded</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Not Uploaded</span>
                        }
                    </div>

                    @if (hasSignature)
                    {
                        <small class="text-muted text-truncate" style="max-width: 250px;">
                            @Model.SignaturePath
                        </small>
                    }
                </div>

                <div class="mt-2">
                    <b>Status:</b>
                    @if (Model.IsConfirmed)
                    {
                        <span class="badge bg-primary">Confirmed</span>
                    }
                    else
                    {

                        <span class="badge bg-secondary">Not Confirmed</span>
                    }
                    @if (Model.IsApproved)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else
                    {

                        <span class="badge bg-secondary">Not Approved</span>
                    }
                </div>
            </div>
        </div>

        <!-- Email Preview -->
        <div class="card mb-3">
            <div class="card-header"><b>Email Preview</b></div>
            <div class="card-body">
                <div class="mb-2"><b>Subject:</b> @Model.EmailSubject</div>
                <div class="border p-2" style="max-height:40vh; overflow:auto;">
                    @Html.Raw(Model.EmailBodyHtml)
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-success" type="button" data-bs-toggle="modal" data-bs-target="#approveModal">
                Approve
            </button>

            <button class="btn btn-warning" type="button" data-bs-toggle="modal" data-bs-target="#corrModal">
                Request Correction
            </button>

            <a class="btn btn-secondary" href="@Url.Action("Step1", "Workflow", new { settingsId = Model.SettingsId })">
                Back to Step 1
            </a>
        </div>
    </div>
</div>

<!-- APPROVE MODAL -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Step2Approve" asp-controller="Workflow" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                <input type="hidden" name="variant" value="@selectedVariant" />
                <input type="hidden" name="mode" value="@selectedMode" />

                <div class="modal-header">
                    <h5 class="modal-title">Approve Settings (Generate Handover Email to Data Team)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p class="mb-2">
                        You are about to <b>approve</b> the Step 1 settings. The system will generate an official approval email
                        (with the secure kickoff link) and save it to:
                        <br />
                        <code>Notice Email approval_Request\Approval\V@Model.Version</code>
                    </p>

                    <div class="alert alert-secondary">
                        <div><b>Roll:</b> @Model.RollShortCode - @Model.RollName</div>
                        <div><b>Notice:</b> @Model.Notice</div>
                        <div><b>Variant:</b> @selectedVariant</div>
                        <div><b>Mode:</b> @selectedMode</div>
                        <hr />
                        <div><b>Letter Date:</b> @Model.LetterDate.ToString("yyyy-MM-dd")</div>

                        @if (Model.Notice == NoticeKind.S49)
                        {
                            <div><b>Objection Period:</b> @(Model.ObjectionStartDate?.ToString("yyyy-MM-dd") ?? "-") to @(Model.ObjectionEndDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                            <div><b>Extension:</b> @(Model.ExtensionDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                            <div><b>Signature:</b> @(hasSignature ? "Uploaded" : "NOT UPLOADED")</div>
                        }
                        @if (Model.Notice == NoticeKind.S51)
                        {
                            <div><b>Evidence Close Date:</b> @(Model.EvidenceCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                        }
                        @if (Model.Notice == NoticeKind.S52)
                        {
                            <div><b>Bulk Range:</b> @(Model.BulkFromDate?.ToString("yyyy-MM-dd") ?? "-") to @(Model.BulkToDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                        }
                        @if (Model.Notice == NoticeKind.S53)
                        {
                            <div><b>Batch Date:</b> @(Model.BatchDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                            <div><b>Appeal Close Date:</b> @(Model.AppealCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                        }
                        @if (Model.Notice == NoticeKind.S78)
                        {
                            <div><b>Extraction Date:</b> @(Model.ExtractionDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                            <div><b>Review Period:</b> @(Model.ReviewOpenDate?.ToString("yyyy-MM-dd") ?? "-") to @(Model.ReviewCloseDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                        }
                    </div>

                    <p class="mb-0 text-muted">
                        <small>Approval does not send emails to clients. Step 3 (Data Team) will batch, print PDFs and send to clients.</small>
                    </p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Approval</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- CORRECTION MODAL -->
<div class="modal fade" id="corrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Step2RequestCorrection" asp-controller="Workflow" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                <input type="hidden" name="variant" value="@selectedVariant" />
                <input type="hidden" name="mode" value="@selectedMode" />

                <div class="modal-header">
                    <h5 class="modal-title">Request Correction (Save Correction Email to Folder)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <p class="mb-2">
                        This will generate a <b>correction request</b> email and save it to:
                        <br />
                        <code>Notice Email approval_Request\Correction\V@Model.Version</code>
                    </p>

                    <div class="alert alert-secondary">
                        <div><b>Roll:</b> @Model.RollShortCode - @Model.RollName</div>
                        <div><b>Notice:</b> @Model.Notice</div>
                        <div><b>Variant:</b> @selectedVariant</div>
                        <div><b>Mode:</b> @selectedMode</div>
                        <div><b>Letter Date:</b> @Model.LetterDate.ToString("yyyy-MM-dd")</div>
                        <div><b>Signature:</b> @(hasSignature ? "Uploaded" : "Not Uploaded")</div>
                    </div>

                    <label class="form-label">Correction comment (required)</label>
                    <textarea class="form-control" name="correctionComment" rows="5" required
                              placeholder="Explain what must be corrected (PDF wording, dates, email body, layout, etc)."></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Submit Correction</button>
                </div>
            </form>
        </div>
    </div>
</div>
