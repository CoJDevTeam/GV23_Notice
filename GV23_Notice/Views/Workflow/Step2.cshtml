@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep2Vm
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Unified Workflow - Step 2 (Preview)";

    bool isInvalid = Model.Notice == NoticeKind.IN;
    bool isS52 = Model.Notice == NoticeKind.S52;
    bool isS53 = Model.Notice == NoticeKind.S53;

    bool supportsSingleEmailMulti =
        Model.Notice == NoticeKind.S49 ||
        Model.Notice == NoticeKind.S51 ||
        Model.Notice == NoticeKind.S53 ||
        Model.Notice == NoticeKind.S78 ||
        Model.Notice == NoticeKind.S52;

    string selectedMode = string.IsNullOrWhiteSpace(Model.SelectedMode)
        ? "single"
        : Model.SelectedMode.Trim().ToLowerInvariant();

    if (selectedMode == "multi") selectedMode = "emailmulti";

    string selectedVariant = string.IsNullOrWhiteSpace(Model.SelectedVariant)
        ? "Default"
        : Model.SelectedVariant.Trim();

    string Step2Link(string variant, string mode)
     => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = variant, mode = mode, appealNo = Model.AppealNo }) ?? "#";

    string Step2LinkKeepVariant(string mode)
        => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = selectedVariant, mode = mode, appealNo = Model.AppealNo }) ?? "#";

    bool hasSignature = !string.IsNullOrWhiteSpace(Model.SignaturePath);
    bool isDJ = Model.Notice == NoticeKind.DJ;
    bool allowSplitPdf = !isInvalid && !isDJ;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/step2css.css" rel="stylesheet" />
</head>
<body>

    <!-- ═══════════════════════════════════════════
         PAGE HEADER
    ═══════════════════════════════════════════ -->
    <header class="page-header">
        <div class="brand">
            <span class="brand-badge">GV23</span>
            <span class="brand-title">Notice Management System</span>
        </div>

        <div class="step-indicator">
            <span style="font-size:11px;color:#888;margin-right:6px;font-weight:600;">STEP</span>
            <div class="step-pip done"></div>
            <div class="step-pip active"></div>
            <div class="step-pip"></div>
            <span style="font-size:11px;color:var(--gold);font-weight:700;margin-left:6px;">2 of 3 — Preview & Approve</span>
        </div>
    </header>

    <!-- ═══════════════════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════════════════ -->
    <div class="main-wrap">

        <!-- ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">✓ @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">⚠ @TempData["Error"]</div>
        }

        <!-- META BAR -->
        <div class="meta-bar">
            <h2>Step 2 — Preview &amp; Approval</h2>
            <div class="meta-pills">
                <div class="meta-pill"><strong>Roll:</strong> @Model.RollShortCode — @Model.RollName</div>
                <div class="meta-pill"><strong>Notice:</strong> @Model.Notice</div>
                <div class="meta-pill"><strong>Recipient:</strong> @Model.RecipientName (@Model.RecipientEmail)</div>
                <div class="meta-pill"><strong>Variant:</strong> @selectedVariant &nbsp;|&nbsp; <strong>Mode:</strong> @selectedMode</div>
            </div>
        </div>

        <!-- ──────────────── VARIANT / MODE TABS ──────────────── -->
        @if (isInvalid)
        {
            <div class="tab-row">
                <span class="tab-label">Variant</span>
                <a class="tab-btn @(selectedVariant == "InvalidOmission" ? "active" : "")"
                   href="@Step2Link("InvalidOmission", "single")">Invalid Omission</a>
                <a class="tab-btn @((selectedVariant == "InvalidObjection" || selectedVariant == "Default") ? "active" : "")"
                   href="@Step2Link("InvalidObjection", "single")">Invalid Objection</a>
            </div>
        }
        else if (isS52)
        {
            <div class="tab-row">
                <span class="tab-label">Variant</span>
                <a class="tab-btn @((selectedVariant == "S52Appeal" || selectedVariant == "Default") ? "active" : "")"
                   href="@Step2Link("S52Appeal", selectedMode)">Appeal Decision</a>
                <a class="tab-btn @(selectedVariant == "S52Review" ? "active" : "")"
                   href="@Step2Link("S52Review", selectedMode)">Section 52 Review</a>
                <div class="tab-divider"></div>
                <span class="tab-label">Mode</span>
                <a class="tab-btn @(selectedMode == "single" ? "active" : "")" href="@Step2LinkKeepVariant("single")">Single</a>
                <a class="tab-btn @(selectedMode == "emailmulti" ? "active" : "")" href="@Step2LinkKeepVariant("emailmulti")">Email Multi</a>
            </div>
            @* AppealNo lookup — required to load an S52 preview from the DB *@
            <div class="tab-row" style="margin-top:8px;align-items:center;gap:10px;flex-wrap:wrap;">
                <span class="tab-label">Appeal No</span>
                <form method="get" action="@Url.Action("Step2","Workflow")" style="display:flex;gap:8px;align-items:center;">
                    <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                    <input type="hidden" name="variant" value="@selectedVariant" />
                    <input type="hidden" name="mode" value="@selectedMode" />
                    <input type="text" name="appealNo" value="@Model.AppealNo"
                           placeholder="e.g. APL-GV23-0001"
                           style="font-size:12px;padding:5px 9px;border:1px solid #ccc;border-radius:4px;width:200px;" />
                    <button type="submit"
                            style="font-size:12px;padding:5px 12px;background:#e6b000;border:none;border-radius:4px;cursor:pointer;font-weight:600;">
                        Load Preview
                    </button>
                    @if (!string.IsNullOrWhiteSpace(Model.AppealNo))
                    {
                        <span style="font-size:11px;color:#555;">Previewing: <b>@Model.AppealNo</b></span>
                    }
                    else
                    {
                        <span style="font-size:11px;color:#c0392b;">⚠ Enter an Appeal No to load the preview</span>
                    }
                </form>
            </div>
        }
        else if (supportsSingleEmailMulti && !isInvalid)
        {
            <div class="tab-row">
                <span class="tab-label">Mode</span>
                <a class="tab-btn @(selectedMode == "single" ? "active" : "")" href="@Step2LinkKeepVariant("single")">Single</a>
                <a class="tab-btn @(selectedMode == "emailmulti" ? "active" : "")" href="@Step2LinkKeepVariant("emailmulti")">Email Multi</a>
                @if (allowSplitPdf)
                {
                    <a class="tab-btn @(selectedMode == "splitpdf" ? "active" : "")" href="@Step2LinkKeepVariant("splitpdf")">Split PDF</a>
                }
            </div>
        }

        <!-- ──────────────── MAIN GRID ──────────────── -->
        <div class="content-grid">

            <!-- LEFT: PDF PREVIEW -->
            <div class="card pdf-card">
                <div class="card-header">
                    <div class="header-title">
                        <div class="header-accent"></div>
                        PDF Preview
                    </div>
                    <a class="btn-open-pdf" href="@Model.PdfUrl" target="_blank">
                        ↗ Open in New Tab
                    </a>
                </div>
                <div class="card-body">
                    <iframe src="@Model.PdfUrl" title="Notice PDF Preview"></iframe>
                </div>
                <div class="card-footer">
                    <b>Single</b> = Standard notice preview &nbsp;·&nbsp;
                    <b>Email Multi</b> = Recipient holds multiple properties (email grouping) &nbsp;·&nbsp;
                    <b>Split PDF</b> = Rows split by category (S53 Multipurpose)
                </div>
            </div>

            <!-- RIGHT: SIDE PANEL -->
            <div class="side-panel">

                <!-- STEP 1 SNAPSHOT -->
                <div class="card">
                    <div class="card-header">
                        <div class="header-title">
                            <div class="header-accent"></div>
                            Step 1 Snapshot — Dates &amp; Signature
                        </div>
                        <div>
                            @if (Model.IsConfirmed)
                            {
                                <span class="badge badge-gold">✓ Confirmed</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Not Confirmed</span>
                            }
                            @if (Model.IsApproved)
                            {
                                <span class="badge badge-success">✓ Approved</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Not Approved</span>
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="snapshot-grid">
                            <div class="snap-item">
                                <span class="snap-label">Letter Date</span>
                                <span class="snap-value">@Model.LetterDate.ToString("yyyy-MM-dd")</span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">City Manager Sign</span>
                                <span class="snap-value @(Model.CityManagerSignDate == null ? "empty" : "")">
                                    @(Model.CityManagerSignDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Objection Start</span>
                                <span class="snap-value @(Model.ObjectionStartDate == null ? "empty" : "")">
                                    @(Model.ObjectionStartDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Objection End</span>
                                <span class="snap-value @(Model.ObjectionEndDate == null ? "empty" : "")">
                                    @(Model.ObjectionEndDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Extension Date</span>
                                <span class="snap-value @(Model.ExtensionDate == null ? "empty" : "")">
                                    @(Model.ExtensionDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Evidence Close</span>
                                <span class="snap-value @(Model.EvidenceCloseDate == null ? "empty" : "")">
                                    @(Model.EvidenceCloseDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Bulk From</span>
                                <span class="snap-value @(Model.BulkFromDate == null ? "empty" : "")">
                                    @(Model.BulkFromDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Bulk To</span>
                                <span class="snap-value @(Model.BulkToDate == null ? "empty" : "")">
                                    @(Model.BulkToDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Batch Date</span>
                                <span class="snap-value @(Model.BatchDate == null ? "empty" : "")">
                                    @(Model.BatchDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Appeal Close</span>
                                <span class="snap-value @(Model.AppealCloseDate == null ? "empty" : "")">
                                    @(Model.AppealCloseDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Extraction Date</span>
                                <span class="snap-value @(Model.ExtractionDate == null ? "empty" : "")">
                                    @(Model.ExtractionDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Extract Days</span>
                                <span class="snap-value @(Model.ExtractPeriodDays == null ? "empty" : "")">
                                    @(Model.ExtractPeriodDays?.ToString() ?? "—")
                                </span>
                            </div>

                            <div class="snap-item">
                                <span class="snap-label">Review Open</span>
                                <span class="snap-value @(Model.ReviewOpenDate == null ? "empty" : "")">
                                    @(Model.ReviewOpenDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                            <div class="snap-item">
                                <span class="snap-label">Review Close</span>
                                <span class="snap-value @(Model.ReviewCloseDate == null ? "empty" : "")">
                                    @(Model.ReviewCloseDate?.ToString("yyyy-MM-dd") ?? "—")
                                </span>
                            </div>
                        </div>

                        <!-- SIGNATURE ROW -->
                        <div class="sig-row" style="margin-top: 14px;">
                            <span class="sig-label">Signature</span>
                            @if (hasSignature)
                            {
                                <span class="badge badge-success">✓ Uploaded</span>
                                <span class="sig-path" title="@Model.SignaturePath">@Model.SignaturePath</span>
                            }
                            else
                            {
                                <span class="badge badge-warn">⚠ Not Uploaded</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- EMAIL PREVIEW -->
                <div class="card">
                    <div class="card-header">
                        <div class="header-title">
                            <div class="header-accent"></div>
                            Email Preview
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="email-subject">
                            <span class="subj-label">Subject</span>
                            @Model.EmailSubject
                        </div>
                        <div class="email-body-wrap">
                            @Html.Raw(Model.EmailBodyHtml)
                        </div>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="action-bar">
                        <button class="btn btn-approve" type="button" onclick="openModal('approveModal')">
                            ✓ Approve
                        </button>
                        <button class="btn btn-correct" type="button" onclick="openModal('corrModal')">
                            ✎ Request Correction
                        </button>
                        <a class="btn btn-back" href="@Url.Action("Step1", "Workflow", new { settingsId = Model.SettingsId })">
                            ← Back to Step 1
                        </a>
                    </div>
                </div>

            </div><!-- /side-panel -->
        </div><!-- /content-grid -->
    </div><!-- /main-wrap -->
    <!-- ═══════════════════════════════════════════
         APPROVE MODAL
    ═══════════════════════════════════════════ -->
    <div class="modal-overlay" id="approveModal">
        <div class="modal-box">
            <form asp-action="Step2Approve" asp-controller="Workflow" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                <input type="hidden" name="variant" value="@selectedVariant" />
                <input type="hidden" name="mode" value="@selectedMode" />
                @if (!string.IsNullOrWhiteSpace(Model.AppealNo))
                {
                    <input type="hidden" name="appealNo" value="@Model.AppealNo" />
                }

                <div class="modal-head">
                    <h5>Approve — Generate Handover Email</h5>
                    <button type="button" class="modal-close" onclick="closeModal('approveModal')">✕</button>
                </div>

                <div class="modal-body">
                    <p>
                        You are about to <strong>approve</strong> the Step 1 settings. The system will generate an official approval
                        email with the secure kickoff link and save it to:<br />
                        <code>Notice Email approval_Request\Approval\@Model.Version</code>
                    </p>

                    <div class="modal-summary">
                        <div class="ms-row"><span class="ms-key">Roll</span><span class="ms-val">@Model.RollShortCode — @Model.RollName</span></div>
                        <div class="ms-row"><span class="ms-key">Notice</span><span class="ms-val">@Model.Notice</span></div>
                        @if (Model.Notice == NoticeKind.S52)
                        {
                            <div class="ms-row"><span class="ms-key">Sub-type</span><span class="ms-val">@(Model.IsSection52Review == true ? "Section 52 Review" : "Appeal Decision")</span></div>
                        }
                        <div class="ms-row"><span class="ms-key">Variant</span><span class="ms-val">@selectedVariant</span></div>
                        <div class="ms-row"><span class="ms-key">Mode</span><span class="ms-val">@selectedMode</span></div>
                        <div class="ms-row"><span class="ms-key">Letter Date</span><span class="ms-val">@Model.LetterDate.ToString("yyyy-MM-dd")</span></div>

                        @if (Model.Notice == NoticeKind.S49)
                        {
                            <div class="ms-row"><span class="ms-key">Objection Period</span><span class="ms-val">@(Model.ObjectionStartDate?.ToString("yyyy-MM-dd") ?? "—") → @(Model.ObjectionEndDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                            <div class="ms-row"><span class="ms-key">Extension</span><span class="ms-val">@(Model.ExtensionDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                            <div class="ms-row"><span class="ms-key">Signature</span><span class="ms-val">@(hasSignature ? "Uploaded" : "⚠ NOT UPLOADED")</span></div>
                        }
                        @if (Model.Notice == NoticeKind.S51)
                        {
                            <div class="ms-row"><span class="ms-key">Evidence Close</span><span class="ms-val">@(Model.EvidenceCloseDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                        }
                        @if (Model.Notice == NoticeKind.S52)
                        {
                            <div class="ms-row"><span class="ms-key">Bulk Range</span><span class="ms-val">@(Model.BulkFromDate?.ToString("yyyy-MM-dd") ?? "—") → @(Model.BulkToDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                            @if (!string.IsNullOrWhiteSpace(Model.AppealNo))
                            {
                                <div class="ms-row"><span class="ms-key">Appeal No (preview)</span><span class="ms-val">@Model.AppealNo</span></div>
                            }
                            <div class="ms-row" style="background:#fffbe6;border-left:3px solid #e6b000;padding:8px 12px;">
                                <span class="ms-key" style="color:#b38900;">ℹ Links</span>
                                <span class="ms-val" style="color:#555;font-size:12px;">The approval email will contain <strong>two kickoff links</strong> — one for Appeal Decision, one for Section 52 Review.</span>
                            </div>
                        }
                        @if (Model.Notice == NoticeKind.S53)
                        {
                            <div class="ms-row"><span class="ms-key">Batch Date</span><span class="ms-val">@(Model.BatchDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                            <div class="ms-row"><span class="ms-key">Appeal Close</span><span class="ms-val">@(Model.AppealCloseDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                        }
                        @if (Model.Notice == NoticeKind.S78)
                        {
                            <div class="ms-row"><span class="ms-key">Extraction Date</span><span class="ms-val">@(Model.ExtractionDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                            <div class="ms-row"><span class="ms-key">Review Period</span><span class="ms-val">@(Model.ReviewOpenDate?.ToString("yyyy-MM-dd") ?? "—") → @(Model.ReviewCloseDate?.ToString("yyyy-MM-dd") ?? "—")</span></div>
                        }
                    </div>

                    <div class="modal-note">
                        ℹ Approval does not send emails to clients. Step 3 (Data Team) will batch, print PDFs and send to clients.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-back" onclick="closeModal('approveModal')">Cancel</button>
                    <button type="submit" class="btn btn-approve">✓ Confirm Approval</button>
                </div>
            </form>
        </div>
    </div>


    <!-- ═══════════════════════════════════════════
         CORRECTION MODAL
    ═══════════════════════════════════════════ -->
    <div class="modal-overlay" id="corrModal">
        <div class="modal-box">
            <form asp-action="Step2RequestCorrection" asp-controller="Workflow" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                <input type="hidden" name="variant" value="@selectedVariant" />
                <input type="hidden" name="mode" value="@selectedMode" />

                <div class="modal-head">
                    <h5>Request Correction</h5>
                    <button type="button" class="modal-close" onclick="closeModal('corrModal')">✕</button>
                </div>

                <div class="modal-body">
                    <p>
                        A <strong>correction request</strong> email will be generated and saved to:<br />
                        <code>Notice Email approval_Request\Correction\@Model.Version</code>
                    </p>

                    <div class="modal-summary">
                        <div class="ms-row"><span class="ms-key">Roll</span><span class="ms-val">@Model.RollShortCode — @Model.RollName</span></div>
                        <div class="ms-row"><span class="ms-key">Notice</span><span class="ms-val">@Model.Notice</span></div>
                        <div class="ms-row"><span class="ms-key">Variant</span><span class="ms-val">@selectedVariant</span></div>
                        <div class="ms-row"><span class="ms-key">Mode</span><span class="ms-val">@selectedMode</span></div>
                        <div class="ms-row"><span class="ms-key">Letter Date</span><span class="ms-val">@Model.LetterDate.ToString("yyyy-MM-dd")</span></div>
                        <div class="ms-row"><span class="ms-key">Signature</span><span class="ms-val">@(hasSignature ? "Uploaded" : "Not Uploaded")</span></div>
                    </div>

                    <label class="form-label">Correction Comment <span style="color:var(--danger)">*</span></label>
                    <textarea class="form-control" name="correctionComment" rows="5" required
                              placeholder="Explain what must be corrected — PDF wording, dates, email body, layout, etc."></textarea>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-back" onclick="closeModal('corrModal')">Cancel</button>
                    <button type="submit" class="btn btn-correct">✎ Submit Correction</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openModal(id) {
          document.getElementById(id).classList.add('open');
          document.body.style.overflow = 'hidden';
        }
        function closeModal(id) {
          document.getElementById(id).classList.remove('open');
          document.body.style.overflow = '';
        }
        // Close on overlay click
        document.querySelectorAll('.modal-overlay').forEach(el => {
          el.addEventListener('click', function(e) {
            if (e.target === el) closeModal(el.id);
          });
        });
        // Close on Escape
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') {
            document.querySelectorAll('.modal-overlay.open').forEach(el => closeModal(el.id));
          }
        });
    </script>

</body>
</html>
