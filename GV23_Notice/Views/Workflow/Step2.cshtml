@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep2Vm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 2 — Preview";

    bool isInvalid = Model.Notice == NoticeKind.IN;
    bool isS52 = Model.Notice == NoticeKind.S52;
    bool isTpa = Model.Notice == NoticeKind.TPA;
    bool isClaTpa = Model.Notice == NoticeKind.CLA_TPA;
    bool isDirectThirdPartyNotice = isTpa || isClaTpa;
    bool supportsSingleEmailMulti =
        Model.Notice is NoticeKind.S49 or NoticeKind.S51 or NoticeKind.S53
                     or NoticeKind.S78 or NoticeKind.S52;

    string selectedMode = string.IsNullOrWhiteSpace(Model.SelectedMode)
        ? "single"
        : Model.SelectedMode.Trim().ToLowerInvariant();
    if (selectedMode == "multi") selectedMode = "emailmulti";

    string selectedVariant = string.IsNullOrWhiteSpace(Model.SelectedVariant)
        ? "Default"
        : Model.SelectedVariant.Trim();

    string S2Link(string variant, string mode)
        => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant, mode, appealNo = Model.AppealNo }) ?? "#";

    string S2LinkKeep(string mode)
        => Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = selectedVariant, mode, appealNo = Model.AppealNo }) ?? "#";

    bool hasSignature = !string.IsNullOrWhiteSpace(Model.SignaturePath);
    bool isDJ = Model.Notice == NoticeKind.DJ;
    bool allowSplitPdf =
      !isInvalid &&
      !isDJ &&
      !isDirectThirdPartyNotice;

    string NoticeName(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection & Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => "Section 52 — Appeal Notices",
        NoticeKind.S53 => "Section 53 — MVD Decision",
        NoticeKind.DJ => "Dear Johnny Notice",
        NoticeKind.IN => "Invalid Notice",
        NoticeKind.S78 => "Section 78 — Review Period",
        NoticeKind.TPA => "Third-Party Appeal Application",
        NoticeKind.CLA_TPA => "CLA-THIRD PARTY APPLICATION NOTICE",
        _ => n.ToString()
    };
}

@* <link href="~/css/admincss/step2css.css" rel="stylesheet" asp-append-version="true" /> *@
<link href="~/css/step2/step2css.css" rel="stylesheet" />
<div class="s2-root">

    <!-- Top bar -->
    <div class="s2-topbar">
        <div class="s2-topbar-left">
            <div class="s2-logo-mark">VNS</div>
            <div class="s2-topbar-div"></div>
            <div>
                <div class="s2-page-title">Notice Preview</div>
                <div class="s2-page-sub">Step 2 — Review the notice and email, then start Step 3</div>
            </div>
        </div>
        <div class="s2-topbar-right">
            <a class="s2-topbar-link" asp-controller="Workflow" asp-action="SettingsLibrary">
                ← Settings Library
            </a>
            <a class="s2-topbar-link" asp-controller="Workflow" asp-action="Step1"
               asp-route-settingsId="@Model.SettingsId">
                Edit Step 1
            </a>
        </div>
    </div>

    <!-- Stepper -->
    <div class="s2-stepper">
        <div class="s2-step done">
            <div class="s2-step-num">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div class="s2-step-label">Configure Dates</div>
        </div>
        <div class="s2-step-line"></div>
        <div class="s2-step active">
            <div class="s2-step-num">2</div>
            <div class="s2-step-label">Preview</div>
        </div>
        <div class="s2-step-line"></div>
        <div class="s2-step">
            <div class="s2-step-num">3</div>
            <div class="s2-step-label">Start Step 3</div>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="s2-alert s2-alert-ok">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="s2-alert s2-alert-err">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            @TempData["Error"]
        </div>
    }

    <!-- Meta pills -->
    <div class="s2-meta-bar">
        <span class="s2-meta-pill s2-notice-pill">@NoticeName(Model.Notice)</span>
        <span class="s2-meta-pill"><strong>Roll:</strong> @Model.RollShortCode — @Model.RollName</span>
        <span class="s2-meta-pill"><strong>@(isClaTpa
                    ? "Notification Date:"
                    : "Letter Date:")
            </strong>

            @Model.LetterDate.ToString("dd MMM yyyy")
        </span>
        <span class="s2-meta-pill"><strong>Recipient:</strong> @Model.RecipientName</span>
        @if (!isDirectThirdPartyNotice)
        {
            <span class="s2-meta-pill">
                <strong>Mode:</strong> @selectedMode
                &nbsp;|&nbsp;
                <strong>Variant:</strong> @selectedVariant
            </span>
        }
        else if (isClaTpa)
        {
            <span class="s2-meta-pill">
                <strong>Representation Period:</strong>
                30 calendar days
            </span>
        }
        else
        {
            <span class="s2-meta-pill">
                <strong>Owner Response Period:</strong>
                51 calendar days
            </span>
        }
    </div>

    <!-- Variant / Mode tabs -->
    @if (isInvalid)
    {
        <div class="s2-tabs">
            <span class="s2-tab-label">Variant</span>
            <a class="s2-tab @(selectedVariant == "InvalidOmission" ? "active" : "")"
               href="@S2Link("InvalidOmission", "single")">Invalid Omission</a>
            <a class="s2-tab @((selectedVariant == "InvalidObjection" || selectedVariant == "Default") ? "active" : "")"
               href="@S2Link("InvalidObjection", "single")">Invalid Objection</a>
        </div>
    }
    else if (isS52)
    {
        bool canReview = Model.S52CanShowReview;
        bool canAppeal = Model.S52CanShowAppealDecision;
        <div class="s2-tabs">
            <span class="s2-tab-label">Variant</span>
            @if (canAppeal)
            {
                <a class="s2-tab @((selectedVariant == "S52Appeal" || selectedVariant == "Default") ? "active" : "")"
                     href="@S2Link("S52Appeal", selectedMode)">Appeal Decision</a>
            }
            else
            {

                     <span class="s2-tab-disabled" title="Not selected on Step 1">Appeal Decision</span>
                 }
            @if (canReview)
            {
                <a class="s2-tab @(selectedVariant == "S52Review" ? "active" : "")"
                     href="@S2Link("S52Review", selectedMode)">Section 52 Review</a>
            }
            else
            {

                     <span class="s2-tab-disabled" title="Not selected on Step 1">Section 52 Review</span>
                 }
            <div class="s2-tab-divider"></div>
            <span class="s2-tab-label">Mode</span>
            <a class="s2-tab @(selectedMode == "single" ? "active" : "")" href="@S2LinkKeep("single")">Single</a>
            <a class="s2-tab @(selectedMode == "emailmulti" ? "active" : "")" href="@S2LinkKeep("emailmulti")">Email Multi</a>
        </div>
        @if (canReview && canAppeal)
        {
            <div class="s2-both-banner">
                ✅ <strong>Both</strong> sub-types selected — review each tab before starting Step 3.
            </div>
        }
    }
    else if (supportsSingleEmailMulti)
    {
        <div class="s2-tabs">
            <span class="s2-tab-label">Mode</span>
            <a class="s2-tab @(selectedMode == "single" ? "active" : "")" href="@S2LinkKeep("single")">Single</a>
            <a class="s2-tab @(selectedMode == "emailmulti" ? "active" : "")" href="@S2LinkKeep("emailmulti")">Email Multi</a>
            @if (allowSplitPdf)
            {
                <a class="s2-tab @(selectedMode == "splitpdf" ? "active" : "")" href="@S2LinkKeep("splitpdf")">Split PDF</a>
            }
        </div>
    }

    <!-- Body grid -->
    <div class="s2-body">
        @if (!Model.PreviewFound)
{
    <div style="grid-column:1 / -1;">
        @await Html.PartialAsync("_NotFoundPartial", Model)
    </div>
}
else
{
        <!-- PDF preview -->
        <div class="s2-card">
            <div class="s2-card-head">
                <div class="s2-card-title">
                    <div class="s2-card-accent"></div>
                    PDF Preview
                </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PdfUrl))
                    {
                        <a href="@Model.PdfUrl" target="_blank" style="font-size:12px;font-weight:700;color:var(--s2-gold-d);text-decoration:none;">
                            ↗ Open in New Tab
                        </a>
                    }
            </div>
            <div class="s2-card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.PdfUrl))
                    {
                        <iframe class="s2-pdf-iframe" src="@Model.PdfUrl" title="Notice PDF Preview"></iframe>
                    }
                    else
                    {
                        @await Html.PartialAsync("_NotFoundPartial", Model)
                    }
            </div>
                <div class="s2-card-foot">
                    @if (isClaTpa)
                    {
                        <span>
                            Preview of one CLA property-owner notification.
                            Bulk printing will process all linked CLA records during Step 3.
                        </span>
                    }
                    else if (isTpa)
                    {
                        <span>
                            Preview of one Third-Party Appeal Application notice.
                        </span>
                    }
                    else
                    {
                        <span>
                            <strong>Single</strong> = Standard notice ·
                            <strong>Email Multi</strong> = Recipient holds multiple properties ·
                            <strong>Split PDF</strong> = Rows split by category
                        </span>
                    }
                </div>
        </div>

        <!-- Side panel -->
        <div style="display:flex;flex-direction:column;gap:16px;">

            <!-- Step 1 snapshot -->
            <div class="s2-card">
                <div class="s2-card-head">
                    <div class="s2-card-title">
                        <div class="s2-card-accent"></div>
                        Step 1 Snapshot
                    </div>
                    <div style="display:flex;gap:5px;">
                        @if (Model.IsApproved)
                        {
                            <span class="s2-badge s2-badge-ok">✓ Approved</span>
                        }
                        else
                        {

                            <span class="s2-badge s2-badge-muted">Not Approved</span>
                        }
                        @if (Model.IsConfirmed)
                        {
                            <span class="s2-badge s2-badge-gold">✓ Confirmed</span>
                        }
                    </div>
                </div>
                <div class="s2-snap-grid">
                    <div class="s2-snap-item">
                            <span class="s2-snap-label">
                                @(isClaTpa
                                    ? "Notification Letter Date"
                                    : "Letter Date")
                            </span>
                        <span class="s2-snap-value">@Model.LetterDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="s2-snap-item">
                        <span class="s2-snap-label">City Manager Sign</span>
                        <span class="s2-snap-value @(Model.CityManagerSignDate == null ? "empty" : "")">
                            @(Model.CityManagerSignDate?.ToString("dd MMM yyyy") ?? "—")
                        </span>
                    </div>
                        @if (Model.ObjectionStartDate != null ||
         Model.ObjectionEndDate != null)
                        {
                            <div class="s2-snap-item">
                                <span class="s2-snap-label">
                                    @(isClaTpa
                                        ? "Representation Starts"
                                        : "Objection Start")
                                </span>

                                <span class="s2-snap-value @(Model.ObjectionStartDate == null ? "empty" : "")">
                                    @(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—")
                                </span>
                            </div>

                            <div class="s2-snap-item">
                                <span class="s2-snap-label">
                                    @(isClaTpa
                                        ? "Representation Closes"
                                        : "Objection End")
                                </span>

                                <span class="s2-snap-value @(Model.ObjectionEndDate == null ? "empty" : "")">
                                    @(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")
                                </span>
                            </div>
                        }
                    
                    @if (Model.AppealCloseDate != null)
                    {
                        <div class="s2-snap-item">
                            <span class="s2-snap-label">Batch Date</span>
                            <span class="s2-snap-value @(Model.BatchDate == null ? "empty" : "")">
                                @(Model.BatchDate?.ToString("dd MMM yyyy") ?? "—")
                            </span>
                        </div>
                        <div class="s2-snap-item">
                            <span class="s2-snap-label">Appeal Close</span>
                            <span class="s2-snap-value @(Model.AppealCloseDate == null ? "empty" : "")">
                                @(Model.AppealCloseDate?.ToString("dd MMM yyyy") ?? "—")
                            </span>
                        </div>
                    }
                    @if (Model.BulkFromDate != null || Model.BulkToDate != null)
                    {
                        <div class="s2-snap-item">
                            <span class="s2-snap-label">Bulk From</span>
                            <span class="s2-snap-value @(Model.BulkFromDate == null ? "empty" : "")">
                                @(Model.BulkFromDate?.ToString("dd MMM yyyy") ?? "—")
                            </span>
                        </div>
                        <div class="s2-snap-item">
                            <span class="s2-snap-label">Bulk To</span>
                            <span class="s2-snap-value @(Model.BulkToDate == null ? "empty" : "")">
                                @(Model.BulkToDate?.ToString("dd MMM yyyy") ?? "—")
                            </span>
                        </div>
                    }
                    @if (Model.EvidenceCloseDate != null)
                    {
                        <div class="s2-snap-item" style="grid-column:1/-1">
                            <span class="s2-snap-label">Evidence Close</span>
                            <span class="s2-snap-value">@Model.EvidenceCloseDate?.ToString("dd MMM yyyy")</span>
                        </div>
                    }
                </div>
                    @if (!isDirectThirdPartyNotice)
                    {
                        <div class="s2-sig-row">
                            <span class="s2-sig-label">Signature</span>

                            @if (hasSignature)
                            {
                                <span class="s2-badge s2-badge-ok">✓ Uploaded</span>
                                <span class="s2-sig-path">
                                    @System.IO.Path.GetFileName(Model.SignaturePath)
                                </span>
                            }
                            else
                            {
                                <span class="s2-badge s2-badge-warn">
                                    ⚠ Not Uploaded
                                </span>
                            }
                        </div>
                    }


            </div>

            <!-- Email preview -->
            <div class="s2-card">
                <div class="s2-card-head">
                    <div class="s2-card-title">
                        <div class="s2-card-accent"></div>
                        Email Preview
                    </div>
                </div>
                <div class="s2-card-body">
                    <div class="s2-email-subj">
                        <span class="s2-subj-label">Subject</span>
                        @Model.EmailSubject
                    </div>
                    <div class="s2-email-body">
                        @Html.Raw(Model.EmailBodyHtml)
                    </div>
                </div>

                <!-- ── Action bar: ONLY "Start Step 3" ─────────── -->
                <div class="s2-action-bar">
                    <button class="s2-btn s2-btn-step3" type="button" onclick="openStep3Modal()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <polygon points="5 3 19 12 5 21 5 3" />
                        </svg>
                            @(isClaTpa
          ? "Approve CLA Preview"
          : "Start Step 3 Processing")
                    </button>
                    <a class="s2-btn s2-btn-back" asp-controller="Workflow" asp-action="Step1"
                       asp-route-settingsId="@Model.SettingsId">
                        ← Back to Step 1
                    </a>
                    <a class="s2-btn s2-btn-lib" asp-controller="Workflow" asp-action="SettingsLibrary">
                        Settings Library
                    </a>
                </div>
            </div>

        </div><!-- /side panel -->
        }
    </div><!-- /s2-body -->

</div><!-- /s2-root -->
<!-- ══════════════════════════════════════════════
     START STEP 3 — WARNING CONFIRMATION MODAL
     (replaces both old Approve + Correction modals)
══════════════════════════════════════════════ -->
<div class="s2-modal-overlay" id="step3Modal">
    <div class="s2-modal">

        <div class="s2-modal-head">
            <div class="s2-modal-head-left">
                <div class="s2-modal-warn-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e6b000" stroke-width="2.2" stroke-linecap="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                </div>
                <div>
                    <div class="s2-modal-title">
                        @(isClaTpa
                            ? "Confirm — Approve CLA Preview"
                            : "Confirm — Start Step 3 Processing")
                    </div>
                    <div class="s2-modal-sub">
                        @(isClaTpa
                            ? "This will approve the CLA letter and email preview"
                            : "This will unlock batch creation for this notice")
                    </div>
                </div>
            </div>
            <button class="s2-modal-x" onclick="closeStep3Modal()">✕</button>
        </div>

        <div class="s2-modal-body">
            <div class="s2-modal-warning">
                <span class="s2-modal-warning-icon">⚠</span>
                <div class="s2-modal-warning-text">
                    @if (isClaTpa)
                    {
                        <span>
                            You are approving the letter and email preview for
                            <strong>CLA-THIRD PARTY APPLICATION NOTICE</strong>.

                            After approval, the workflow will continue to printing,
                            appeal-pack verification and sending notices to property owners.
                        </span>
                    }
                    else
                    {
                        <span>
                            You are about to start Step 3 processing for
                            <strong>@NoticeName(Model.Notice)</strong>
                            on roll
                            <strong>
                                @Model.RollShortCode — @Model.RollName
                            </strong>.

                            Step 3 will allow the Data Team to create batches,
                            print PDFs and send notices to ratepayers.
                        </span>
                    }
                </div>
            </div>

            <div class="s2-modal-summary">
                <div class="s2-ms-row">
                    <span class="s2-ms-key">Roll</span>
                    <span class="s2-ms-val">@Model.RollShortCode — @Model.RollName</span>
                </div>
                <div class="s2-ms-row">
                    <span class="s2-ms-key">Notice</span>
                    <span class="s2-ms-val">@NoticeName(Model.Notice)</span>
                </div>
                <div class="s2-ms-row">
                    <span class="s2-ms-key">Letter Date</span>
                    <span class="s2-ms-val">@Model.LetterDate.ToString("dd MMMM yyyy")</span>
                </div>
                @if (Model.Notice == NoticeKind.S53 && Model.AppealCloseDate != null)
                {
                    <div class="s2-ms-row">
                        <span class="s2-ms-key">Appeal Close</span>
                        <span class="s2-ms-val">@Model.AppealCloseDate?.ToString("dd MMMM yyyy")</span>
                    </div>
                }
                @if (Model.Notice == NoticeKind.S49)
                {
                    <div class="s2-ms-row">
                        <span class="s2-ms-key">Objection Period</span>
                        <span class="s2-ms-val">@(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—") → @(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</span>
                    </div>
                    <div class="s2-ms-row">
                        <span class="s2-ms-key">Signature</span>
                        <span class="s2-ms-val">@(hasSignature ? "✓ Uploaded" : "⚠ Not Uploaded")</span>
                    </div>
                }
                @if (isClaTpa)
                {
                    <div class="s2-ms-row">
                        <span class="s2-ms-key">
                            Representation Period
                        </span>

                        <span class="s2-ms-val">
                            30 calendar days
                        </span>
                    </div>

                    <div class="s2-ms-row">
                        <span class="s2-ms-key">
                            Representation Closes
                        </span>

                        <span class="s2-ms-val">
                            @(Model.ObjectionEndDate?.ToString("dd MMMM yyyy")
                                ?? Model.LetterDate.AddDays(30).ToString("dd MMMM yyyy"))
                        </span>
                    </div>
                }
                <div class="s2-ms-row">
                    <span class="s2-ms-key">Version</span>
                    <span class="s2-ms-val">v @Model.Version</span>
                </div>
            </div>

            <div class="s2-modal-note">
                @if (isClaTpa)
                {
                    <span>
                        ℹ This approval does not send emails.
                        The next stage will print the CLA letters, verify appeal packs,
                        and prepare the owner notifications.
                    </span>
                }
                else
                {
                    <span>
                        ℹ This does not send any notices to ratepayers.
                        The Data Team will manage batch creation, PDF printing,
                        and email dispatch in Step 3.
                    </span>
                }
            </div>
        </div>

        <div class="s2-modal-foot">
            <button type="button" class="s2-modal-cancel" onclick="closeStep3Modal()">Cancel</button>

            <form asp-action="Step2Approve" asp-controller="Workflow" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                <input type="hidden" name="variant" value="@selectedVariant" />
                <input type="hidden" name="mode" value="@selectedMode" />
                <button type="submit" class="s2-modal-confirm">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <polygon points="5 3 19 12 5 21 5 3" />
                    </svg>
                    @(isClaTpa
     ? "Yes — Approve CLA Preview"
     : "Yes — Start Step 3")
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openStep3Modal() {
            document.getElementById('step3Modal').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeStep3Modal() {
            document.getElementById('step3Modal').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.getElementById('step3Modal').addEventListener('click', function(e) {
            if (e.target === this) closeStep3Modal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeStep3Modal();
        });
    </script>
}
