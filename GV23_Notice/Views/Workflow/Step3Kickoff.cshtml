@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep3KickoffVm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 3 — Batch Dashboard";
    bool hasSignature = !string.IsNullOrWhiteSpace(Model.SignaturePath);

    string noticeLabel = Model.Notice switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection & Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => Model.S52IsReview ? "Section 52 — Review" : "Section 52 — Appeal Decision",
        NoticeKind.S53 => "Section 53 — MVD Decision",
        NoticeKind.DJ => "Dear Johnny Notice",
        NoticeKind.IN => Model.IsInvalidOmission == true ? "Invalid — Omission" : "Invalid — Objection",
        NoticeKind.S78 => "Section 78 — Review Period",
        _ => Model.Notice.ToString()
    };
    string noticeCode = Model.Notice.ToString();
    string noticeChip = Model.Notice switch
    {
        NoticeKind.S49 => "chip-s49",
        NoticeKind.S51 => "chip-s51",
        NoticeKind.S52 => "chip-s52",
        NoticeKind.S53 => "chip-s53",
        NoticeKind.DJ => "chip-dj",
        NoticeKind.IN => "chip-in",
        NoticeKind.S78 => "chip-s78",
        _ => ""
    };
    int totalRecords = Model.CreatedBatches.Sum(b => b.NumberOfRecords);
}

<link href="~/css/step3/createbatchcss.css" rel="stylesheet" />

@* ── FromStep2 welcome modal ── *@
@if (Model.FromStep2)
{
    <div class="s2-overlay" id="s2Modal">
        <div class="s2-modal">
            <div class="s2-head">
                <div class="s2-head-left">
                    <div class="s2-check">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#e6b000" stroke-width="2.5" stroke-linecap="round">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                    </div>
                    <div>
                        <div class="s2-head-title">Step 2 Approved</div>
                        <div class="s2-head-sub">Ready to create your first batch</div>
                    </div>
                </div>
                <button class="s2-close" onclick="closeS2Modal()">✕</button>
            </div>
            <div class="s2-body">
                <div class="cb-info">
                    <div class="cb-info-row"><span class="cb-info-key">Notice</span><span class="cb-info-val">@noticeLabel</span></div>
                    <div class="cb-info-row"><span class="cb-info-key">Roll</span><span class="cb-info-val">@Model.RollShortCode — @Model.RollName</span></div>
                    <div class="cb-info-row"><span class="cb-info-key">Letter Date</span><span class="cb-info-val">@Model.LetterDate.ToString("dd MMMM yyyy")</span></div>
                    @if (Model.AppealCloseDate.HasValue)
                    {
                        <div class="cb-info-row"><span class="cb-info-key">Appeal Closes</span><span class="cb-info-val">@Model.AppealCloseDate.Value.ToString("dd MMMM yyyy")</span></div>
                    }
                    <div class="cb-info-row"><span class="cb-info-key">First Batch</span><span class="cb-info-val mono">@Model.NextBatchCode</span></div>
                </div>
                <p class="s2-note">
                    ℹ Click <strong>Create First Batch</strong> to open the batch form, or <strong>View Dashboard</strong> to continue later.
                </p>
            </div>
            <div class="s2-foot">
                <button class="cb-cancel" onclick="closeS2Modal()">View Dashboard</button>
                <button class="cb-submit" onclick="closeS2AndOpenCreate()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Create First Batch
                </button>
            </div>
        </div>
    </div>
}

@* ── Create Batch Modal ── *@
<div class="cb-overlay" id="cbModal">
    <div class="cb-modal">
        <div class="cb-head">
            <div class="cb-head-left">
                <div class="cb-head-icon">📦</div>
                <div>
                    <div class="cb-head-title">Create New Batch</div>
                    <div class="cb-head-sub">@noticeLabel</div>
                </div>
            </div>
            <button class="cb-close" onclick="closeCbModal()">✕</button>
        </div>
        <div class="cb-body">
            <div class="cb-info">
                <div class="cb-info-row"><span class="cb-info-key">Roll</span><span class="cb-info-val">@Model.RollShortCode — @Model.RollName</span></div>
                <div class="cb-info-row"><span class="cb-info-key">Letter Date</span><span class="cb-info-val">@Model.LetterDate.ToString("dd MMMM yyyy")</span></div>
                @if (Model.Notice == NoticeKind.S53 && Model.AppealCloseDate.HasValue)
                {
                    <div class="cb-info-row"><span class="cb-info-key">Appeal Closes</span><span class="cb-info-val">@Model.AppealCloseDate.Value.ToString("dd MMMM yyyy")</span></div>
                }
                @if (Model.Notice == NoticeKind.S49)
                {
                    <div class="cb-info-row"><span class="cb-info-key">Objection Period</span><span class="cb-info-val">@(Model.ObjectionStartDate?.ToString("dd MMM") ?? "—") – @(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</span></div>
                }
                <div class="cb-info-row"><span class="cb-info-key">Batch Code</span><span class="cb-info-val mono">@Model.NextBatchCode</span></div>
                <div class="cb-info-row"><span class="cb-info-key">Records</span><span class="cb-info-val">Up to 500 per batch</span></div>
            </div>
            <form asp-action="Step2CreateBatch" asp-controller="Step3" method="post" id="cbForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@Model.ApprovalKey" />
                <div class="cb-field-lbl">Batch Date</div>
                <input type="date" name="batchDate" id="cbDateInput" class="cb-date-input"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                <div class="cb-foot" style="padding:16px 0 0; border:none">
                    <button type="button" class="cb-cancel" onclick="closeCbModal()">Cancel</button>
                    <button type="submit" class="cb-submit" id="cbSubmitBtn">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                        Create Batch
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="dash-page">

    <!-- Hero -->
    <div class="dash-hero">
        <div class="dash-hero-left">
            <div class="dash-vns">VNS</div>
            <div class="dash-div"></div>
            <div>
                <div class="dash-title">Batch Dashboard</div>
                <div class="dash-sub">Step 3 — @Model.RollShortCode · @Model.RollName</div>
            </div>
        </div>
        <div class="dash-hero-right">
            <a class="dash-hero-link" href="@Url.Action("Index", "Step3")">← All Workflows</a>
            <a class="dash-hero-link" href="@Url.Action("Step2", "Workflow", new { settingsId = Model.SettingsId, variant = "Default", mode = "single" })">Preview Notice</a>
        </div>
    </div>

    <!-- Notice ribbon -->
    <div class="dash-ribbon">
        <span class="dash-notice-chip @noticeChip">@noticeCode</span>
        <span class="dash-ribbon-name">@noticeLabel</span>
        <span class="dash-ribbon-sep">·</span>
        <span class="dash-ribbon-item"><strong>Letter Date</strong> @Model.LetterDate.ToString("dd MMM yyyy")</span>
        @if (Model.AppealCloseDate.HasValue)
        {
            <span class="dash-ribbon-sep">·</span>
            <span class="dash-ribbon-item"><strong>Appeal Closes</strong> @Model.AppealCloseDate.Value.ToString("dd MMM yyyy")</span>
        }
        @if (Model.Notice == NoticeKind.S49 && Model.ObjectionStartDate.HasValue)
        {
            <span class="dash-ribbon-sep">·</span>
            <span class="dash-ribbon-item"><strong>Objection</strong> @Model.ObjectionStartDate.Value.ToString("dd MMM") – @(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "?")</span>
        }
        @if (Model.IsApproved && !string.IsNullOrWhiteSpace(Model.ApprovedBy))
        {
            <span class="dash-ribbon-sep">·</span>
            <span class="dash-ribbon-item"><strong>Approved by</strong> @Model.ApprovedBy</span>
        }
    </div>

    <div class="dash-body">

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="dash-alert dash-alert-ok">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="dash-alert dash-alert-err">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                @TempData["Error"]
            </div>
        }

        <!-- Stat strip -->
        <div class="dash-stats">
            <div class="dash-stat stat-green">
                <div class="dash-stat-lbl">Batches Created</div>
                <div class="dash-stat-num">@Model.CreatedBatches.Count</div>
                <div class="dash-stat-sub">For this workflow</div>
            </div>
            <div class="dash-stat">
                <div class="dash-stat-lbl">Total Records</div>
                <div class="dash-stat-num">@totalRecords.ToString("N0")</div>
                <div class="dash-stat-sub">Across all batches</div>
            </div>
            <div class="dash-stat stat-gold">
                <div class="dash-stat-lbl">Next Batch</div>
                <div class="dash-stat-num" style="font-size:15px;font-family:monospace!important">@Model.NextBatchCode</div>
                <div class="dash-stat-sub">Auto-assigned code</div>
            </div>
            <div class="dash-stat">
                <div class="dash-stat-lbl">Records per Batch</div>
                <div class="dash-stat-num">500</div>
                <div class="dash-stat-sub">Fixed per run</div>
            </div>
        </div>

        <!-- Section header with action buttons -->
        <div class="dash-sec">
            <div class="dash-sec-left">
                <div class="dash-sec-bar"></div>
                <span class="dash-sec-title">Batch History</span>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
                @if (Model.CreatedBatches.Count > 0)
                {
                    <a href="@Url.Action("Print", "Step3", new { key = Model.ApprovalKey })"
                       style="font-size:12.5px;font-weight:700;padding:7px 15px;border-radius:8px;
                                  background:var(--surf);border:1.5px solid var(--bord);color:var(--tx);
                                  text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all .13s"
                       onmouseover="this.style.borderColor='var(--gold-r)';this.style.background='var(--gold-p)'"
                       onmouseout="this.style.borderColor='var(--bord)';this.style.background='var(--surf)'">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <polyline points="6 9 6 2 18 2 18 9" />
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                            <rect x="6" y="14" width="12" height="8" />
                        </svg>
                        Print Dashboard
                    </a>
                    <a href="@Url.Action("SendEmail", "Step3", new { key = Model.ApprovalKey })"
                       style="font-size:12.5px;font-weight:700;padding:7px 15px;border-radius:8px;
                                  background:var(--surf);border:1.5px solid var(--bord);color:var(--tx);
                                  text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all .13s"
                       onmouseover="this.style.borderColor='var(--gold-r)';this.style.background='var(--gold-p)'"
                       onmouseout="this.style.borderColor='var(--bord)';this.style.background='var(--surf)'">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="22" y1="2" x2="11" y2="13" />
                            <polygon points="22 2 15 22 11 13 2 9 22 2" />
                        </svg>
                        Send Email
                    </a>
                }
                @if (!Model.IsS52)
                {
                    <button class="btn-new-batch" onclick="openCbModal()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="12" y1="5" x2="12" y2="19" />
                            <line x1="5" y1="12" x2="19" y2="12" />
                        </svg>
                        Create New Batch
                    </button>
                }
                @if (Model.IsS52)
                {
                    <a class="btn-new-batch" href="@Url.Action("Print", "Step3", new { key = Model.ApprovalKey })">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <polyline points="6 9 6 2 18 2 18 9" />
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                            <rect x="6" y="14" width="12" height="8" />
                        </svg>
                        Go to Print (@Model.S52RangeCount.ToString("N0") records)
                    </a>
                }
            </div>
        </div>

        <!-- Batch table -->
        <div class="dash-card">
            <div class="dash-card-head">
                <span class="dash-card-title">
                    @if (Model.CreatedBatches.Count == 0)
                    {
                        <text>No batches created yet</text>
                    }
                    else
                    {

                        <text>@Model.CreatedBatches.Count batch@(Model.CreatedBatches.Count == 1 ? "" : "es") created</text>
                    }
                </span>
                <span style="font-size:11.5px;color:var(--mu)">v@Model.Version · @Model.RollShortCode</span>
            </div>

            @if (Model.CreatedBatches.Count == 0)
            {
                <div class="dash-empty">
                    <div class="dash-empty-icon">📦</div>
                    <div class="dash-empty-title">No Batches Yet</div>
                    <div class="dash-empty-sub">
                        Click <strong>Create New Batch</strong> above to create the first batch for<br />
                        @noticeLabel on roll @Model.RollShortCode.
                    </div>
                    @if (!Model.IsS52)
                    {
                        <button class="btn-new-batch" onclick="openCbModal()" style="font-size:14px;padding:11px 24px">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                <line x1="12" y1="5" x2="12" y2="19" />
                                <line x1="5" y1="12" x2="19" y2="12" />
                            </svg>
                            Create First Batch
                        </button>
                    }
                </div>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Batch Code</th>
                                <th>Batch Date</th>
                                <th>Records</th>
                                <th>Created By</th>
                                <th>Created At</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int bn = 0;
                            }
                            @foreach (var b in Model.CreatedBatches)
                            {
                                bn++;
                                <tr>
                                    <td style="color:var(--mu);font-size:11px;font-weight:600">@bn</td>
                                    <td>
                                        <div class="batch-code">@b.BatchName</div>
                                    </td>
                                    <td style="font-size:12.5px;color:var(--mu)">@b.BatchDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="batch-records">@b.NumberOfRecords.ToString("N0")</span></td>
                                    <td style="font-size:12px;color:var(--mu)">@b.CreatedBy</td>
                                    <td style="font-size:12px;color:var(--mu);white-space:nowrap">@b.CreatedAtUtc.ToString("dd MMM HH:mm")</td>
                                    <td>
                                        @if (b.IsApproved)
                                        {
                                            <span class="k-badge k-badge-ok">✓ Done</span>
                                        }
                                        else
                                        {

                                            <span class="k-badge k-badge-pend">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="tbl-actions">
                                            <a class="tbl-btn tbl-btn-print"
                                               href="@Url.Action("Print", "Step3", new { key = Model.ApprovalKey })">
                                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                    <polyline points="6 9 6 2 18 2 18 9" />
                                                    <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                                                    <rect x="6" y="14" width="12" height="8" />
                                                </svg>
                                                Print
                                            </a>
                                            <a class="tbl-btn tbl-btn-send"
                                               href="@Url.Action("SendEmail", "Step3", new { key = Model.ApprovalKey })">
                                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                    <line x1="22" y1="2" x2="11" y2="13" />
                                                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                                </svg>
                                                Send
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        /* Create Batch modal */
        function openCbModal() {
            document.getElementById('cbModal').classList.add('open');
            document.body.style.overflow = 'hidden';
            document.getElementById('cbDateInput').focus();
        }
        function closeCbModal() {
            document.getElementById('cbModal').classList.remove('open');
            document.body.style.overflow = '';
        }
        document.getElementById('cbModal').addEventListener('click', function(e) {
            if (e.target === this) closeCbModal();
        });
        document.getElementById('cbForm').addEventListener('submit', function() {
            var btn = document.getElementById('cbSubmitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span style="display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:cbspin .7s linear infinite"></span> Creating…';
        });

        @if (Model.FromStep2)
        {
                <text>
            /* FromStep2 welcome modal */
            function closeS2Modal() {
                document.getElementById('s2Modal').classList.remove('open');
                document.body.style.overflow = '';
            }
            function closeS2AndOpenCreate() {
                closeS2Modal();
                setTimeout(openCbModal, 160);
            }
            document.addEventListener('DOMContentLoaded', function() {
                var m = document.getElementById('s2Modal');
                if (m) { m.classList.add('open'); document.body.style.overflow = 'hidden'; }
            });
            document.getElementById('s2Modal').addEventListener('click', function(e) {
                if (e.target === this) closeS2Modal();
            });
                </text>
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { closeCbModal(); @(Model.FromStep2 ? "closeS2Modal();" : "") }
        });
    </script>
    <style>
     
    </style>
}
