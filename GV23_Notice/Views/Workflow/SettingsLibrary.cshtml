@model List<GV23_Notice.Models.Workflow.ViewModels.SettingsLibraryRowVm>
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Settings Library";

    string NoticeName(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection & Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => "Section 52 — Appeal Notices",
        NoticeKind.S53 => "Section 53 — MVD Decision",
        NoticeKind.DJ => "Dear Johnny Notice",
        NoticeKind.IN => "Invalid Notice",
        NoticeKind.S78 => "Section 78 — Review Period",
        _ => n.ToString()
    };

    string NoticeChipClass(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "sl-chip-s49",
        NoticeKind.S51 => "sl-chip-s51",
        NoticeKind.S52 => "sl-chip-s52",
        NoticeKind.S53 => "sl-chip-s53",
        NoticeKind.DJ => "sl-chip-dj",
        NoticeKind.IN => "sl-chip-in",
        NoticeKind.S78 => "sl-chip-s78",
        _ => ""
    };
}


<link href="~/css/step2/settinglibrarycss.css" rel="stylesheet" />
<div id="wf-loader" role="status">
    <div class="wf-spinner"></div>
    <div>
        <div class="wf-loader-text" id="wf-loader-text">Loading…</div>
        <div class="wf-loader-sub" id="wf-loader-sub">Please wait</div>
    </div>
</div>
<div id="wf-toast-container" aria-live="polite"></div>

<div class="wf-wrap">

    <!-- Hero -->
    <div class="sl-hero">
        <div class="sl-hero-left">
            <div class="sl-logo-mark">VNS</div>
            <div class="sl-hero-div"></div>
            <div>
                <div class="sl-hero-title">Settings Library</div>
                <div class="sl-hero-sub">Select a configuration to preview or continue to Step 3</div>
            </div>
        </div>
        <div class="sl-hero-right">
            <a class="sl-hero-btn sl-btn-gold" asp-controller="Workflow" asp-action="Step1">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                New Configuration
            </a>
            <a class="sl-hero-btn sl-btn-outline" asp-controller="Home" asp-action="Index">
                ← Dashboard
            </a>
        </div>
    </div>

    <div class="sl-body">

        <!-- Stats strip -->
        <div class="sl-stats">
            <div class="sl-stat sl-stat-gold">
                <div class="sl-stat-lbl">Total Configurations</div>
                <div class="sl-stat-num">@Model.Count</div>
                <div class="sl-stat-sub">Approved settings</div>
            </div>
            <div class="sl-stat sl-stat-green">
                <div class="sl-stat-lbl">With Signature</div>
                <div class="sl-stat-num">@Model.Count(x => !string.IsNullOrWhiteSpace(x.SignaturePath))</div>
                <div class="sl-stat-sub">Ready for generation</div>
            </div>
            <div class="sl-stat">
                <div class="sl-stat-lbl">Missing Signature</div>
                <div class="sl-stat-num">@Model.Count(x => string.IsNullOrWhiteSpace(x.SignaturePath))</div>
                <div class="sl-stat-sub">Requires upload</div>
            </div>
            <div class="sl-stat">
                <div class="sl-stat-lbl">Notice Types</div>
                <div class="sl-stat-num">@Model.Select(x => x.Notice).Distinct().Count()</div>
                <div class="sl-stat-sub">Distinct types in use</div>
            </div>
        </div>

        <!-- Table card -->
        <div class="sl-sec-head">
            <div class="sl-sec-left">
                <div class="sl-sec-bar"></div>
                <span class="sl-sec-title">Approved Configurations</span>
            </div>
            <span style="font-size:11.5px;color:var(--sl-mu)">Click Preview to review the notice and start Step 3</span>
        </div>

        <div class="sl-card">
            <div class="sl-card-head">
                <span class="sl-card-head-title">All Configurations</span>
                <span class="sl-card-meta">Sort by column header · Filter with the search box</span>
            </div>

            @if (!Model.Any())
            {
                <div class="sl-empty">
                    <div class="sl-empty-icon">📭</div>
                    <p>No approved configurations found.<br />Create one from Step 1.</p>
                </div>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table id="settingsTable" class="sl-table" style="width:100%">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Roll</th>
                                <th>Notice Type</th>
                                <th>Mode</th>
                                <th>Ver</th>
                                <th>Letter Date</th>
                                <th>Signature</th>
                                <th style="width:200px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td><span class="sl-id">#@r.SettingsId</span></td>
                                    <td>
                                        <div class="sl-roll-name">@r.RollName</div>
                                        <span class="sl-roll-code">@r.RollShortCode</span>
                                    </td>
                                    <td>
                                        <span class="sl-notice-chip @NoticeChipClass(r.Notice)">@r.Notice</span>
                                        <div class="sl-notice-name">@NoticeName(r.Notice)</div>
                                    </td>
                                    <td>
                                        @if (r.Mode.ToString().ToLower() == "bulk")
                                        {
                                            <span class="sl-status sl-pip-step2">Bulk</span>
                                        }
                                        else
                                        {

                                            <span class="sl-status" style="background:var(--sl-surf);color:var(--sl-mu);border-color:var(--sl-bord)">Single</span>
                                        }
                                    </td>
                                    <td style="font-size:12px;color:var(--sl-mu)">v @r.Version</td>
                                    <td style="font-size:12px;color:var(--sl-mu);font-variant-numeric:tabular-nums">
                                        @r.LetterDate.ToString("dd MMM yyyy")
                                    </td>
                                    <td>
                                        @if (string.IsNullOrWhiteSpace(r.SignaturePath))
                                        {
                                            <span class="sl-status sl-pip-sig">⚠ Missing</span>
                                        }
                                        else
                                        {

                                            <span class="sl-status sl-pip-step3">✓ Uploaded</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="sl-actions">
                                            <!-- Preview → Step 2 with this settingsId — the main CTA -->
                                            <a class="sl-action sl-action-preview"
                                               href="@Url.Action("Step2", "Workflow", new { settingsId = r.SettingsId, variant = "Default", mode = "single" })">
                                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                    <circle cx="12" cy="12" r="3" />
                                                </svg>
                                                Preview
                                            </a>
                                            <!-- Edit -->
                                            <a class="sl-action sl-action-edit"
                                               href="@Url.Action("Step1", "Workflow", new { settingsId = r.SettingsId })">
                                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                                Edit
                                            </a>
                                            <!-- Summary -->
                                            <a class="sl-action sl-action-summary"
                                               href="@Url.Action("Step1Summary", "Workflow", new { settingsId = r.SettingsId })">
                                                Summary
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const WfToast = (() => {
            const c = document.getElementById("wf-toast-container");
            const TITLES={success:"Success",error:"Error",warning:"Warning",info:"Info"};
            function show(type,msg,title) {
                const t=document.createElement("div"); t.className=`wf-toast t-${type}`;
                t.innerHTML=`<div class="wf-toast-main"><div class="wf-toast-stripe"></div>
                    <div class="wf-toast-body"><div class="wf-toast-title">${title||TITLES[type]}</div>
                    <div class="wf-toast-msg">${msg}</div></div>
                    <button class="wf-toast-close">×</button></div>
                    <div class="wf-toast-progress"><div class="wf-toast-bar"></div></div>`;
                c.appendChild(t);
                requestAnimationFrame(()=>requestAnimationFrame(()=>{
                    t.classList.add("show");
                    const bar=t.querySelector(".wf-toast-bar");
                    bar.style.transition="transform 5000ms linear";bar.style.transform="scaleX(0)";
                }));
                const tm=setTimeout(()=>dismiss(t),5000);
                t.querySelector(".wf-toast-close").addEventListener("click",()=>{clearTimeout(tm);dismiss(t);});
            }
            function dismiss(t){t.classList.remove("show");t.classList.add("hide");t.addEventListener("transitionend",()=>t.remove(),{once:true});}
            return{success:(m,t)=>show("success",m,t),error:(m,t)=>show("error",m,t),
                   warning:(m,t)=>show("warning",m,t),info:(m,t)=>show("info",m,t)};
        })();
        const WfLoader={
            show:(m,h)=>{document.getElementById("wf-loader-text").textContent=m||"Loading…";
                          document.getElementById("wf-loader-sub").textContent=h||"Please wait";
                          document.getElementById("wf-loader").classList.add("active");},
            hide:()=>document.getElementById("wf-loader").classList.remove("active")
        };
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof $.fn.DataTable === "undefined") return;
            $('#settingsTable').DataTable({
                pageLength:15, lengthMenu:[10,15,25,50,100], order:[[5,'desc']],
                columnDefs:[{orderable:false,targets:7}],
                language:{search:"",searchPlaceholder:"Search configurations…",
                          lengthMenu:"Show _MENU_ rows",info:"Showing _START_–_END_ of _TOTAL_",
                          infoEmpty:"No settings found",paginate:{previous:"‹",next:"›"}},
                dom:"<'dt-toolbar'<'dataTables_length'l><'dataTables_filter'f>>t<'row'<'col-sm-6'i><'col-sm-6'p>>",
                initComplete: function () {
                    WfToast.info(`${this.api().data().length} configuration(s) loaded.`, "Library Ready");
                }
            });
            document.querySelectorAll(".sl-action").forEach(a =>
                a.addEventListener("click", function() {
                    const label = this.textContent.trim();
                    WfLoader.show(`Opening ${label}…`, "Loading configuration");
                })
            );
        });
    </script>
}
