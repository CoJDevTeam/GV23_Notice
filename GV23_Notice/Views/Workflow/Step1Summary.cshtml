@model GV23_Notice.Models.Workflow.ViewModels.WorkflowStep1SummaryVm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 1 Summary";

    // Full notice names (no abbreviations shown to user)
    string NoticeName(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection &amp; Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => "Section 52 — Appeal Notices",
        NoticeKind.S53 => "Section 53 — Municipal Valuation Decision",
        NoticeKind.DJ => "Dear Johnny — Acknowledgement Notice",
        NoticeKind.IN => "Invalid Notice",
        NoticeKind.S78 => "Section 78 — Property Verification Review",
        _ => n.ToString()
    };

    // Icon letter per notice
    string NoticeIcon(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "49",
        NoticeKind.S51 => "51",
        NoticeKind.S52 => "52",
        NoticeKind.S53 => "53",
        NoticeKind.DJ => "DJ",
        NoticeKind.IN => "IN",
        NoticeKind.S78 => "78",
        _ => "?"
    };

    bool hasSignature = !string.IsNullOrWhiteSpace(Model.SignaturePath);
    bool sigRequired = Model.Notice == NoticeKind.S49;
    bool canApprove = !sigRequired || hasSignature;
}


<link href="~/css/step1/step1summarycss.css" rel="stylesheet" />
<div id="wf-loader" role="status">
    <div class="ss-spinner"></div>
    <div>
        <div id="wf-loader-text" class="ss-loader-text">Processing…</div>
        <div id="wf-loader-sub" class="ss-loader-sub">Please wait</div>
    </div>
</div>
<div id="wf-toast-container" aria-live="polite"></div>

<div class="ss-root">

    <!-- TOP BAR -->
    <div class="ss-topbar">
        <div class="ss-topbar-left">
            <div class="ss-logo-mark">VNS</div>
            <div class="ss-topbar-div"></div>
            <div>
                <div class="ss-page-title">Configuration Summary</div>
                <div class="ss-page-sub">Step 1 — Review before approving</div>
            </div>
        </div>
        <div class="ss-topbar-right">
            <a class="ss-topbar-link"
               asp-controller="Workflow" asp-action="Step1"
               asp-route-settingsId="@Model.SettingsId">
                ← Edit Configuration
            </a>
        </div>
    </div>

    <!-- STEPPER -->
    <div class="ss-stepper">
        <div class="ss-step ss-done">
            <div class="ss-step-num">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
            </div>
            <div class="ss-step-label">Configure Dates</div>
        </div>
        <div class="ss-step-line"></div>
        <div class="ss-step ss-active">
            <div class="ss-step-num">2</div>
            <div class="ss-step-label">Preview</div>
        </div>
        <div class="ss-step-line"></div>
        <div class="ss-step">
            <div class="ss-step-num">3</div>
            <div class="ss-step-label">Start Step 3</div>
        </div>
    </div>

    <!-- SIGNATURE WARNING (S49 only) -->
    @if (sigRequired && !hasSignature)
    {
        <div class="ss-warn-banner">
            <span class="ss-warn-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                    <line x1="12" y1="9" x2="12" y2="13" />
                    <line x1="12" y1="17" x2="12.01" y2="17" />
                </svg>
            </span>
            <div>
                <div class="ss-warn-title">Signature Required — Section 49</div>
                <div class="ss-warn-text">
                    A signature image must be uploaded before this configuration can be approved.
                    Go back to Step 1 and upload the signature file.
                </div>
            </div>
            <a class="ss-warn-btn" asp-controller="Workflow" asp-action="Step1"
               asp-route-settingsId="@Model.SettingsId">
                Upload Signature →
            </a>
        </div>
    }

    <div class="ss-body">

        <!-- ── LEFT: detail cards ─────────────────────────────── -->
        <div class="ss-left">

            <!-- Configuration Overview -->
            <div class="ss-card">
                <div class="ss-card-header">
                    <div class="ss-card-header-left">
                        <div class="ss-card-icon ss-icon-@Model.Notice.ToString().ToLower()">
                            @NoticeIcon(Model.Notice)
                        </div>
                        <div>
                            <div class="ss-card-title">Configuration Overview</div>
                            <div class="ss-card-sub">Roll, notice type and valuation period</div>
                        </div>
                    </div>
                    <div class="ss-notice-tag ss-tag-@Model.Notice.ToString().ToLower()">
                        @Html.Raw(NoticeName(Model.Notice))
                    </div>
                </div>

                <div class="ss-detail-grid">
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">Roll</span>
                        <span class="ss-detail-value">
                            <span class="ss-code-chip">@Model.RollShortCode</span>
                            <span class="ss-detail-name">@Model.RollName</span>
                        </span>
                    </div>
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">Notice Type</span>
                        <span class="ss-detail-value ss-detail-strong">
                            @Html.Raw(NoticeName(Model.Notice))
                        </span>
                    </div>
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">Batch Mode</span>
                        <span class="ss-detail-value">
                            @if (Model.Mode.ToString().ToLower() == "bulk")
                            {
                                <span class="ss-badge ss-badge-bulk">Bulk</span>
                            }
                            else
                            {

                                <span class="ss-badge ss-badge-single">Single</span>
                            }
                        </span>
                    </div>
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">Version</span>
                        <span class="ss-detail-value">
                            <span class="ss-badge ss-badge-version">v @Model.Version</span>
                        </span>
                    </div>
                </div>

                <div class="ss-divider"></div>

                <div class="ss-detail-grid">
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">Letter Date</span>
                        <span class="ss-detail-value ss-mono">@Model.LetterDate.ToString("dd MMMM yyyy")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PortalUrl))
                    {
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Portal URL</span>
                            <span class="ss-detail-value">
                                <a href="@Model.PortalUrl" target="_blank" class="ss-link">@Model.PortalUrl</a>
                            </span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.EnquiriesLine))
                    {
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Enquiries</span>
                            <span class="ss-detail-value">@Model.EnquiriesLine</span>
                        </div>
                    }
                    <div class="ss-detail-row">
                        <span class="ss-detail-label">City Manager</span>
                        <span class="ss-detail-value ss-mono">
                            @(Model.CityManagerSignDate?.ToString("dd MMMM yyyy") ?? "—")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Section 49 details -->
            @if (Model.Notice == NoticeKind.S49)
            {
                <div class="ss-card">
                    <div class="ss-card-header">
                        <div class="ss-card-header-left">
                            <div class="ss-card-icon ss-icon-s49">49</div>
                            <div>
                                <div class="ss-card-title">Section 49 — Public Inspection &amp; Objections</div>
                                <div class="ss-card-sub">Objection window and signature</div>
                            </div>
                        </div>
                    </div>
                    <div class="ss-detail-grid">
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Objection Opens</span>
                            <span class="ss-detail-value ss-mono">@(Model.ObjectionStartDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Objection Closes</span>
                            <span class="ss-detail-value ss-mono">@(Model.ObjectionEndDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Extension Date</span>
                            <span class="ss-detail-value ss-mono">@(Model.ExtensionDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Signature</span>
                            <span class="ss-detail-value">
                                @if (hasSignature)
                                {
                                    <span class="ss-badge ss-badge-ok">✓ Uploaded</span>
                                    <span class="ss-file-path">@System.IO.Path.GetFileName(Model.SignaturePath)</span>
                                }
                                else
                                {

                                    <span class="ss-badge ss-badge-warn">⚠ Missing — required</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            }

            <!-- Section 51 details -->
            @if (Model.Notice == NoticeKind.S51)
            {
                <div class="ss-card">
                    <div class="ss-card-header">
                        <div class="ss-card-header-left">
                            <div class="ss-card-icon ss-icon-s51">51</div>
                            <div>
                                <div class="ss-card-title">Section 51 — Objection Decision</div>
                                <div class="ss-card-sub">Evidence close date</div>
                            </div>
                        </div>
                    </div>
                    <div class="ss-detail-grid">
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Evidence Closes</span>
                            <span class="ss-detail-value ss-mono">@(Model.EvidenceCloseDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                    </div>
                </div>
            }

            <!-- Section 52 details -->
            @if (Model.Notice == NoticeKind.S52)
            {
                <div class="ss-card">
                    <div class="ss-card-header">
                        <div class="ss-card-header-left">
                            <div class="ss-card-icon ss-icon-s52">52</div>
                            <div>
                                <div class="ss-card-title">Section 52 — Appeal Notices</div>
                                <div class="ss-card-sub">Backlog processing configuration</div>
                            </div>
                        </div>
                    </div>
                    <div class="ss-detail-grid">
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Sub-Type</span>
                            <span class="ss-detail-value">
                                @if (Model.S52SendMode == S52SendMode.ReviewOnly)
                                {
                                    <span class="ss-badge ss-badge-s52r">Section 52 Review only</span>
                                }
                                else if (Model.S52SendMode == S52SendMode.AppealDecisionOnly)
                                {

                                    <span class="ss-badge ss-badge-s52a">Appeal Decision only</span>
                                }
                                else
                                {

                                    <span class="ss-badge ss-badge-both">Both sub-types</span>
                                }
                            </span>
                        </div>
                        @if (Model.ShowReview || Model.ShowAppealDecision)
                        {
                            <div class="ss-detail-row">
                                <span class="ss-detail-label">Date Range From</span>
                                <span class="ss-detail-value ss-mono">@(Model.BulkFromDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                            </div>
                            <div class="ss-detail-row">
                                <span class="ss-detail-label">Date Range To</span>
                                <span class="ss-detail-value ss-mono">@(Model.BulkToDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Section 53 details -->
            @if (Model.Notice == NoticeKind.S53)
            {
                <div class="ss-card">
                    <div class="ss-card-header">
                        <div class="ss-card-header-left">
                            <div class="ss-card-icon ss-icon-s53">53</div>
                            <div>
                                <div class="ss-card-title">Section 53 — Municipal Valuation Decision</div>
                                <div class="ss-card-sub">Batch date and appeal close date</div>
                            </div>
                        </div>
                    </div>
                    <div class="ss-detail-grid">
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Batch Date</span>
                            <span class="ss-detail-value ss-mono">@(Model.BatchDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Appeal Closes</span>
                            <span class="ss-detail-value ss-mono ss-detail-strong">@(Model.AppealCloseDate?.ToString("dd MMMM yyyy") ?? "—")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.AppealCloseOverrideReason))
                        {
                            <div class="ss-detail-row">
                                <span class="ss-detail-label">Override Reason</span>
                                <span class="ss-detail-value">@Model.AppealCloseOverrideReason</span>
                            </div>
                        }
                        <div class="ss-detail-row">
                            <span class="ss-detail-label">Override Evidence</span>
                            <span class="ss-detail-value">
                                @if (!string.IsNullOrWhiteSpace(Model.AppealCloseOverrideEvidencePath))
                                {
                                    <span class="ss-badge ss-badge-ok">✓ Uploaded</span>
                                }
                                else
                                {

                                    <span style="color:var(--ss-mu);font-size:13px">—</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            }

        </div>

        <!-- ── RIGHT: checklist + approve ────────────────────── -->
        <div class="ss-right">
            <div class="ss-action-card">
                <div class="ss-action-header">
                    <div class="ss-action-title">Approval Checklist</div>
                    <div class="ss-action-sub">All items must pass before approving</div>
                </div>

                <div class="ss-checklist">
                    <div class="ss-check">
                        <div class="ss-check-dot ok">✓</div>
                        <span>Roll — <strong>@Model.RollName</strong></span>
                    </div>
                    <div class="ss-check">
                        <div class="ss-check-dot ok">✓</div>
                        <span>@Html.Raw(NoticeName(Model.Notice))</span>
                    </div>
                    <div class="ss-check">
                        <div class="ss-check-dot ok">✓</div>
                        <span>Letter date — <strong>@Model.LetterDate.ToString("dd MMM yyyy")</strong></span>
                    </div>

                    @if (Model.Notice == NoticeKind.S49)
                    {
                        <div class="ss-check">
                            @if (hasSignature)
                            {
                                <div class="ss-check-dot ok">✓</div>
                                <span>Signature uploaded</span>
     }
                            else
                            {
                                <div class="ss-check-dot warn">!</div>
                                <span>Signature <strong>missing</strong> — required</span>
     }
                        </div>
                        <div class="ss-check">
                            <div class="ss-check-dot ok">✓</div>
                            <span>Objection window configured</span>
                        </div>
                    }

                    @if (Model.Notice == NoticeKind.S53)
                    {
                        <div class="ss-check">
                            <div class="ss-check-dot ok">✓</div>
                            <span>Appeal close date — <strong>@(Model.AppealCloseDate?.ToString("dd MMM yyyy") ?? "not set")</strong></span>
                        </div>
                    }
                </div>

                <!-- Meta -->
                <div class="ss-meta-block">
                    <div class="ss-meta-row">
                        <span class="ss-meta-label">Settings ID</span>
                        <span class="ss-meta-val ss-mono">#@Model.SettingsId</span>
                    </div>
                    <div class="ss-meta-row">
                        <span class="ss-meta-label">Letter Date</span>
                        <span class="ss-meta-val ss-mono">@Model.LetterDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="ss-meta-row">
                        <span class="ss-meta-label">Version</span>
                        <span class="ss-badge ss-badge-version">v @Model.Version</span>
                    </div>
                </div>

                <!-- Action buttons -->
                <div class="ss-action-btns">
                    <form id="approve-form" asp-action="Step1SummaryApprove"
                          asp-controller="Workflow" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="settingsId" value="@Model.SettingsId" />
                        <button id="approve-btn" type="submit"
                                class="ss-btn ss-btn-approve @(!canApprove ? "ss-btn-disabled" : "")"
                                @(!canApprove ? "disabled" : "")>
                            <span class="ss-btn-spinner"></span>
                            <span>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Continue to Step 2 
                            </span>
                        </button>
                    </form>
                    <a class="ss-btn ss-btn-edit"
                       asp-controller="Workflow" asp-action="Step1"
                       asp-route-settingsId="@Model.SettingsId">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                        Edit Configuration
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const WfToast = (() => {
            const c = document.getElementById('wf-toast-container');
            const ICONS={success:'✓',error:'✕',warning:'!',info:'i'};
            const TITLES={success:'Success',error:'Error',warning:'Warning',info:'Info'};
            function show(type,msg,title) {
                const t=document.createElement('div'); t.className=`wf-toast t-${type}`;
                t.innerHTML=`<div class="wf-toast-main"><div class="wf-toast-stripe"></div>
                    <div class="wf-toast-body"><div class="wf-toast-title">${title||TITLES[type]}</div>
                    <div class="wf-toast-msg">${msg}</div></div>
                    <button class="wf-toast-close">×</button></div>
                    <div class="wf-toast-progress"><div class="wf-toast-bar"></div></div>`;
                c.appendChild(t);
                requestAnimationFrame(()=>requestAnimationFrame(()=>{
                    t.classList.add('show');
                    const bar=t.querySelector('.wf-toast-bar');
                    bar.style.transition='transform 5000ms linear';
                    bar.style.transform='scaleX(0)';
                }));
                const tm=setTimeout(()=>dismiss(t),5000);
                t.querySelector('.wf-toast-close').onclick=()=>{clearTimeout(tm);dismiss(t);};
            }
            function dismiss(t){t.classList.replace('show','hide');t.addEventListener('transitionend',()=>t.remove(),{once:true});}
            return{success:(m,t)=>show('success',m,t),error:(m,t)=>show('error',m,t),
                   warning:(m,t)=>show('warning',m,t),info:(m,t)=>show('info',m,t)};
        })();
        const WfLoader={
            show:(m,h)=>{document.getElementById('wf-loader-text').textContent=m||'Loading…';
                          document.getElementById('wf-loader-sub').textContent=h||'Please wait';
                          document.getElementById('wf-loader').classList.add('active');},
            hide:()=>document.getElementById('wf-loader').classList.remove('active')
        };
        @if (TempData["Error"] != null)
        {
            <text>document.addEventListener('DOMContentLoaded',()=>WfToast.error("@Html.Raw(TempData["Error"]?.ToString()?.Replace("\"", "\\\""))"));</text>
        }
        @if (TempData["Success"] != null)
        {
            <text>document.addEventListener('DOMContentLoaded',()=>WfToast.success("@Html.Raw(TempData["Success"]?.ToString()?.Replace("\"", "\\\""))"));</text>
        }
        document.addEventListener('DOMContentLoaded', () => {
            const form=document.getElementById('approve-form');
            const btn=document.getElementById('approve-btn');
            if(form&&btn&&!btn.disabled){
                form.addEventListener('submit',()=>{
                    btn.classList.add('loading');
                    WfLoader.show('Approving configuration…','Saving and moving to Step 2');
                });
            }
            document.querySelectorAll('.ss-btn-edit').forEach(a=>
                a.addEventListener('click',()=>WfLoader.show('Loading editor…','Opening Step 1 configuration')));
        });
    </script>
}
