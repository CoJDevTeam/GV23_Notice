@model GV23_Notice.Models.Workflow.ViewModels.Step3SendEmailVm
@using System.Globalization
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Step 3 — Send Notices";
    var key = Model.WorkflowKey;
    var totalPrinted = Model.TotalPrinted;
    var totalSent = Model.TotalSent;
    var cap = Model.MaxEmailsPerSend;
}

<link href="~/css/step3/step3kickoffcss.css" rel="stylesheet" />
<style>
    .se-fs {
        position: fixed;
        top: 60px;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 500;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #f2f2f2;
        font-family: 'Poppins',sans-serif
    }

    .se-meta {
        flex-shrink: 0;
        background: #111;
        height: 40px;
        padding: 0 18px;
        display: flex;
        align-items: center;
        border-bottom: 2px solid #2ebd6c;
        overflow-x: auto;
        scrollbar-width: none
    }

        .se-meta::-webkit-scrollbar {
            display: none
        }

    .se-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 0 14px;
        height: 100%;
        font-size: .69rem;
        font-weight: 600;
        color: rgba(255,255,255,.9);
        white-space: nowrap;
        border-right: 1px solid rgba(255,255,255,.08)
    }

        .se-chip:last-child {
            border-right: none
        }

    .se-chip-lbl {
        color: rgba(255,255,255,.35);
        font-weight: 400;
        margin-right: 3px
    }

    .se-chip-val {
        color: #2ebd6c;
        font-weight: 700
    }

        .se-chip-val.gold {
            color: #F5CA3A
        }

    .se-banner {
        flex-shrink: 0;
        background: #fff;
        border-bottom: 1px solid #e4e4e4;
        padding: 0 18px;
        height: 44px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.06)
    }

    .se-trail {
        display: flex;
        align-items: center;
        gap: 6px
    }

    .se-bc {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #c0c0c0
    }

        .se-bc.done {
            color: #1a8a4a
        }

        .se-bc.active {
            color: #2ebd6c
        }

    .se-bc-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .62rem;
        font-weight: 700;
        background: #f0f0f0;
        color: #c0c0c0
    }

    .se-bc.done .se-bc-dot {
        background: #1a8a4a;
        color: #fff
    }

    .se-bc.active .se-bc-dot {
        background: #2ebd6c;
        color: #fff
    }

    .se-bc-arrow {
        color: #d8d8d8;
        font-size: .8rem
    }

    .se-step-lbl {
        margin-left: auto;
        font-size: .7rem;
        font-weight: 700;
        color: #1a1a1a
    }

        .se-step-lbl span {
            color: #2ebd6c
        }

    .se-body {
        flex: 1;
        display: grid;
        grid-template-columns: 340px 1fr;
        min-height: 0;
        overflow: hidden
    }

    .se-left {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        overflow-x: hidden;
        background: #f5f5f5;
        border-right: 1px solid #d8d8d8;
        scrollbar-width: thin;
        scrollbar-color: #2ebd6c #f0f0f0
    }

        .se-left::-webkit-scrollbar {
            width: 4px
        }

        .se-left::-webkit-scrollbar-thumb {
            background: #2ebd6c;
            border-radius: 2px
        }

    .se-back {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 12px 16px;
        font-size: .72rem;
        font-weight: 700;
        color: #555;
        text-decoration: none;
        border-bottom: 1px solid #ebebeb
    }

        .se-back:hover {
            color: #1a8a4a
        }

    .se-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        padding: 14px 16px;
        background: #f9f9f9;
        border-bottom: 1px solid #ebebeb
    }

    .se-stat {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 12px
    }

    .se-stat-num {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1;
        letter-spacing: -.04em
    }

        .se-stat-num.gold {
            color: #E6B000
        }

        .se-stat-num.green {
            color: #1a8a4a
        }

    .se-stat-lbl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9a9a9a;
        margin-top: 4px
    }

    .se-cap-wrap {
        padding: 12px 16px;
        background: #f9f9f9;
        border-bottom: 1px solid #ebebeb
    }

    .se-cap-label {
        font-size: .6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #9a9a9a;
        margin-bottom: 5px;
        display: flex;
        justify-content: space-between
    }

    .se-cap-bar-wrap {
        height: 8px;
        background: #e8e8e8;
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 5px
    }

    .se-cap-bar-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg,#1a8a4a,#2ebd6c);
        transition: width .3s
    }

        .se-cap-bar-fill.over {
            background: linear-gradient(90deg,#c0392b,#e74c3c)
        }

    .se-cap-note {
        font-size: .65rem;
        color: #9a9a9a
    }

        .se-cap-note.warn {
            color: #c0392b;
            font-weight: 700
        }

    .se-alert {
        margin: 14px 16px;
        padding: 10px 14px;
        border-radius: 7px;
        font-size: .75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px
    }

    .se-alert-ok {
        background: #e8f8ef;
        border: 1px solid #b2dfcc;
        color: #1a6a3a
    }

    .se-alert-err {
        background: #fff0f0;
        border: 1px solid #f0b0b0;
        color: #8a1a1a
    }

    .se-card {
        background: #fff;
        border-bottom: 1px solid #ebebeb;
        flex-shrink: 0
    }

    .se-card-header {
        background: #0d0d0d;
        padding: 9px 16px;
        border-bottom: 2px solid #2ebd6c;
        display: flex;
        align-items: center;
        gap: 8px
    }

        .se-card-header h4 {
            font-size: .7rem;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: .07em;
            margin: 0
        }

    .se-card-body {
        padding: 14px 16px
    }

    .se-fl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #9a9a9a;
        margin-bottom: 2px
    }

    .se-fv {
        font-size: .78rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 10px
    }

        .se-fv.empty {
            color: #d0d0d0;
            font-style: italic;
            font-weight: 400
        }

    .se-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 12px
    }

    .se-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin: 10px 0
    }

    .se-right {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #fff
    }

    .se-right-header {
        flex-shrink: 0;
        background: #0d0d0d;
        padding: 12px 20px;
        border-bottom: 3px solid #2ebd6c;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px
    }

    .se-right-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .78rem;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: .07em
    }

    .se-right-icon {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        background: linear-gradient(135deg,#1a8a4a,#2ebd6c);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0
    }

    .se-table-wrap {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: #2ebd6c #f0f0f0
    }

        .se-table-wrap::-webkit-scrollbar {
            width: 4px
        }

        .se-table-wrap::-webkit-scrollbar-thumb {
            background: #2ebd6c;
            border-radius: 2px
        }

    .se-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Poppins',sans-serif
    }

        .se-table thead tr {
            background: #0d0d0d;
            position: sticky;
            top: 0;
            z-index: 2
        }

        .se-table thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: .6rem;
            font-weight: 700;
            color: rgba(255,255,255,.5);
            text-transform: uppercase;
            letter-spacing: .07em;
            white-space: nowrap
        }

            .se-table thead th.col-chk {
                width: 40px;
                text-align: center
            }

        .se-table tbody tr {
            border-bottom: 1px solid #f0f0f0;
            transition: background .12s;
            cursor: pointer
        }

            .se-table tbody tr:hover {
                background: #f0fff5
            }

            .se-table tbody tr.row-selected {
                background: #e8f8ef
            }

            .se-table tbody tr.row-sent {
                opacity: .5;
                cursor: default
            }

        .se-table tbody td {
            padding: 11px 14px;
            font-size: .76rem;
            color: #1a1a1a;
            vertical-align: middle
        }

    .se-bt-code {
        font-family: 'Courier New',monospace;
        font-size: .78rem;
        font-weight: 700;
        color: #0d0d0d;
        background: #f5f5f5;
        padding: 3px 7px;
        border-radius: 5px;
        display: inline-block
    }

    .se-bt-meta {
        font-size: .62rem;
        color: #aaa;
        margin-top: 2px
    }

    .se-bt-count {
        font-weight: 700;
        font-size: .82rem
    }

        .se-bt-count.green {
            color: #1a8a4a
        }

        .se-bt-count.grey {
            color: #aaa
        }

    .se-chk {
        width: 17px;
        height: 17px;
        cursor: pointer;
        accent-color: #2ebd6c
    }

    .se-badge-ok {
        background: #e8f8ef;
        color: #1a8a4a;
        border: 1px solid #b2dfcc;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .se-badge-warn {
        background: #fff3d6;
        color: #b06800;
        border: 1px solid #f0d078;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .se-badge-info {
        background: #e8f0fe;
        color: #1a56c4;
        border: 1px solid #b3c8f8;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .se-badge-sent {
        background: #e8f8ef;
        color: #1a8a4a;
        border: 1px solid #b2dfcc;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .se-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 32px;
        text-align: center
    }

    .se-empty-icon {
        font-size: 3rem;
        opacity: .25;
        margin-bottom: 16px
    }

    .se-empty-title {
        font-size: .95rem;
        font-weight: 800;
        color: #1a1a1a;
        margin-bottom: 6px
    }

    .se-empty-sub {
        font-size: .75rem;
        color: #9a9a9a;
        line-height: 1.7;
        max-width: 300px
    }

    .se-send-footer {
        flex-shrink: 0;
        background: #0d0d0d;
        border-top: 3px solid #2ebd6c;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 14px
    }

    .se-sel-info {
        font-size: .72rem;
        color: rgba(255,255,255,.6);
        white-space: nowrap
    }

        .se-sel-info strong {
            color: #fff
        }

    .se-footer-spacer {
        flex: 1
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg)
        }
    }

    .se-spin {
        display: inline-block;
        width: 13px;
        height: 13px;
        border: 2px solid rgba(255,255,255,.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .7s linear infinite
    }

    .btn-send {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 24px;
        border-radius: 8px;
        background: linear-gradient(135deg,#1a8a4a,#2ebd6c);
        border: none;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .78rem;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 3px 10px rgba(26,138,74,.4);
        transition: all .18s
    }

        .btn-send:hover:not(:disabled) {
            background: linear-gradient(135deg,#15703c,#1a8a4a);
            transform: translateY(-1px)
        }

        .btn-send:disabled {
            opacity: .45;
            cursor: not-allowed;
            transform: none
        }

    @@keyframes epulse {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: .5
        }
    }

    .ep-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.72);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px)
    }

        .ep-overlay.active {
            display: flex
        }

    .ep-modal {
        background: #fff;
        border-radius: 14px;
        padding: 32px 36px;
        width: 480px;
        max-width: 92vw;
        box-shadow: 0 24px 64px rgba(0,0,0,.45);
        font-family: 'Poppins',sans-serif
    }

    .ep-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px
    }

    .ep-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg,#1a8a4a,#2ebd6c);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0
    }

    .ep-title {
        font-size: .95rem;
        font-weight: 800;
        color: #0d0d0d
    }

    .ep-sub {
        font-size: .7rem;
        color: #9a9a9a;
        margin-top: 2px
    }

    .ep-bar-wrap {
        height: 14px;
        background: #f0f0f0;
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 10px
    }

    .ep-bar-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg,#1a8a4a,#2ebd6c);
        transition: width .4s ease;
        width: 0%
    }

        .ep-bar-fill.done {
            background: linear-gradient(90deg,#0f5032,#1a8a4a)
        }

        .ep-bar-fill.has-fail {
            background: linear-gradient(90deg,#c0392b,#e74c3c)
        }

    .ep-pct-wrap {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 18px
    }

    .ep-pct {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0d0d0d;
        letter-spacing: -.05em;
        line-height: 1
    }

    .ep-counts {
        font-size: .7rem;
        color: #9a9a9a;
        text-align: right;
        line-height: 1.8
    }

        .ep-counts strong {
            color: #1a1a1a
        }

    .ep-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 20px
    }

    .ep-chip {
        flex: 1;
        min-width: 80px;
        background: #f9f9f9;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 8px 10px;
        text-align: center
    }

    .ep-chip-num {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1
    }

        .ep-chip-num.green {
            color: #1a8a4a
        }

        .ep-chip-num.gold {
            color: #D4A500
        }

        .ep-chip-num.red {
            color: #c0392b
        }

        .ep-chip-num.grey {
            color: #aaa
        }

    .ep-chip-lbl {
        font-size: .56rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9a9a9a;
        margin-top: 3px
    }

    .ep-path {
        background: #f5f5f5;
        border-radius: 7px;
        padding: 8px 12px;
        font-size: .67rem;
        color: #555;
        word-break: break-all;
        margin-bottom: 18px
    }

        .ep-path code {
            color: #2ebd6c;
            font-weight: 700
        }

    .ep-working {
        text-align: center;
        font-size: .72rem;
        color: #9a9a9a;
        margin-bottom: 16px
    }

    .ep-pulse {
        animation: epulse 1.5s ease-in-out infinite;
        display: inline-block
    }

    .ep-done-banner {
        background: linear-gradient(135deg,#0f5032,#1a8a4a);
        border-radius: 10px;
        padding: 14px 18px;
        display: none;
        align-items: center;
        gap: 12px;
        color: #fff;
        margin-bottom: 16px
    }

        .ep-done-banner.active {
            display: flex
        }

    .ep-done-icon {
        font-size: 1.8rem;
        flex-shrink: 0
    }

    .ep-done-title {
        font-size: .82rem;
        font-weight: 800
    }

    .ep-done-sub {
        font-size: .68rem;
        opacity: .8;
        margin-top: 2px
    }

    .ep-btn {
        display: none;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        background: linear-gradient(135deg,#1a8a4a,#2ebd6c);
        border: none;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .8rem;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 3px 10px rgba(26,138,74,.35)
    }

        .ep-btn.active {
            display: flex
        }
</style>

<div class="se-fs">
    <div class="se-meta">
        <div class="se-chip"><span class="se-chip-lbl">Roll</span><span class="se-chip-val gold">@Model.RollShortCode — @Model.RollName</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Notice</span><span class="se-chip-val gold">@Model.Notice</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Version</span><span class="se-chip-val gold">@Model.VersionText</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Batches</span><span class="se-chip-val">@Model.TotalBatches</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Ready</span><span class="se-chip-val">@totalPrinted</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Sent</span><span class="se-chip-val">@totalSent</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Cap</span><span class="se-chip-val">@cap</span></div>
    </div>

    <div class="se-banner">
        <div class="se-trail">
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Configure</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Approve</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Kickoff</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Batches</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Print</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc active"><div class="se-bc-dot">6</div>Send</div>
        </div>
        <div class="se-step-lbl">Send Notices to Clients &nbsp;·&nbsp; <span>Step 3 / Step 3</span></div>
    </div>

    <div class="se-body">
        <div class="se-left">
            @if (TempData["Success"] != null)
            {
                <div class="se-alert se-alert-ok">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="se-alert se-alert-err">@TempData["Error"]</div>
            }
            <a href="@Url.Action("Print", "Step3", new { key })" class="se-back">← Back to Print Dashboard</a>
            <div class="se-stats">
                <div class="se-stat"><div class="se-stat-num gold">@Model.TotalBatches</div><div class="se-stat-lbl">Batches</div></div>
                <div class="se-stat"><div class="se-stat-num">@cap.ToString("N0")</div><div class="se-stat-lbl">Email Cap</div></div>
                <div class="se-stat"><div class="se-stat-num">@totalPrinted.ToString("N0")</div><div class="se-stat-lbl">Ready to Send</div></div>
                <div class="se-stat"><div class="se-stat-num green">@totalSent.ToString("N0")</div><div class="se-stat-lbl">Already Sent</div></div>
            </div>
            <div class="se-cap-wrap">
                <div class="se-cap-label"><span>Selected vs Cap</span><span id="capCountLabel">0 / @cap selected</span></div>
                <div class="se-cap-bar-wrap"><div class="se-cap-bar-fill" id="capBar" style="width:0%"></div></div>
                <div class="se-cap-note" id="capNote">Select batches on the right to send</div>
            </div>
            <div class="se-card">
                <div class="se-card-header"><span>📋</span><h4>Workflow Summary</h4></div>
                <div class="se-card-body">
                    <div class="se-grid-2">
                        <div><div class="se-fl">Notice</div><div class="se-fv">@Model.Notice</div></div>
                        <div><div class="se-fl">Version</div><div class="se-fv">@Model.VersionText</div></div>
                        <div style="grid-column:span 2"><div class="se-fl">Letter Date</div><div class="se-fv @(Model.LetterDate == null ? "empty" : "")">@(Model.LetterDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        <div><div class="se-fl">Objection Start</div><div class="se-fv @(Model.ObjectionStartDate == null ? "empty" : "")">@(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        <div><div class="se-fl">Objection End</div><div class="se-fv @(Model.ObjectionEndDate == null ? "empty" : "")">@(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        @if (Model.ExtensionDate.HasValue)
                        {
                            <div style="grid-column:span 2"><div class="se-fl">Extension Date</div><div class="se-fv">@Model.ExtensionDate.Value.ToString("dd MMM yyyy")</div></div>
                        }
                        <div style="grid-column:span 2"><div class="se-fl">Financial Years</div><div class="se-fv @(string.IsNullOrWhiteSpace(Model.FinancialYearsText) ? "empty" : "")">@(Model.FinancialYearsText ?? "—")</div></div>
                    </div>
                    <hr class="se-divider" />
                    <div><div class="se-fl">Email Template</div><div class="se-fv">@Model.Notice Kickoff-approved body</div></div>
                    <div>
                        <div class="se-fl">.eml Copies Saved To</div>
                        <div class="se-fv" style="font-size:.65rem;color:#666;font-weight:400;word-break:break-all;line-height:1.5">
                            [Root]\@(Model.RollShortCode)_@(Model.Notice)\Batches\[BatchName]_Emails\[PropertyDesc].eml
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="se-right">
            <div class="se-right-header">
                <div class="se-right-title">
                    <div class="se-right-icon">📧</div>
                    Send Notices Dashboard — @Model.Notice
                </div>
                <span class="se-badge-info">@Model.Batches.Count batch@(Model.Batches.Count == 1 ? "" : "es")</span>
            </div>

            <form id="sendForm" action="/Step3/SendEmail" method="post" style="display:contents">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@key" />

                <div class="se-table-wrap">
                    @if (Model.Batches.Count == 0)
                    {
                        <div class="se-empty">
                            <div class="se-empty-icon">📭</div>
                            <div class="se-empty-title">No Printed Batches Yet</div>
                            <div class="se-empty-sub">Go back to the <strong>Print Dashboard</strong> and print your batches first.</div>
                        </div>
                    }
                    else
                    {
                        <table class="se-table">
                            <thead>
                                <tr>
                                    <th class="col-chk"><input type="checkbox" class="se-chk" id="chkAll" onchange="toggleAll(this)" /></th>
                                    <th>Batch Code</th>
                                    <th>Notice</th>
                                    <th>Batch Date</th>
                                    <th>Records</th>
                                    <th>Created By</th>
                                    <th>Ready</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rowNum = 0;
                                }
                                @foreach (var b in Model.Batches)
                                {
                                    rowNum++;
                                    var isSent = b.IsFullySent;
                                    var hasReady = b.HasReadyToSend;
                                    <tr class="@(isSent ? "row-sent" : "")" id="row_@b.BatchId" onclick="@(isSent ? "" : $"toggleRow({b.BatchId})")">
                                        <td class="col-chk" onclick="event.stopPropagation()">
                                            @if (!isSent && hasReady)
                                            {
                                                <input type="checkbox" class="se-chk batch-chk" id="chk_@b.BatchId"
                                                       name="batchIds" value="@b.BatchId"
                                                       data-count="@b.PrintedCount" onchange="onChkChange()" />
                                            }
                                        </td>
                                        <td>
                                            <span class="se-bt-code">@b.BatchName</span>
                                            <div class="se-bt-meta">@b.CreatedBy · @b.CreatedAtUtc.ToString("dd MMM HH:mm")</div>
                                        </td>
                                        <td><span class="se-badge-info">@Model.Notice</span></td>
                                        <td style="font-size:.72rem;color:#555;white-space:nowrap">@b.BatchDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="se-bt-count">@(b.PrintedCount + b.SentCount + b.FailedCount + b.NoEmailCount)</span></td>
                                        <td style="font-size:.72rem;color:#555">@b.CreatedBy</td>
                                        <td>
                                            @if (b.PrintedCount > 0)
                                            {
                                                <span class="se-bt-count green">@b.PrintedCount</span>
                                            }
                                            else
                                            {

                                                <span class="se-bt-count grey">0</span>
                                            }
                                        </td>
                                        <td>
                                            @if (b.SentCount > 0 && b.PrintedCount == 0)
                                            {
                                                <span class="se-badge-sent">✓ Sent (@b.SentCount)</span>
                                            }
                                            else if (b.SentCount > 0)
                                            {

                                                <span class="se-badge-ok">Partial (@b.SentCount sent)</span>
                                            }
                                            else if (b.FailedCount > 0)
                                            {

                                                <span class="se-badge-warn">⚠ @b.FailedCount failed</span>
                                            }
                                            else if (b.NoEmailCount > 0)
                                            {

                                                <span class="se-badge-warn">No email (@b.NoEmailCount)</span>
                                            }
                                            else if (b.PrintedCount > 0)
                                            {

                                                <span class="se-badge-info">Ready</span>
                                            }
                                            else
                                            {

                                                <span class="se-badge-warn">Not Printed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="se-send-footer">
                    <div class="se-sel-info">
                        <strong id="selCount">0</strong> batches selected &nbsp;·&nbsp; <strong id="selRecords">0</strong> notices
                    </div>
                    <div class="se-footer-spacer"></div>
                    <div class="se-sel-info" id="capWarn" style="display:none;color:#e74c3c;font-weight:700;">
                        ⚠ Over @cap limit
                    </div>
                    <button type="button" class="btn-send" id="sendBtn" disabled onclick="submitSendForm()">
                        📧 Send Notices
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EMAIL PROGRESS OVERLAY -->
<div class="ep-overlay" id="epOverlay">
    <div class="ep-modal">
        <div class="ep-header">
            <div class="ep-icon">📧</div>
            <div>
                <div class="ep-title" id="epTitle">Sending emails…</div>
                <div class="ep-sub" id="epSub">Please wait — do not close this page</div>
            </div>
        </div>
        <div class="ep-bar-wrap"><div class="ep-bar-fill" id="epBarFill"></div></div>
        <div class="ep-pct-wrap">
            <div class="ep-pct"><span id="epPct">0</span>%</div>
            <div class="ep-counts">
                <div>Total: <strong id="epTotal">—</strong></div>
                <div>Sent: <strong id="epSent">0</strong></div>
                <div>Remaining: <strong id="epRemaining">—</strong></div>
            </div>
        </div>
        <div class="ep-chips">
            <div class="ep-chip"><div class="ep-chip-num gold" id="epChipPending">—</div><div class="ep-chip-lbl">Pending</div></div>
            <div class="ep-chip"><div class="ep-chip-num green" id="epChipSent">0</div><div class="ep-chip-lbl">Sent</div></div>
            <div class="ep-chip"><div class="ep-chip-num red" id="epChipFailed">0</div><div class="ep-chip-lbl">Failed</div></div>
            <div class="ep-chip"><div class="ep-chip-num grey" id="epChipNoEmail">0</div><div class="ep-chip-lbl">No Email</div></div>
        </div>
        <div class="ep-path">📁 .eml copies: <code>[Root]\@(Model.RollShortCode)_@(Model.Notice)\Batches\[BatchName]_Emails\[Property].eml</code></div>
        <div class="ep-working" id="epWorking"><span class="ep-pulse">✉️ Sending in progress…</span></div>
        <div class="ep-done-banner" id="epDoneBanner">
            <div class="ep-done-icon">🎉</div>
            <div>
                <div class="ep-done-title" id="epDoneTitle">Notices sent successfully</div>
                <div class="ep-done-sub" id="epDoneSub">.eml copies saved to folder</div>
            </div>
        </div>
        <button class="ep-btn" id="epCloseBtn" onclick="closeEmailOverlay()">✓ Done — Close &amp; Refresh</button>
    </div>
</div>

@section Scripts {
    <script>
        let _selCount=0,_selRecords=0,_pollTimer=null,_sendBatchIds=[];
        const CAP=@cap,WF_KEY='@key';

        function onChkChange(){
            _selCount=_selRecords=0;
            document.querySelectorAll('.batch-chk:checked').forEach(c=>{_selCount++;_selRecords+=parseInt(c.dataset.count||'0');});
            updateCapUI();
        }
        function toggleRow(id){
            const c=document.getElementById('chk_'+id);
            if(!c)return;
            c.checked=!c.checked;
            onChkChange();
            document.getElementById('row_'+id).classList.toggle('row-selected',c.checked);
        }
        function toggleAll(m){
            document.querySelectorAll('.batch-chk').forEach(c=>{
                c.checked=m.checked;
                const r=document.getElementById('row_'+c.value);
                if(r)r.classList.toggle('row-selected',m.checked);
            });
            onChkChange();
        }
        function updateCapUI(){
            document.getElementById('selCount').textContent=_selCount;
            document.getElementById('selRecords').textContent=_selRecords.toLocaleString();
            const pct=Math.min(100,Math.round(_selRecords*100/CAP)),over=_selRecords>CAP;
            const bar=document.getElementById('capBar');
            bar.style.width=pct+'%';bar.classList.toggle('over',over);
            document.getElementById('capCountLabel').textContent=_selRecords.toLocaleString()+' / '+CAP.toLocaleString()+' selected';
            const note=document.getElementById('capNote');
            note.textContent=over?'Over limit by '+(_selRecords-CAP).toLocaleString()+' — deselect some':(_selCount>0?_selRecords.toLocaleString()+' notices will be sent':'Select batches on the right');
            note.className='se-cap-note'+(over?' warn':'');
            document.getElementById('capWarn').style.display=over?'':'none';
            document.getElementById('sendBtn').disabled=over||_selCount===0;
        }
        function submitSendForm(){
            _sendBatchIds=Array.from(document.querySelectorAll('.batch-chk:checked')).map(c=>parseInt(c.value));
            if(!_sendBatchIds.length)return;
            const btn=document.getElementById('sendBtn');
            btn.disabled=true;
            btn.innerHTML='<span class="se-spin"></span> Sending…';
            showEmailOverlay();
            document.getElementById('sendForm').submit();
        }
        function showEmailOverlay(){
            document.getElementById('epOverlay').classList.add('active');
            document.getElementById('epTitle').textContent='Sending '+_selCount+' batch'+(_selCount>1?'es':'')+'…';
            document.getElementById('epSub').textContent=_selRecords.toLocaleString()+' notices — please wait';
            document.getElementById('epTotal').textContent=_selRecords.toLocaleString();
            document.getElementById('epRemaining').textContent=_selRecords.toLocaleString();
            document.getElementById('epChipPending').textContent=_selRecords.toLocaleString();
            ['epChipSent','epChipFailed','epChipNoEmail','epSent','epPct'].forEach(id=>document.getElementById(id).textContent='0');
            document.getElementById('epBarFill').style.width='0%';
            document.getElementById('epBarFill').classList.remove('done','has-fail');
            document.getElementById('epWorking').style.display='';
            document.getElementById('epDoneBanner').classList.remove('active');
            document.getElementById('epCloseBtn').classList.remove('active');
            clearInterval(_pollTimer);
            _pollTimer=setInterval(pollEmailProgress,700);
        }
        function pollEmailProgress(){
            const url=_sendBatchIds.length===1
                ?'/Step3/EmailProgress?batchId='+_sendBatchIds[0]
                :'/Step3/EmailProgressAll?key='+WF_KEY;
            fetch(url).then(r=>r.json()).then(d=>{
                const total=d.total||0,sent=d.sent||0,failed=d.failed||0,noEmail=d.noEmail||0,pending=d.printed||0;
                const doneN=sent+failed+noEmail,pct=total>0?Math.round(doneN*100/total):0;
                document.getElementById('epPct').textContent=pct;
                document.getElementById('epTotal').textContent=total.toLocaleString();
                document.getElementById('epSent').textContent=sent.toLocaleString();
                document.getElementById('epRemaining').textContent=pending.toLocaleString();
                document.getElementById('epChipPending').textContent=pending.toLocaleString();
                document.getElementById('epChipSent').textContent=sent.toLocaleString();
                document.getElementById('epChipFailed').textContent=failed.toLocaleString();
                document.getElementById('epChipNoEmail').textContent=noEmail.toLocaleString();
                document.getElementById('epBarFill').style.width=pct+'%';
                if(d.done){
                    clearInterval(_pollTimer);
                    document.getElementById('epBarFill').classList.add(failed>0?'has-fail':'done');
                    document.getElementById('epWorking').style.display='none';
                    document.getElementById('epDoneBanner').classList.add('active');
                    document.getElementById('epDoneTitle').textContent=failed>0
                        ?'Done — '+sent.toLocaleString()+' sent, '+failed.toLocaleString()+' failed'
                        :sent.toLocaleString()+' notices sent successfully';
                    document.getElementById('epDoneSub').textContent='.eml copies saved · '+noEmail.toLocaleString()+' had no email';
                    document.getElementById('epTitle').textContent='Send complete';
                    document.getElementById('epCloseBtn').classList.add('active');
                }
            }).catch(()=>{});
        }
        function closeEmailOverlay(){
            clearInterval(_pollTimer);
            document.getElementById('epOverlay').classList.remove('active');
            window.location.reload();
        }
    </script>
}
