<div class="se-fs">
    <div class="se-meta">
        <div class="se-chip"><span class="se-chip-lbl">Roll</span><span class="se-chip-val gold">@Model.RollShortCode — @Model.RollName</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Notice</span><span class="se-chip-val gold">@Model.Notice</span></div>
        <div class="se-chip"><span class="se-chip-lbl">Version</span><span class="se-chip-val gold">@Model.VersionText</span></div>
        @if (isTpa && tpa != null)
        {
            <div class="se-chip"><span class="se-chip-lbl">Mode</span><span class="se-chip-val">Direct Send</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Ready</span><span class="se-chip-val">@tpa.TotalReadyToSend</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Sent</span><span class="se-chip-val">@tpa.TotalSent</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Failed</span><span class="se-chip-val">@tpa.TotalFailed</span></div>
            <div class="se-chip"><span class="se-chip-lbl">No Email</span><span class="se-chip-val">@tpa.TotalNoOwnerEmail</span></div>
        }
        else
        {
            <div class="se-chip"><span class="se-chip-lbl">Batches</span><span class="se-chip-val">@Model.TotalBatches</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Ready</span><span class="se-chip-val">@totalPrinted</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Sent</span><span class="se-chip-val">@totalSent</span></div>
            <div class="se-chip"><span class="se-chip-lbl">Cap</span><span class="se-chip-val">@cap</span></div>
        }
        @if (qaRequired)
        {
            <div class="se-chip">
                <span class="se-chip-lbl">QA</span>
                <span class="se-chip-val @(qaApproved ? "" : "gold")">
                    @(qaApproved ? "Approved" : "Required")
                </span>
            </div>
        }
    </div>

    <div class="se-banner">
        <div class="se-trail">
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Configure</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Approve</div>
            <div class="se-bc-arrow">›</div>
            <div class="se-bc done"><div class="se-bc-dot">✓</div>Kickoff</div>
            <div class="se-bc-arrow">›</div>
            @if (!isTpa)
            {
                <div class="se-bc done"><div class="se-bc-dot">✓</div>Batches</div>
                <div class="se-bc-arrow">›</div>
            }

            <div class="se-bc done"><div class="se-bc-dot">✓</div>Print</div>
            <div class="se-bc-arrow">›</div>

            @if (qaRequired)
            {
                if (qaApproved)
                {
                    <div class="se-bc done"><div class="se-bc-dot">✓</div>QA</div>
                }
                else
                {
                    <div class="se-bc active"><div class="se-bc-dot">6</div>QA</div>
                }

                <div class="se-bc-arrow">›</div>
                <div class="se-bc @(qaApproved ? "active" : "")">
                    <div class="se-bc-dot">@(qaApproved ? "7" : "–")</div>Send
                </div>
            }
            else
            {
                <div class="se-bc active"><div class="se-bc-dot">6</div>Send</div>
            }
        </div>
        <div class="se-step-lbl">
            Send Notices to Clients &nbsp;·&nbsp;
            <span>@(qaRequired ? "QA Gate Active" : "Step 3 / Step 3")</span>
        </div>
    </div>

    <div class="se-body">
        <div class="se-left">
            @if (TempData["Success"] != null)
            {
                <div class="se-alert se-alert-ok">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="se-alert se-alert-err">@TempData["Error"]</div>
            }
            @if (qaRequired && !qaApproved)
            {
                <div class="se-alert se-alert-err">
                    <span>🔒</span>
                    <span>
                        QA must be approved before notices can be sent.
                        <a href="@Url.Action("QA", "Step3", new { key })"
                               style="color:#8a1a1a;text-decoration:underline;font-weight:800;">
                            Open QA
                        </a>
                    </span>
                </div>
            }
            else if (qaRequired && qaApproved)
            {
                <div class="se-alert se-alert-ok">
                    <span>✅</span>
                    <span>QA approved. Notices can now be sent.</span>
                </div>
            }
            <a href="@Url.Action("Print", "Step3", new { key })" class="se-back">← Back to Print Dashboard</a>
            <div class="se-stats">
                @if (isTpa && tpa != null)
                {
                    <div class="se-stat">
                        <div class="se-stat-num gold">@tpa.TotalReadyToSend.ToString("N0")</div>
                        <div class="se-stat-lbl">Ready</div>
                    </div>
                    <div class="se-stat">
                        <div class="se-stat-num green">@tpa.TotalSent.ToString("N0")</div>
                        <div class="se-stat-lbl">Sent</div>
                    </div>
                    <div class="se-stat">
                        <div class="se-stat-num">@tpa.TotalNoOwnerEmail.ToString("N0")</div>
                        <div class="se-stat-lbl">No Owner Email</div>
                    </div>
                    <div class="se-stat">
                        <div class="se-stat-num @(tpa.TotalFailed > 0 ? "gold" : "")">@tpa.TotalFailed.ToString("N0")</div>
                        <div class="se-stat-lbl">Failed</div>
                    </div>
                }
                else
                {
                    <div class="se-stat"><div class="se-stat-num gold">@Model.TotalBatches</div><div class="se-stat-lbl">Batches</div></div>
                    <div class="se-stat"><div class="se-stat-num">@cap.ToString("N0")</div><div class="se-stat-lbl">Email Cap</div></div>
                    <div class="se-stat"><div class="se-stat-num">@totalPrinted.ToString("N0")</div><div class="se-stat-lbl">Ready to Send</div></div>
                    <div class="se-stat"><div class="se-stat-num green">@totalSent.ToString("N0")</div><div class="se-stat-lbl">Already Sent</div></div>
                }
            </div>
            @if (!isTpa)
{
            <div class="se-cap-wrap">
                <div class="se-cap-label"><span>Selected vs Cap</span><span id="capCountLabel">0 / @cap selected</span></div>
                <div class="se-cap-bar-wrap"><div class="se-cap-bar-fill" id="capBar" style="width:0%"></div></div>
                <div class="se-cap-note" id="capNote">Select batches on the right to send</div>
            </div>
            }
            else
            {
                <div class="se-cap-wrap">
                    <div class="se-cap-label">
                        <span>Third-Party Appeal Sending</span>
                        <span>@(tpa?.TotalReadyToSend ?? 0) ready</span>
                    </div>
                    <div class="se-cap-note">
                        TPA sends directly from printed ThirdPartyAppealApplicationNotices. No batch selection is required.
                    </div>
                </div>
            }
            @if (qaRequired)
            {
                <div class="se-card">
                    <div class="se-card-header">
                        <span>🧾</span>
                        <h4>QA Approval Gate</h4>
                    </div>
                    <div class="se-card-body">
                        <div class="se-fl">QA Status</div>

                        @if (qaApproved)
                        {
                            <div class="se-fv" style="color:#1a8a4a;">Approved</div>
                            <div style="font-size:.7rem;color:#777;line-height:1.6;">
                                This workflow passed QA. Email sending is unlocked.
                            </div>
                        }
                        else
                        {
                            <div class="se-fv" style="color:#8a1a1a;">Required Before Sending</div>
                            <div style="font-size:.7rem;color:#777;line-height:1.6;">
                                You must approve the dynamic QA sample before sending client notices.
                            </div>

                            <div style="margin-top:12px;">
                                <a href="@Url.Action("QA", "Step3", new { key })"
                                       class="btn-send"
                                       style="text-decoration:none;box-shadow:none;padding:9px 14px;">
                                    Open QA Book
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
            <div class="se-card">
                <div class="se-card-header"><span>📋</span><h4>Workflow Summary</h4></div>
                <div class="se-card-body">
                    <div class="se-grid-2">
                        <div><div class="se-fl">Notice</div><div class="se-fv">@Model.Notice</div></div>
                        <div><div class="se-fl">Version</div><div class="se-fv">@Model.VersionText</div></div>
                        <div style="grid-column:span 2"><div class="se-fl">Letter Date</div><div class="se-fv @(Model.LetterDate == null ? "empty" : "")">@(Model.LetterDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        <div><div class="se-fl">Objection Start</div><div class="se-fv @(Model.ObjectionStartDate == null ? "empty" : "")">@(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        <div><div class="se-fl">Objection End</div><div class="se-fv @(Model.ObjectionEndDate == null ? "empty" : "")">@(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
                        @if (Model.ExtensionDate.HasValue)
                        {
                            <div style="grid-column:span 2"><div class="se-fl">Extension Date</div><div class="se-fv">@Model.ExtensionDate.Value.ToString("dd MMM yyyy")</div></div>
                        }
                        <div style="grid-column:span 2"><div class="se-fl">Financial Years</div><div class="se-fv @(string.IsNullOrWhiteSpace(Model.FinancialYearsText) ? "empty" : "")">@(Model.FinancialYearsText ?? "—")</div></div>
                    </div>
                    <hr class="se-divider" />
                    <div><div class="se-fl">Email Template</div><div class="se-fv">@Model.Notice Kickoff-approved body</div></div>
                    <div>
                        <div class="se-fl">.eml Copies Saved To</div>

                        <div class="se-fv" style="font-size:.65rem;color:#666;font-weight:400;word-break:break-all;line-height:1.5">
                            @if (isTpa)
                            {
                                <text>[Appeal Root]\[Appeal_No]\THIRD-PARTY APPLICATION\email_[Appeal_No]_[PropertyDesc]_Third-Party Appeal Application.eml</text>
                            }
                            @if (Model.IsS52)
                            {
                                var s52Sub = Model.S52IsReview ? "Section 52 Review" : "Appeal Decision";
                                <text>[Appeal Root]\[Appeal_No]\@s52Sub\[Appeal_No]_[PropertyDesc]_@(Model.S52IsReview ? "S52" : "AD").eml</text>
                            }
                            else
                            {
                                <text>[Root]\@(Model.RollShortCode)_@(Model.Notice)\Batches\[BatchName]_Emails\[PropertyDesc].eml</text>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="se-right">
            <div class="se-right-header">
                <div class="se-right-title">
                    <div class="se-right-icon">📧</div>
                    Send Notices Dashboard — @(isTpa ? "Third-Party Appeal Application" : Model.Notice.ToString())
                </div>
                @if (isTpa && tpa != null)
                {
                    <span class="se-badge-info">@tpa.Items.Count record@(tpa.Items.Count == 1 ? "" : "s")</span>
                }
                else
                {
                    <span class="se-badge-info">@Model.Batches.Count batch@(Model.Batches.Count == 1 ? "" : "es")</span>
                }
            </div>

            <form id="sendForm" action="/Step3/SendEmail" method="post" style="display:contents">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@key" />

                <div class="se-table-wrap">
                    @if (isTpa && tpa != null)
                    {
                        if (!tpa.Items.Any())
                        {
                            <div class="se-empty">
                                <div class="se-empty-icon">📭</div>
                                <div class="se-empty-title">No Third-Party Appeal notices ready</div>
                                <div class="se-empty-sub">
                                    Go back to the Print Dashboard and print the Third-Party Appeal notices first.
                                </div>
                            </div>
                        }
                        else
                        {
                            <table class="se-table">
                                <thead>
                                    <tr>
                                        <th>Appeal No</th>
                                        <th>Property</th>
                                        <th>Owner</th>
                                        <th>Third Party</th>
                                        <th>Admin</th>
                                        <th>Status</th>
                                        <th>PDF</th>
                                        <th>Pack</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in tpa.Items)
                                    {
                                        <tr>
                                            <td>
                                                <span class="se-bt-code">@item.AppealNo</span>
                                                @if (!string.IsNullOrWhiteSpace(item.ObjectionNo))
                                                {
                                                    <div class="se-bt-meta">Obj: @item.ObjectionNo</div>
                                                }
                                            </td>

                                            <td>
                                                <div style="font-weight:700;max-width:360px">@item.PropertyDescription</div>
                                            </td>

                                            <td>
                                                <div style="font-weight:700">@item.OwnerName</div>
                                                @if (!string.IsNullOrWhiteSpace(item.OwnerEmail))
                                                {
                                                    <div class="se-bt-meta">@item.OwnerEmail</div>
                                                }
                                                else
                                                {
                                                    <span class="se-badge-warn">No owner email</span>
                                                }
                                            </td>

                                            <td>
                                                <div style="font-weight:700">@item.ThirdPartyName</div>
                                                <div class="se-bt-meta">@item.ThirdPartyEmail</div>
                                            </td>

                                            <td>
                                                <div style="font-weight:700">@item.AdminName</div>
                                                <div class="se-bt-meta">@item.AdminEmail</div>
                                            </td>

                                            <td>
                                                @if (item.Status == "Sent")
                                                {
                                                    <span class="se-badge-sent">✓ Sent</span>
                                                }
                                                else if (item.Status == "Email-Failed")
                                                {
                                                    <span class="se-badge-warn">⚠ Failed</span>
                                                    @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                                                    {
                                                        <div class="se-bt-meta" style="color:#c0392b">@item.ErrorMessage</div>
                                                    }
                                                }
                                                else if (item.Status == "Printed")
                                                {
                                                    if (qaRequired && !qaApproved)
                                                    {
                                                        <span class="se-badge-warn">🔒 QA Required</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="se-badge-info">Ready</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="se-badge-warn">@item.Status</span>
                                                }
                                            </td>

                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.PdfPath))
                                                {
                                                    <span class="se-badge-ok">PDF</span>
                                                }
                                                else
                                                {
                                                    <span class="se-badge-warn">Missing</span>
                                                }
                                            </td>

                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(item.AppealPackZipPath))
                                                {
                                                    <span class="se-badge-ok">ZIP</span>
                                                }
                                                else
                                                {
                                                    <span class="se-badge-warn">Missing</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                    else if (Model.Batches.Count == 0)
                    {
                        <div class="se-empty">
                            <div class="se-empty-icon">📭</div>
                            <div class="se-empty-title">No Printed Batches Yet</div>
                            <div class="se-empty-sub">Go back to the <strong>Print Dashboard</strong> and print your batches first.</div>
                        </div>
                    }
                    else
                    {
                        <table class="se-table">
                            <thead>
                                <tr>
                                    <th class="col-chk">
                                        <input type="checkbox"
                                               class="se-chk"
                                               id="chkAll"
                                               onchange="toggleAll(this)"
                                        @(qaRequired && !qaApproved ? "disabled" : "") />
                                    </th>
                                    <th>Batch Code</th>
                                    <th>Notice</th>
                                    <th>Batch Date</th>
                                    <th>Records</th>
                                    <th>Created By</th>
                                    <th>Ready</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rowNum = 0;
                                }
                                @foreach (var b in Model.Batches)
                                {
                                    rowNum++;
                                    var isSent = b.IsFullySent;
                                    var hasReady = b.HasReadyToSend;
                                    <tr class="@(isSent ? "row-sent" : "")" id="row_@b.BatchId" onclick="@(isSent ? "" : $"toggleRow({b.BatchId})")">
                                        <td class="col-chk" onclick="event.stopPropagation()">
                                            @if (!isSent && hasReady)
                                            {
                                                <input type="checkbox"
                                                       class="se-chk batch-chk"
                                                       id="chk_@b.BatchId"
                                                       name="batchIds"
                                                       value="@b.BatchId"
                                                       data-count="@b.PrintedCount"
                                                       onchange="onChkChange()"
                                                @(qaRequired && !qaApproved ? "disabled" : "") />
                                            }
                                        </td>
                                        <td>
                                            <span class="se-bt-code">@b.BatchName</span>
                                            <div class="se-bt-meta">@b.CreatedBy · @b.CreatedAtUtc.ToString("dd MMM HH:mm")</div>
                                        </td>
                                        <td><span class="se-badge-info">@Model.Notice</span></td>
                                        <td style="font-size:.72rem;color:#555;white-space:nowrap">@b.BatchDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="se-bt-count">@(b.PrintedCount + b.SentCount + b.FailedCount + b.NoEmailCount)</span></td>
                                        <td style="font-size:.72rem;color:#555">@b.CreatedBy</td>
                                        <td>
                                            @if (b.PrintedCount > 0)
                                            {
                                                <span class="se-bt-count green">@b.PrintedCount</span>
                                            }
                                            else
                                            {

                                                <span class="se-bt-count grey">0</span>
                                            }
                                        </td>
                                        <td>
                                            @if (b.SentCount > 0 && b.PrintedCount == 0)
                                            {
                                                <span class="se-badge-sent">✓ Sent (@b.SentCount)</span>
                                            }
                                            else if (b.SentCount > 0)
                                            {

                                                <span class="se-badge-ok">Partial (@b.SentCount sent)</span>
                                            }
                                            else if (b.FailedCount > 0)
                                            {

                                                <span class="se-badge-warn">⚠ @b.FailedCount failed</span>
                                            }
                                            else if (b.NoEmailCount > 0)
                                            {

                                                <span class="se-badge-warn">No email (@b.NoEmailCount)</span>
                                            }
                                            else if (b.PrintedCount > 0 && qaRequired && !qaApproved)
                                            {
                                                <span class="se-badge-warn">🔒 QA Required</span>
                                            }
                                            else if (b.PrintedCount > 0)
                                            {
                                                <span class="se-badge-info">Ready</span>
                                            }
                                            else
                                            {

                                                <span class="se-badge-warn">Not Printed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="se-send-footer">
                    @if (isTpa && tpa != null)
                    {
                        <div class="se-sel-info">
                            <strong>@tpa.TotalReadyToSend</strong> Third-Party Appeal notices ready
                            &nbsp;·&nbsp;
                            <strong>@tpa.TotalSent</strong> sent
                        </div>

                        <div class="se-footer-spacer"></div>

                        <button type="button"
                                class="btn-send"
                                id="sendBtn"
                            @(qaRequired && !qaApproved ? "disabled" : "")
                            @(tpaCanSend ? "" : "disabled")
                                onclick="submitTpaSendForm()">
                            @(qaRequired && !qaApproved ? "🔒 QA Required" : "📧 Send Third-Party Appeal Notices")
                        </button>
                    }
                    else
                    {
                        <div class="se-sel-info">
                            <strong id="selCount">0</strong> batches selected &nbsp;·&nbsp; <strong id="selRecords">0</strong> notices
                        </div>
                        <div class="se-footer-spacer"></div>
                        <div class="se-sel-info" id="capWarn" style="display:none;color:#e74c3c;font-weight:700;">
                            ⚠ Over @cap limit
                        </div>
                        <button type="button"
                                class="btn-send"
                                id="sendBtn"
                                disabled
                                onclick="submitSendForm()">
                            @(qaRequired && !qaApproved ? "🔒 QA Required" : "📧 Send Notices")
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EMAIL PROGRESS OVERLAY -->
<div class="ep-overlay" id="epOverlay">
    <div class="ep-modal">
        <div class="ep-header">
            <div class="ep-icon">📧</div>
            <div>
                <div class="ep-title" id="epTitle">Sending emails…</div>
                <div class="ep-sub" id="epSub">Please wait — do not close this page</div>
            </div>
        </div>
        <div class="ep-bar-wrap"><div class="ep-bar-fill" id="epBarFill"></div></div>
        <div class="ep-pct-wrap">
            <div class="ep-pct"><span id="epPct">0</span>%</div>
            <div class="ep-counts">
                <div>Total: <strong id="epTotal">—</strong></div>
                <div>Sent: <strong id="epSent">0</strong></div>
                <div>Remaining: <strong id="epRemaining">—</strong></div>
            </div>
        </div>
        <div class="ep-chips">
            <div class="ep-chip"><div class="ep-chip-num gold" id="epChipPending">—</div><div class="ep-chip-lbl">Pending</div></div>
            <div class="ep-chip"><div class="ep-chip-num green" id="epChipSent">0</div><div class="ep-chip-lbl">Sent</div></div>
            <div class="ep-chip"><div class="ep-chip-num red" id="epChipFailed">0</div><div class="ep-chip-lbl">Failed</div></div>
            <div class="ep-chip"><div class="ep-chip-num grey" id="epChipNoEmail">0</div><div class="ep-chip-lbl">No Email</div></div>
        </div>
        <div class="ep-path">📁 .eml copies:
            @if (Model.IsS52)
            {
                var s52Sub = Model.S52IsReview ? "Section 52 Review" : "Appeal Decision";
                <code>[Appeal Root]\[Appeal_No]\@s52Sub\[Appeal_No]_[PropertyDesc]_@(Model.S52IsReview ? "S52" : "AD").eml</code>
            }
            else
            {
                <code>[Root]\@(Model.RollShortCode)_@(Model.Notice)\Batches\[BatchName]_Emails\[Property].eml</code>
            }
        </div>
        <div class="ep-working" id="epWorking"><span class="ep-pulse">✉️ Sending in progress…</span></div>
        <div class="ep-done-banner" id="epDoneBanner">
            <div class="ep-done-icon">🎉</div>
            <div>
                <div class="ep-done-title" id="epDoneTitle">Notices sent successfully</div>
                <div class="ep-done-sub" id="epDoneSub">.eml copies saved to folder</div>
            </div>
        </div>
        <button class="ep-btn" id="epCloseBtn" onclick="closeEmailOverlay()">✓ Done — Close &amp; Refresh</button>
    </div>
</div>

@section Scripts {
    <script>
        let _selCount = 0;
        let _selRecords = 0;
        let _pollTimer = null;
        let _sendBatchIds = [];

        const CAP = @cap;
        const WF_KEY = '@key';
        const QA_REQUIRED = @(qaRequired.ToString().ToLowerInvariant());
        const QA_APPROVED = @(qaApproved.ToString().ToLowerInvariant());
        const IS_TPA = @(isTpa.ToString().ToLowerInvariant());
        const TPA_READY = @(tpa?.TotalReadyToSend ?? 0);

        // ─────────────────────────────────────────────────────────────
        // NORMAL BATCH SEND FUNCTIONS
        // These only run for normal notices.
        // TPA does not use batch checkboxes.
        // ─────────────────────────────────────────────────────────────

        function onChkChange() {
            if (IS_TPA) return;

            _selCount = 0;
            _selRecords = 0;

            document.querySelectorAll('.batch-chk:checked').forEach(c => {
                _selCount++;
                _selRecords += parseInt(c.dataset.count || '0');
            });

            updateCapUI();
        }

        function toggleRow(id) {
            if (IS_TPA) return;

            if (QA_REQUIRED && !QA_APPROVED) {
                alert('QA must be approved before selecting batches to send.');
                return;
            }

            const c = document.getElementById('chk_' + id);

            if (!c || c.disabled) return;

            c.checked = !c.checked;
            onChkChange();

            const row = document.getElementById('row_' + id);

            if (row) {
                row.classList.toggle('row-selected', c.checked);
            }
        }

        function toggleAll(m) {
            if (IS_TPA) return;

            if (QA_REQUIRED && !QA_APPROVED) {
                alert('QA must be approved before selecting batches to send.');
                m.checked = false;
                return;
            }

            document.querySelectorAll('.batch-chk:not(:disabled)').forEach(c => {
                c.checked = m.checked;

                const r = document.getElementById('row_' + c.value);

                if (r) {
                    r.classList.toggle('row-selected', m.checked);
                }
            });

            onChkChange();
        }

        function updateCapUI() {
            if (IS_TPA) return;

            const selCountEl = document.getElementById('selCount');
            const selRecordsEl = document.getElementById('selRecords');
            const capBarEl = document.getElementById('capBar');
            const capCountLabelEl = document.getElementById('capCountLabel');
            const capNoteEl = document.getElementById('capNote');
            const capWarnEl = document.getElementById('capWarn');
            const sendBtn = document.getElementById('sendBtn');

            if (!sendBtn) return;

            if (selCountEl) {
                selCountEl.textContent = _selCount;
            }

            if (selRecordsEl) {
                selRecordsEl.textContent = _selRecords.toLocaleString();
            }

            const pct = CAP > 0
                ? Math.min(100, Math.round(_selRecords * 100 / CAP))
                : 0;

            const over = CAP > 0 && _selRecords > CAP;

            if (capBarEl) {
                capBarEl.style.width = pct + '%';
                capBarEl.classList.toggle('over', over);
            }

            if (capCountLabelEl) {
                capCountLabelEl.textContent =
                    _selRecords.toLocaleString() + ' / ' + CAP.toLocaleString() + ' selected';
            }

            if (capNoteEl) {
                capNoteEl.textContent = over
                    ? 'Over limit by ' + (_selRecords - CAP).toLocaleString() + ' — deselect some'
                    : (_selCount > 0
                        ? _selRecords.toLocaleString() + ' notices will be sent'
                        : 'Select batches on the right');

                capNoteEl.className = 'se-cap-note' + (over ? ' warn' : '');
            }

            if (capWarnEl) {
                capWarnEl.style.display = over ? '' : 'none';
            }

            const qaBlocked = QA_REQUIRED && !QA_APPROVED;

            sendBtn.disabled = qaBlocked || over || _selCount === 0;

            if (qaBlocked) {
                sendBtn.innerHTML = '🔒 QA Required';
            } else {
                sendBtn.innerHTML = '📧 Send Notices';
            }
        }

        function submitSendForm() {
            if (IS_TPA) {
                submitTpaSendForm();
                return;
            }

            if (QA_REQUIRED && !QA_APPROVED) {
                alert('QA must be approved before notices can be sent.');
                window.location.href = '@Url.Action("QA", "Step3", new { key })';
                return;
            }

            _sendBatchIds = Array.from(document.querySelectorAll('.batch-chk:checked'))
                .map(c => parseInt(c.value))
                .filter(x => !isNaN(x));

            if (!_sendBatchIds.length) return;

            const btn = document.getElementById('sendBtn');

            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="se-spin"></span> Sending…';
            }

            showEmailOverlay();

            const form = document.getElementById('sendForm');

            if (form) {
                form.submit();
            }
        }

        function showEmailOverlay() {
            if (IS_TPA) {
                showTpaEmailOverlay();
                return;
            }

            document.getElementById('epOverlay').classList.add('active');
            document.getElementById('epTitle').textContent =
                'Sending ' + _selCount + ' batch' + (_selCount > 1 ? 'es' : '') + '…';

            document.getElementById('epSub').textContent =
                _selRecords.toLocaleString() + ' notices — please wait';

            document.getElementById('epTotal').textContent = _selRecords.toLocaleString();
            document.getElementById('epRemaining').textContent = _selRecords.toLocaleString();
            document.getElementById('epChipPending').textContent = _selRecords.toLocaleString();

            document.getElementById('epSent').textContent = '0';
            document.getElementById('epPct').textContent = '0';
            document.getElementById('epChipSent').textContent = '0';
            document.getElementById('epChipFailed').textContent = '0';
            document.getElementById('epChipNoEmail').textContent = '0';

            document.getElementById('epBarFill').style.width = '0%';
            document.getElementById('epBarFill').classList.remove('done', 'has-fail');

            document.getElementById('epWorking').style.display = '';
            document.getElementById('epDoneBanner').classList.remove('active');
            document.getElementById('epCloseBtn').classList.remove('active');

            clearInterval(_pollTimer);
            _pollTimer = setInterval(pollEmailProgress, 700);
        }

        function pollEmailProgress() {
            if (IS_TPA) {
                pollTpaEmailProgress();
                return;
            }

            const url = _sendBatchIds.length === 1
                ? '/Step3/EmailProgress?batchId=' + _sendBatchIds[0]
                : '/Step3/EmailProgressAll?key=' + encodeURIComponent(WF_KEY);

            fetch(url)
                .then(r => r.json())
                .then(d => {
                    const total = d.total || 0;
                    const sent = d.sent || 0;
                    const failed = d.failed || 0;
                    const noEmail = d.noEmail || 0;
                    const pending = d.printed || 0;

                    const doneN = sent + failed + noEmail;
                    const pct = total > 0 ? Math.round(doneN * 100 / total) : 0;

                    document.getElementById('epPct').textContent = pct;
                    document.getElementById('epTotal').textContent = total.toLocaleString();
                    document.getElementById('epSent').textContent = sent.toLocaleString();
                    document.getElementById('epRemaining').textContent = pending.toLocaleString();

                    document.getElementById('epChipPending').textContent = pending.toLocaleString();
                    document.getElementById('epChipSent').textContent = sent.toLocaleString();
                    document.getElementById('epChipFailed').textContent = failed.toLocaleString();
                    document.getElementById('epChipNoEmail').textContent = noEmail.toLocaleString();

                    const bar = document.getElementById('epBarFill');
                    bar.style.width = pct + '%';

                    if (d.done) {
                        clearInterval(_pollTimer);

                        bar.classList.add(failed > 0 ? 'has-fail' : 'done');

                        document.getElementById('epWorking').style.display = 'none';
                        document.getElementById('epDoneBanner').classList.add('active');

                        document.getElementById('epDoneTitle').textContent = failed > 0
                            ? 'Done — ' + sent.toLocaleString() + ' sent, ' + failed.toLocaleString() + ' failed'
                            : sent.toLocaleString() + ' notices sent successfully';

                        document.getElementById('epDoneSub').textContent =
                            '.eml copies saved · ' + noEmail.toLocaleString() + ' had no email';

                        document.getElementById('epTitle').textContent = 'Send complete';
                        document.getElementById('epCloseBtn').classList.add('active');
                    }
                })
                .catch(() => {
                    // keep polling on temporary error
                });
        }

        // ─────────────────────────────────────────────────────────────
        // TPA DIRECT SEND FUNCTIONS
        // TPA sends directly from printed ThirdPartyAppealApplicationNotices.
        // No batchIds are required.
        // ─────────────────────────────────────────────────────────────

        function submitTpaSendForm() {
            if (!IS_TPA) {
                submitSendForm();
                return;
            }

            if (QA_REQUIRED && !QA_APPROVED) {
                alert('QA must be approved before notices can be sent.');
                window.location.href = '@Url.Action("QA", "Step3", new { key })';
                return;
            }

            if (TPA_READY <= 0) {
                alert('There are no Third-Party Appeal notices ready to send.');
                return;
            }

            const btn = document.getElementById('sendBtn');

            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="se-spin"></span> Sending…';
            }

            showTpaEmailOverlay();

            const form = document.getElementById('sendForm');

            if (form) {
                form.submit();
            }
        }

        function showTpaEmailOverlay() {
            document.getElementById('epOverlay').classList.add('active');
            document.getElementById('epTitle').textContent = 'Sending Third-Party Appeal notices…';
            document.getElementById('epSub').textContent =
                TPA_READY.toLocaleString() + ' notices — please wait';

            document.getElementById('epTotal').textContent = TPA_READY.toLocaleString();
            document.getElementById('epRemaining').textContent = TPA_READY.toLocaleString();
            document.getElementById('epChipPending').textContent = TPA_READY.toLocaleString();

            document.getElementById('epSent').textContent = '0';
            document.getElementById('epPct').textContent = '0';
            document.getElementById('epChipSent').textContent = '0';
            document.getElementById('epChipFailed').textContent = '0';
            document.getElementById('epChipNoEmail').textContent = '0';

            document.getElementById('epBarFill').style.width = '0%';
            document.getElementById('epBarFill').classList.remove('done', 'has-fail');

            document.getElementById('epWorking').style.display = '';
            document.getElementById('epDoneBanner').classList.remove('active');
            document.getElementById('epCloseBtn').classList.remove('active');

            clearInterval(_pollTimer);
            _pollTimer = setInterval(pollTpaEmailProgress, 700);
        }

        function pollTpaEmailProgress() {
            fetch('/Step3/ThirdPartyEmailProgress?key=' + encodeURIComponent(WF_KEY))
                .then(r => r.json())
                .then(d => {
                    const total = d.total || 0;
                    const sent = d.sent || 0;
                    const failed = d.failed || 0;
                    const skipped = d.skipped || 0;
                    const pending = d.pending || 0;

                    const doneN = sent + failed + skipped;
                    const pct = total > 0 ? Math.round(doneN * 100 / total) : 0;

                    document.getElementById('epPct').textContent = pct;
                    document.getElementById('epTotal').textContent = total.toLocaleString();
                    document.getElementById('epSent').textContent = sent.toLocaleString();
                    document.getElementById('epRemaining').textContent = pending.toLocaleString();

                    document.getElementById('epChipPending').textContent = pending.toLocaleString();
                    document.getElementById('epChipSent').textContent = sent.toLocaleString();
                    document.getElementById('epChipFailed').textContent = failed.toLocaleString();
                    document.getElementById('epChipNoEmail').textContent = skipped.toLocaleString();

                    const bar = document.getElementById('epBarFill');
                    bar.style.width = pct + '%';

                    if (d.done) {
                        clearInterval(_pollTimer);

                        bar.classList.add(failed > 0 ? 'has-fail' : 'done');

                        document.getElementById('epWorking').style.display = 'none';
                        document.getElementById('epDoneBanner').classList.add('active');

                        document.getElementById('epDoneTitle').textContent = failed > 0
                            ? 'Done — ' + sent.toLocaleString() + ' sent, ' + failed.toLocaleString() + ' failed'
                            : sent.toLocaleString() + ' Third-Party Appeal notices sent successfully';

                        document.getElementById('epDoneSub').textContent =
                            '.eml copies saved · ' + skipped.toLocaleString() + ' skipped';

                        document.getElementById('epTitle').textContent = 'Send complete';
                        document.getElementById('epCloseBtn').classList.add('active');
                    }
                })
                .catch(() => {
                    // keep polling on temporary error
                });
        }

        function closeEmailOverlay() {
            clearInterval(_pollTimer);

            const overlay = document.getElementById('epOverlay');

            if (overlay) {
                overlay.classList.remove('active');
            }

            window.location.reload();
        }

        // ─────────────────────────────────────────────────────────────
        // PAGE INITIALISATION
        // ─────────────────────────────────────────────────────────────

        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('sendBtn');
            const note = document.getElementById('capNote');

            if (QA_REQUIRED && !QA_APPROVED) {
                if (btn) {
                    btn.disabled = true;
                    btn.innerHTML = '🔒 QA Required';
                }

                if (note) {
                    note.textContent = 'QA approval is required before sending notices.';
                    note.className = 'se-cap-note warn';
                }

                return;
            }

            if (IS_TPA) {
                if (btn) {
                    btn.disabled = TPA_READY <= 0;
                    btn.innerHTML = TPA_READY > 0
                        ? '📧 Send Third-Party Appeal Notices'
                        : 'No Third-Party Appeal Notices Ready';
                }

                if (note) {
                    note.textContent = 'TPA sends directly. No batch selection is required.';
                    note.className = 'se-cap-note';
                }

                return;
            }

            updateCapUI();
        });

        // ─────────────────────────────────────────────────────────────
        // PAGE LOADER DISMISS
        // ─────────────────────────────────────────────────────────────

        (function () {
            function dismiss() {
                const el = document.getElementById('pageLoader');

                if (el) {
                    el.classList.add('hidden');
                }
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function () {
                    setTimeout(dismiss, 350);
                });
            } else {
                setTimeout(dismiss, 350);
            }

            setTimeout(dismiss, 2000);
        })();
    </script>
}
