@model GV23_Notice.Models.Workflow.ViewModels.Step3SendEmailVm
@using System.Globalization
@using GV23_Notice.Domain.Workflow
@inject GV23_Notice.Services.QA.INoticeQaService QaService

@{
    ViewData["Title"] = "Step 3 — Send Notices";

    var key = Model.WorkflowKey;

    var tpa = ViewBag.TpaEmail as GV23_Notice.Models.Workflow.ViewModels.ThirdPartyAppealSendEmailVm;
    bool isTpa = Model.Notice == NoticeKind.TPA;

    var totalPrinted = isTpa && tpa != null ? tpa.TotalReadyToSend : Model.TotalPrinted;
    var totalSent = isTpa && tpa != null ? tpa.TotalSent : Model.TotalSent;
    var totalFailed = isTpa && tpa != null ? tpa.TotalFailed : 0;
    var totalNoEmail = isTpa && tpa != null ? tpa.TotalNoOwnerEmail : 0;

    var cap = Model.MaxEmailsPerSend;

    var qaApproved = await QaService.IsQaApprovedAsync(Model.WorkflowKey, Context.RequestAborted);
    var qaRequired = await QaService.RequiresQaAsync(Model.WorkflowKey, Context.RequestAborted);

    bool tpaCanSend = isTpa && tpa != null && tpa.TotalReadyToSend > 0;
}

