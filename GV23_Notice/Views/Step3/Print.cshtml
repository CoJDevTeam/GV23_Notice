@model GV23_Notice.Models.Workflow.ViewModels.Step3PrintVm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 3 — Print Batches";
    var key = Model.WorkflowKey;
    bool anyPrintable = Model.Batches.Any(b => b.GeneratedCount > 0);
    bool allDone = Model.Batches.Any() && Model.Batches.All(b => b.GeneratedCount == 0);

    string subTypeLabel = Model.S52IsReview ? "Section 52 Review" : "Appeal Decision";
    // URL back to kickoff — WorkflowKey IS the ApprovalKey
    string kickoffUrl = Url.Action("Step3Kickoff", "Workflow", new { settingsId = Model.SettingsId, key = Model.WorkflowKey }) ?? "#";
}

<link href="~/css/Step3/Step3KickoffCss.css" rel="stylesheet" />
<style>
    /* ── FULL-SCREEN SHELL ────────────────────────────────── */
    .sp-fs {
        position: fixed;
        top: 60px;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 500;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #f2f2f2;
        font-family: 'Poppins',sans-serif
    }
    /* META BAR */
    .sp-meta {
        flex-shrink: 0;
        background: #111;
        height: 40px;
        padding: 0 18px;
        display: flex;
        align-items: center;
        border-bottom: 2px solid #E6B000;
        overflow-x: auto;
        scrollbar-width: none
    }

        .sp-meta::-webkit-scrollbar {
            display: none
        }

    .sp-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 0 14px;
        height: 100%;
        font-size: .69rem;
        font-weight: 600;
        color: rgba(255,255,255,.9);
        white-space: nowrap;
        border-right: 1px solid rgba(255,255,255,.08)
    }

        .sp-chip:last-child {
            border-right: none
        }

    .sp-cl {
        color: rgba(255,255,255,.35);
        font-weight: 400;
        margin-right: 3px
    }

    .sp-cv {
        color: #F5CA3A;
        font-weight: 700
    }
    /* STEP TRAIL */
    .sp-trail {
        flex-shrink: 0;
        background: #fff;
        border-bottom: 1px solid #e4e4e4;
        padding: 0 18px;
        height: 44px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,.06)
    }

    .sp-bc {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #c0c0c0
    }

        .sp-bc.done {
            color: #1a8a4a
        }

        .sp-bc.active {
            color: #E6B000
        }

    .sp-bc-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .62rem;
        font-weight: 700;
        background: #f0f0f0;
        color: #c0c0c0
    }

    .sp-bc.done .sp-bc-dot {
        background: #1a8a4a;
        color: #fff
    }

    .sp-bc.active .sp-bc-dot {
        background: #E6B000;
        color: #0d0d0d
    }

    .sp-arrow {
        color: #d8d8d8;
        font-size: .8rem
    }

    .sp-trail-label {
        margin-left: auto;
        font-size: .7rem;
        font-weight: 700;
        color: #1a1a1a
    }

        .sp-trail-label span {
            color: #E6B000
        }
    /* BODY */
    .sp-body {
        flex: 1;
        display: grid;
        grid-template-columns: 320px 1fr;
        min-height: 0;
        overflow: hidden
    }
    /* LEFT */
    .sp-left {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #f5f5f5;
        border-right: 1px solid #d8d8d8;
        scrollbar-width: thin;
        scrollbar-color: #E6B000 #f0f0f0
    }

        .sp-left::-webkit-scrollbar {
            width: 4px
        }

        .sp-left::-webkit-scrollbar-thumb {
            background: #E6B000;
            border-radius: 2px
        }
    /* RIGHT */
    .sp-right {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #fff
    }

    .sp-rh {
        flex-shrink: 0;
        background: #0d0d0d;
        padding: 13px 20px;
        border-bottom: 3px solid #E6B000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px
    }

    .sp-rh-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .78rem;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: .07em
    }

    .sp-rh-icon {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        background: linear-gradient(135deg,#F5CA3A,#D4A500);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0
    }

    .sp-rb {
        flex: 1;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: #E6B000 #f0f0f0
    }

        .sp-rb::-webkit-scrollbar {
            width: 4px
        }

        .sp-rb::-webkit-scrollbar-thumb {
            background: #E6B000;
            border-radius: 2px
        }
    /* CARD */
    .sp-card {
        background: #fff;
        border-bottom: 1px solid #ebebeb;
        flex-shrink: 0
    }

    .sp-card-hdr {
        background: #0d0d0d;
        padding: 9px 16px;
        border-bottom: 2px solid #E6B000;
        display: flex;
        align-items: center;
        gap: 8px
    }

        .sp-card-hdr h4 {
            font-size: .7rem;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: .07em;
            margin: 0
        }

    .sp-card-body {
        padding: 14px 16px
    }
    /* FIELD */
    .sp-field {
        margin-bottom: 10px
    }

    .sp-fl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #9a9a9a;
        margin-bottom: 2px
    }

    .sp-fv {
        font-size: .78rem;
        font-weight: 700;
        color: #1a1a1a
    }

        .sp-fv.empty {
            color: #d0d0d0;
            font-style: italic;
            font-weight: 400
        }

    .sp-grid2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 12px
    }

    .sp-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin: 10px 0
    }
    /* STATS */
    .sp-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        padding: 14px 16px;
        background: #f9f9f9;
        border-bottom: 1px solid #ebebeb
    }

    .sp-stat {
        background: #fff;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 12px
    }

    .sp-sn {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1;
        letter-spacing: -.04em
    }

        .sp-sn.gold {
            color: #E6B000
        }

        .sp-sn.green {
            color: #1a8a4a
        }

        .sp-sn.red {
            color: #c0392b
        }

    .sp-sl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9a9a9a;
        margin-top: 4px
    }
    /* BADGES */
    .sp-badge-ok {
        background: #e8f8ef;
        color: #1a8a4a;
        border: 1px solid #b2dfcc;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .sp-badge-warn {
        background: #fff3d6;
        color: #b06800;
        border: 1px solid #f0d078;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .sp-badge-info {
        background: #e8f0fe;
        color: #1a56c4;
        border: 1px solid #b3c8f8;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }

    .sp-badge-red {
        background: #fff0f0;
        color: #c0392b;
        border: 1px solid #f0b0b0;
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap
    }
    /* ALERT */
    .sp-alert {
        margin: 14px 16px;
        padding: 10px 14px;
        border-radius: 7px;
        font-size: .75rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px
    }

    .sp-alert-ok {
        background: #e8f8ef;
        border: 1px solid #b2dfcc;
        color: #1a6a3a
    }

    .sp-alert-err {
        background: #fff0f0;
        border: 1px solid #f0b0b0;
        color: #8a1a1a
    }
    /* ACTION BUTTONS (sidebar) */
    .sp-actions {
        padding: 14px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        border-bottom: 1px solid #ebebeb
    }

    .btn-gold {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 11px 16px;
        border-radius: 8px;
        background: linear-gradient(135deg,#F5CA3A,#D4A500);
        border: none;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .76rem;
        font-weight: 800;
        color: #0d0d0d;
        box-shadow: 0 3px 10px rgba(230,176,0,.35);
        transition: all .18s;
        text-decoration: none
    }

        .btn-gold:hover {
            background: linear-gradient(135deg,#ffd700,#E6B000);
            transform: translateY(-1px);
            box-shadow: 0 5px 14px rgba(230,176,0,.5);
            color: #0d0d0d
        }

        .btn-gold:disabled, .btn-gold.disabled {
            background: #e0e0e0;
            color: #aaa;
            box-shadow: none;
            cursor: not-allowed;
            transform: none
        }

    .btn-outline-dark {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 10px 16px;
        border-radius: 8px;
        background: #fff;
        border: 2px solid #1a1a1a;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .76rem;
        font-weight: 700;
        color: #1a1a1a;
        transition: all .18s;
        text-decoration: none
    }

        .btn-outline-dark:hover {
            background: #1a1a1a;
            color: #fff
        }

    .btn-outline-gold {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 10px 16px;
        border-radius: 8px;
        background: #fff;
        border: 2px solid #E6B000;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .76rem;
        font-weight: 700;
        color: #b06800;
        transition: all .18s;
        text-decoration: none
    }

        .btn-outline-gold:hover {
            background: #fff3d6;
            border-color: #D4A500
        }
    /* PRINT TABLE */
    .sp-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Poppins',sans-serif
    }

        .sp-table thead tr {
            background: #0d0d0d;
            position: sticky;
            top: 0;
            z-index: 2
        }

        .sp-table thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: .6rem;
            font-weight: 700;
            color: rgba(255,255,255,.5);
            text-transform: uppercase;
            letter-spacing: .07em;
            white-space: nowrap
        }

        .sp-table tbody tr {
            border-bottom: 1px solid #f0f0f0;
            transition: background .12s
        }

            .sp-table tbody tr:hover {
                background: #fdf8e0
            }

        .sp-table tbody td {
            padding: 11px 14px;
            font-size: .76rem;
            color: #1a1a1a;
            vertical-align: middle
        }

    .sp-code {
        font-family: 'Courier New',monospace;
        font-size: .78rem;
        font-weight: 700;
        color: #0d0d0d;
        background: #f5f5f5;
        padding: 3px 7px;
        border-radius: 5px;
        white-space: nowrap;
        display: inline-block
    }

    .sp-meta-sub {
        font-size: .62rem;
        color: #aaa;
        margin-top: 2px
    }

    .sp-dt {
        font-size: .72rem;
        color: #555;
        white-space: nowrap
    }
    /* PER-BATCH STATUS BAR */
    .sp-status-bar {
        display: flex;
        gap: 4px;
        align-items: center;
        flex-wrap: wrap
    }

    .sp-status-pill {
        font-size: .62rem;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 10px;
        white-space: nowrap
    }

    .sp-status-gen {
        background: #f0f0f0;
        color: #777
    }

    .sp-status-done {
        background: #e8f8ef;
        color: #1a8a4a
    }

    .sp-status-fail {
        background: #fff0f0;
        color: #c0392b
    }

    .sp-status-sent {
        background: #e8f0fe;
        color: #1a56c4
    }
    /* Progress mini */
    .sp-mini-prog {
        height: 5px;
        background: #f0f0f0;
        border-radius: 99px;
        overflow: hidden;
        margin-top: 5px;
        width: 120px
    }

    .sp-mini-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg,#D4A500,#F5CA3A)
    }

        .sp-mini-fill.done {
            background: linear-gradient(90deg,#1a8a4a,#2ebd6c)
        }
    /* Print btn per row */
    .btn-print-row {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 7px 12px;
        border-radius: 7px;
        background: linear-gradient(135deg,#F5CA3A,#D4A500);
        border: none;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .7rem;
        font-weight: 700;
        color: #0d0d0d;
        box-shadow: 0 2px 6px rgba(230,176,0,.3);
        transition: all .15s
    }

        .btn-print-row:hover {
            background: linear-gradient(135deg,#ffd700,#E6B000);
            transform: translateY(-1px)
        }

        .btn-print-row:disabled {
            background: #e0e0e0;
            color: #aaa;
            box-shadow: none;
            cursor: not-allowed;
            transform: none
        }
    /* Empty / completion */
    .sp-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 32px;
        text-align: center
    }

    .sp-empty-icon {
        font-size: 3rem;
        opacity: .25;
        margin-bottom: 16px
    }

    .sp-complete-banner {
        background: linear-gradient(135deg,#0f5032,#1a8a4a);
        border-radius: 10px;
        padding: 16px 20px;
        margin: 16px;
        display: flex;
        align-items: center;
        gap: 14px;
        color: #fff
    }
    /* FOLDER PATH INFO */
    .sp-path-info {
        margin: 14px 16px;
        padding: 10px 14px;
        border-radius: 7px;
        background: #f0f8ff;
        border: 1px solid #b3c8f8;
        font-size: .7rem;
        color: #1a56c4
    }

        .sp-path-info code {
            font-size: .68rem;
            background: rgba(0,0,0,.06);
            padding: 1px 5px;
            border-radius: 3px;
            color: #0d0d0d
        }
    /* Spinning loader for buttons */
    @@keyframes spin {
        to {
            transform: rotate(360deg)
        }
    }

    .sp-spin {
        display: inline-block;
        width: 13px;
        height: 13px;
        border: 2px solid rgba(0,0,0,.15);
        border-top-color: #0d0d0d;
        border-radius: 50%;
        animation: spin .7s linear infinite
    }
    /* S52 range card */
    .sp-s52-card {
        background: #fff;
        margin: 16px;
        border-radius: 10px;
        border: 2px solid #E6B000;
        padding: 20px;
        text-align: center
    }

    .sp-s52-title {
        font-size: .95rem;
        font-weight: 800;
        color: #0d0d0d;
        margin-bottom: 6px
    }

    .sp-s52-sub {
        font-size: .75rem;
        color: #777;
        margin-bottom: 16px;
        line-height: 1.6
    }

    .sp-s52-dates {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin-bottom: 20px
    }

    .sp-s52-date-chip {
        background: #f9f9f9;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 10px 18px;
        text-align: center
    }

    .sp-s52-date-lbl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9a9a9a;
        margin-bottom: 3px
    }

    .sp-s52-date-val {
        font-size: .85rem;
        font-weight: 800;
        color: #1a1a1a
    }
    /* ── PRINT PROGRESS OVERLAY ──────────────────────────── */
    .pp-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.72);
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px)
    }

        .pp-overlay.active {
            display: flex
        }

    .pp-modal {
        background: #fff;
        border-radius: 14px;
        padding: 32px 36px;
        width: 480px;
        max-width: 92vw;
        box-shadow: 0 24px 64px rgba(0,0,0,.45);
        font-family: 'Poppins',sans-serif
    }

    .pp-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px
    }

    .pp-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: linear-gradient(135deg,#F5CA3A,#D4A500);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0
    }

    .pp-title {
        font-size: .95rem;
        font-weight: 800;
        color: #0d0d0d
    }

    .pp-sub {
        font-size: .7rem;
        color: #9a9a9a;
        margin-top: 2px
    }

    .pp-bar-wrap {
        height: 14px;
        background: #f0f0f0;
        border-radius: 99px;
        overflow: hidden;
        margin-bottom: 10px
    }

    .pp-bar-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg,#D4A500,#F5CA3A);
        transition: width .4s ease;
        width: 0%
    }

        .pp-bar-fill.done {
            background: linear-gradient(90deg,#1a8a4a,#2ebd6c)
        }

    .pp-pct {
        font-size: 1.6rem;
        font-weight: 800;
        color: #0d0d0d;
        letter-spacing: -.05em;
        line-height: 1
    }

    .pp-pct-wrap {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 18px
    }

    .pp-counts {
        font-size: .7rem;
        color: #9a9a9a;
        text-align: right;
        line-height: 1.8
    }

        .pp-counts strong {
            color: #1a1a1a
        }

    .pp-chips {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 20px
    }

    .pp-chip {
        flex: 1;
        min-width: 90px;
        background: #f9f9f9;
        border: 1px solid #ebebeb;
        border-radius: 8px;
        padding: 8px 10px;
        text-align: center
    }

    .pp-chip-num {
        font-size: 1.1rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1
    }

        .pp-chip-num.green {
            color: #1a8a4a
        }

        .pp-chip-num.red {
            color: #c0392b
        }

        .pp-chip-num.gold {
            color: #D4A500
        }

    .pp-chip-lbl {
        font-size: .58rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9a9a9a;
        margin-top: 3px
    }

    .pp-path {
        background: #f5f5f5;
        border-radius: 7px;
        padding: 8px 12px;
        font-size: .67rem;
        color: #555;
        word-break: break-all;
        margin-bottom: 18px
    }

        .pp-path code {
            color: #D4A500;
            font-weight: 700
        }

    .pp-done-banner {
        background: linear-gradient(135deg,#0f5032,#1a8a4a);
        border-radius: 10px;
        padding: 14px 18px;
        display: none;
        align-items: center;
        gap: 12px;
        color: #fff;
        margin-bottom: 16px
    }

        .pp-done-banner.active {
            display: flex
        }

    .pp-done-icon {
        font-size: 1.8rem;
        flex-shrink: 0
    }

    .pp-done-title {
        font-size: .82rem;
        font-weight: 800
    }

    .pp-done-sub {
        font-size: .68rem;
        opacity: .8;
        margin-top: 2px
    }

    .pp-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        background: linear-gradient(135deg,#F5CA3A,#D4A500);
        border: none;
        cursor: pointer;
        font-family: 'Poppins',sans-serif;
        font-size: .8rem;
        font-weight: 800;
        color: #0d0d0d;
        box-shadow: 0 3px 10px rgba(230,176,0,.35);
        display: none
    }

        .pp-btn.active {
            display: flex
        }

    .pp-pulse {
        animation: ppulse 1.5s ease-in-out infinite
    }

    @@keyframes ppulse {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: .5
        }
    }
</style>

<div class="sp-fs">

    <!-- META BAR -->
    <div class="sp-meta">
        <div class="sp-chip"><span class="sp-cl">Roll</span><span class="sp-cv">@Model.RollShortCode — @Model.RollName</span></div>
        <div class="sp-chip"><span class="sp-cl">Notice</span><span class="sp-cv">@Model.Notice</span></div>
        <div class="sp-chip"><span class="sp-cl">Version</span><span class="sp-cv">@Model.VersionText</span></div>
        @if (Model.IsS52)
        {
            <div class="sp-chip"><span class="sp-cl">Type</span><span class="sp-cv">@subTypeLabel</span></div>
            <div class="sp-chip"><span class="sp-cl">Range</span><span class="sp-cv">@(Model.BulkFromDate?.ToString("dd MMM") ?? "?") – @(Model.BulkToDate?.ToString("dd MMM yyyy") ?? "?")</span></div>
        }
        else
        {
            <div class="sp-chip"><span class="sp-cl">Batches</span><span class="sp-cv">@Model.TotalBatches</span></div>
            <div class="sp-chip"><span class="sp-cl">Printed</span><span class="sp-cv">@Model.TotalPrinted.ToString("N0")</span></div>
            @if (Model.TotalFailed > 0)
            {
                <div class="sp-chip"><span class="sp-cl">Failed</span><span style="color:#f87171;font-weight:700">@Model.TotalFailed</span></div>
            }
        }
    </div>

    <!-- STEP TRAIL — different for S52 (no Batches step) vs standard -->
    <div class="sp-trail">
        <div style="display:flex;align-items:center;gap:6px">
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Configure</div>
            <div class="sp-arrow">›</div>
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Approve</div>
            <div class="sp-arrow">›</div>
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Kickoff</div>
            @if (!Model.IsS52)
            {
                <div class="sp-arrow">›</div>
                <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Batches</div>
            }
            <div class="sp-arrow">›</div>
            <div class="sp-bc active"><div class="sp-bc-dot">@(Model.IsS52 ? "4" : "5")</div>Print</div>
            <div class="sp-arrow">›</div>
            <div class="sp-bc"><div class="sp-bc-dot">@(Model.IsS52 ? "5" : "6")</div>Send Email</div>
        </div>
        <div class="sp-trail-label">Print @(Model.IsS52 ? "Range" : "Batches") &nbsp;·&nbsp; <span>Step 3</span></div>
    </div>

    <!-- BODY -->
    <div class="sp-body">

        <!-- ── LEFT SIDEBAR ──────────────────────────────────────────────── -->
        <div class="sp-left">

            @if (TempData["Success"] != null)
            {
                <div class="sp-alert sp-alert-ok">✅ @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="sp-alert sp-alert-err">⚠ @TempData["Error"]</div>
            }

            <!-- Stats — S52 shows range info, others show batch stats -->
            @if (Model.IsS52)
            {
                <div class="sp-stats">
                    <div class="sp-stat">
                        <div class="sp-sn gold">@subTypeLabel</div>
                        <div class="sp-sl">Print Type</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn">@(Model.BulkFromDate?.ToString("dd MMM") ?? "—")</div>
                        <div class="sp-sl">From Date</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn">@(Model.BulkToDate?.ToString("dd MMM") ?? "—")</div>
                        <div class="sp-sl">To Date</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn green">@Model.TotalPrinted.ToString("N0")</div>
                        <div class="sp-sl">Printed</div>
                    </div>
                </div>
            }
            else
            {
                <div class="sp-stats">
                    <div class="sp-stat">
                        <div class="sp-sn gold">@Model.TotalBatches</div>
                        <div class="sp-sl">Batches</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn">@Model.TotalRecordsBatched.ToString("N0")</div>
                        <div class="sp-sl">Total Records</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn green">@Model.TotalPrinted.ToString("N0")</div>
                        <div class="sp-sl">Printed</div>
                    </div>
                    <div class="sp-stat">
                        <div class="sp-sn @(Model.TotalFailed > 0 ? "red" : "")">@Model.TotalFailed.ToString("N0")</div>
                        <div class="sp-sl">Failed</div>
                    </div>
                </div>
            }

            <!-- Bulk actions -->
            <div class="sp-actions">
                @if (Model.IsS52)
                {
                    <!-- S52: Print All button triggers range print across all batches -->
                    @if (anyPrintable)
                    {
                        <button type="button" class="btn-gold" onclick="submitPrintAll()">
                            🖨 Print All Batches
                        </button>
                        <form id="printAllForm" action="/Step3/PrintAll" method="post" style="display:none">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="key" value="@key" />
                        </form>
                    }
                    else if (Model.Batches.Any())
                    {
                        <div class="btn-gold disabled" style="opacity:.5">🖨 Print All Batches</div>
                    }
                    <!-- S52: Go to Send Email -->
                    <a href="@Url.Action("SendEmail", "Step3", new { key })" class="btn-outline-gold">
                        📧 Go to Send Email →
                    </a>
                    <!-- S52: Back to Kickoff -->
                    <a href="@kickoffUrl" class="btn-outline-dark">
                        ← Back to Kickoff
                    </a>
                }
                else
                {
                    <!-- Standard notices: Print All -->
                    @if (anyPrintable)
                    {
                        <button type="button" class="btn-gold" onclick="submitPrintAll()">
                            🖨 Print All Batches
                        </button>
                        <form id="printAllForm" action="/Step3/PrintAll" method="post" style="display:none">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="key" value="@key" />
                        </form>
                    }
                    else
                    {
                        <div class="btn-gold disabled" style="opacity:.5">🖨 Print All Batches</div>
                    }
                    <!-- Navigate to Send Email -->
                    <a href="@Url.Action("SendEmail", "Step3", new { key })" class="btn-outline-gold">
                        📧 Go to Send Email →
                    </a>
                    <!-- Back to Kickoff to create more batches -->
                    <a href="@kickoffUrl" class="btn-outline-dark">
                        📦 Create More Batches
                    </a>
                }
            </div>

            <!-- Save path info -->
            <div class="sp-path-info">
                <b>📁 Save location:</b><br />
                <code>@($"C:\\[Roll Root]\\{Model.RollShortCode}_{Model.Notice}\\Batches\\[BatchName]\\[PropertyDesc]_{Model.Notice}.pdf")</code>
            </div>

            <!-- Workflow summary card -->
            <div class="sp-card">
                <div class="sp-card-hdr"><span>📋</span><h4>Workflow Summary</h4></div>
                <div class="sp-card-body">
                    <div class="sp-grid2">
                        <div class="sp-field"><div class="sp-fl">Notice</div><div class="sp-fv">@Model.Notice</div></div>
                        <div class="sp-field"><div class="sp-fl">Version</div><div class="sp-fv">@Model.VersionText</div></div>
                        <div class="sp-field" style="grid-column:span 2">
                            <div class="sp-fl">Letter Date</div>
                            <div class="sp-fv @(Model.LetterDate == null ? "empty" : "")">@(Model.LetterDate?.ToString("dd MMM yyyy") ?? "—")</div>
                        </div>
                        @if (!Model.IsS52)
                        {
                            <div class="sp-field">
                                <div class="sp-fl">Obj. Start</div>
                                <div class="sp-fv @(Model.ObjectionStartDate == null ? "empty" : "")">@(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—")</div>
                            </div>
                            <div class="sp-field">
                                <div class="sp-fl">Obj. End</div>
                                <div class="sp-fv @(Model.ObjectionEndDate == null ? "empty" : "")">@(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</div>
                            </div>
                            @if (Model.ExtensionDate.HasValue)
                            {
                                <div class="sp-field"><div class="sp-fl">Extension</div><div class="sp-fv">@Model.ExtensionDate.Value.ToString("dd MMM yyyy")</div></div>
                            }
                        }
                        else
                        {
                            <div class="sp-field">
                                <div class="sp-fl">From Date</div>
                                <div class="sp-fv">@(Model.BulkFromDate?.ToString("dd MMM yyyy") ?? "—")</div>
                            </div>
                            <div class="sp-field">
                                <div class="sp-fl">To Date</div>
                                <div class="sp-fv">@(Model.BulkToDate?.ToString("dd MMM yyyy") ?? "—")</div>
                            </div>
                        }
                        <div class="sp-field" style="grid-column:span 2">
                            <div class="sp-fl">Financial Years</div>
                            <div class="sp-fv @(string.IsNullOrWhiteSpace(Model.FinancialYearsText) ? "empty" : "")">@(Model.FinancialYearsText ?? "—")</div>
                        </div>
                    </div>
                    @if (!Model.IsS52)
                    {
                        <hr class="sp-divider" />
                        <div class="sp-field">
                            <div class="sp-fl">Signature</div><div class="sp-fv">
                                @if (!string.IsNullOrWhiteSpace(Model.SignaturePath))
                                {
                                    <span class="sp-badge-ok">✓ Uploaded</span>
                                }
                                else
                                {

                                    <span class="sp-badge-warn">⚠ Missing</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (allDone && !Model.IsS52)
            {
                <div class="sp-complete-banner" style="margin:14px 16px;border-radius:10px">
                    <div style="font-size:2rem;flex-shrink:0">🎉</div>
                    <div>
                        <div style="font-size:.82rem;font-weight:800;margin-bottom:2px">All Batches Printed</div>
                        <div style="font-size:.7rem;opacity:.75">@Model.TotalPrinted.ToString("N0") notices saved. Proceed to Send Email.</div>
                    </div>
                </div>
            }

        </div><!-- /sp-left -->
        <!-- ── RIGHT: BATCH PRINT TABLE ──────────────────────────────────── -->
        <div class="sp-right">
            <div class="sp-rh">
                <div class="sp-rh-title">
                    <div class="sp-rh-icon">🖨</div>
                    Print Dashboard — @Model.Notice — @Model.RollShortCode
                    @if (Model.IsS52)
                    {
                        <span style="margin-left:6px;font-size:.68rem;opacity:.7">(@subTypeLabel)</span>
                    }
                </div>
                <span class="sp-badge-info">@Model.Batches.Count batch@(Model.Batches.Count == 1 ? "" : "es")</span>
            </div>
            <div class="sp-rb">
                @if (!Model.Batches.Any())
                {
                    <div class="sp-empty">
                        <div class="sp-empty-icon">📦</div>
                        @if (Model.IsS52)
                        {
                            <div style="font-size:.95rem;font-weight:800;color:#1a1a1a;margin-bottom:6px">No Batches Found</div>
                            <div style="font-size:.75rem;color:#9a9a9a;line-height:1.7;max-width:300px">
                                No S52 batches have been created yet.<br />Return to the Kickoff page and use the batch panel if records are available.
                            </div>
                            <a href="@kickoffUrl" class="btn-gold" style="margin-top:20px;max-width:220px">
                                ← Back to Kickoff
                            </a>
                        }
                        else
                        {
                            <div style="font-size:.95rem;font-weight:800;color:#1a1a1a;margin-bottom:6px">No Batches Found</div>
                            <div style="font-size:.75rem;color:#9a9a9a;line-height:1.7;max-width:300px">
                                Go back to <strong>Create Batches</strong> to create batches first.
                            </div>
                            <a href="@kickoffUrl" class="btn-gold" style="margin-top:20px;max-width:220px">
                                📦 Go to Create Batches
                            </a>
                        }
                    </div>
                }
                else
                {
                    <table class="sp-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Batch Code</th>
                                <th>Date</th>
                                <th>Records</th>
                                <th>Status</th>
                                <th style="text-align:center">Print</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowNum = 0;
                            }
                            @foreach (var b in Model.Batches)
                            {
                                rowNum++;
                                var total = b.NumberOfRecords;
                                var pct = total == 0 ? 0 : (int)Math.Round(b.PrintedCount * 100m / total);
                                pct = Math.Clamp(pct, 0, 100);
                                <tr>
                                    <td class="sp-dt" style="color:#bbb;width:30px">@rowNum</td>
                                    <td>
                                        <span class="sp-code">@b.BatchName</span>
                                        <div class="sp-meta-sub">@b.CreatedBy · @b.CreatedAtUtc.ToString("dd MMM yyyy HH:mm")</div>
                                    </td>
                                    <td class="sp-dt">@b.BatchDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span style="font-weight:700">@b.NumberOfRecords.ToString("N0")</span>
                                        <div class="sp-mini-prog">
                                            <div class="sp-mini-fill @(pct == 100 ? "done" : "")" style="width:@pct%"></div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="sp-status-bar">
                                            @if (b.PrintedCount > 0)
                                            {
                                                <span class="sp-status-pill sp-status-done">✓ @b.PrintedCount printed</span>
                                            }
                                            @if (b.GeneratedCount > 0)
                                            {
                                                <span class="sp-status-pill sp-status-gen">⏳ @b.GeneratedCount pending</span>
                                            }
                                            @if (b.SentCount > 0)
                                            {
                                                <span class="sp-status-pill sp-status-sent">📧 @b.SentCount sent</span>
                                            }
                                            @if (b.FailedCount > 0)
                                            {
                                                <span class="sp-status-pill sp-status-fail">✗ @b.FailedCount failed</span>
                                            }
                                        </div>
                                    </td>
                                    <td style="text-align:center">
                                        @if (b.GeneratedCount > 0 || b.FailedCount > 0)
                                        {
                                            <button type="button" class="btn-print-row"
                                                    onclick="submitPrintBatch(@b.BatchId, '@b.BatchName', @b.NumberOfRecords, this)">
                                                🖨 @(b.PrintedCount > 0 ? "Retry" : "Print")
                                            </button>
                                            <form id="printForm_@b.BatchId"
                                                  action="/Step3/PrintBatch" method="post" style="display:none">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="batchId" value="@b.BatchId" />
                                                <input type="hidden" name="key" value="@key" />
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="sp-badge-ok">✓ Done</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div><!-- /sp-right -->

    </div><!-- /sp-body -->
</div><!-- /sp-fs -->
<!-- ── PRINT PROGRESS OVERLAY ─────────────────────────────────── -->
<div class="pp-overlay" id="ppOverlay">
    <div class="pp-modal">
        <div class="pp-header">
            <div class="pp-icon">🖨</div>
            <div>
                <div class="pp-title" id="ppTitle">Printing batch…</div>
                <div class="pp-sub" id="ppBatchName">Please wait</div>
            </div>
        </div>
        <div class="pp-bar-wrap">
            <div class="pp-bar-fill" id="ppBarFill"></div>
        </div>
        <div class="pp-pct-wrap">
            <div class="pp-pct"><span id="ppPct">0</span>%</div>
            <div class="pp-counts">
                <div>Total: <strong id="ppTotal">—</strong></div>
                <div>Printed: <strong id="ppPrinted">0</strong></div>
                <div>Remaining: <strong id="ppRemaining">—</strong></div>
            </div>
        </div>
        <div class="pp-chips">
            <div class="pp-chip">
                <div class="pp-chip-num gold" id="ppChipGen">—</div>
                <div class="pp-chip-lbl">Pending</div>
            </div>
            <div class="pp-chip">
                <div class="pp-chip-num green" id="ppChipDone">0</div>
                <div class="pp-chip-lbl">Printed</div>
            </div>
            <div class="pp-chip">
                <div class="pp-chip-num red" id="ppChipFail">0</div>
                <div class="pp-chip-lbl">Failed</div>
            </div>
        </div>
        <div class="pp-path">
            📁 Saving to: <code id="ppPath">@($"[Roll Root]\\{Model.RollShortCode}_{Model.Notice}\\Batches\\[BatchName]\\[Property]_{Model.Notice}.pdf")</code>
        </div>
        <div id="ppWorking" style="text-align:center;font-size:.72rem;color:#9a9a9a;margin-bottom:16px">
            <span class="pp-pulse">⏳ Printing in progress…</span>
        </div>
        <div class="pp-done-banner" id="ppDoneBanner">
            <div class="pp-done-icon">🎉</div>
            <div>
                <div class="pp-done-title" id="ppDoneTitle">Batch printed successfully</div>
                <div class="pp-done-sub" id="ppDoneSub">All notices saved to folder</div>
            </div>
        </div>
        <button class="pp-btn" id="ppCloseBtn" onclick="closePrintOverlay()">
            ✓ Done — Close
        </button>
    </div>
</div>

<script>
    let _pollTimer  = null;
    let _currentKey = '@key';

    function submitPrintBatch(batchId, batchName, totalRecords, btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="sp-spin"></span> Starting…';
        startPrint(batchId, batchName, totalRecords);
        document.getElementById('printForm_' + batchId).submit();
    }

    function submitPrintAll() {
        const totalRecords = @Model.Batches.Sum(b => b.GeneratedCount + b.FailedCount);
        startPrint(0, 'All Batches', totalRecords);
        document.getElementById('printAllForm').submit();
    }

    function startPrint(batchId, batchName, totalRecords) {
        document.getElementById('ppOverlay').classList.add('active');
        document.getElementById('ppTitle').textContent     = 'Printing batch…';
        document.getElementById('ppBatchName').textContent = batchName;
        document.getElementById('ppTotal').textContent     = totalRecords;
        document.getElementById('ppRemaining').textContent = totalRecords;
        document.getElementById('ppChipGen').textContent   = totalRecords;
        document.getElementById('ppChipDone').textContent  = '0';
        document.getElementById('ppChipFail').textContent  = '0';
        document.getElementById('ppBarFill').style.width   = '0%';
        document.getElementById('ppBarFill').classList.remove('done');
        document.getElementById('ppPct').textContent       = '0';
        document.getElementById('ppWorking').style.display = '';
        document.getElementById('ppDoneBanner').classList.remove('active');
        document.getElementById('ppCloseBtn').classList.remove('active');
        document.getElementById('ppPath').textContent =
            `[Roll Root]\\@(Model.RollShortCode)_@(Model.Notice)\\Batches\\${batchName}\\[Property]_@(Model.Notice).pdf`;
        _pollTimer = setInterval(() => pollProgress(batchId), 600);
    }

    function pollProgress(batchId) {
        const url = batchId === 0
            ? `/Step3/PrintProgressAll?key=${_currentKey}`
            : `/Step3/PrintProgress?batchId=${batchId}`;
        fetch(url)
            .then(r => r.json())
            .then(d => {
                const total   = d.total   || 0;
                const printed = d.printed || 0;
                const failed  = d.failed  || 0;
                const gen     = d.generated || 0;
                const pct     = total > 0 ? Math.round((printed + failed) * 100 / total) : 0;

                document.getElementById('ppPct').textContent       = pct;
                document.getElementById('ppTotal').textContent     = total.toLocaleString();
                document.getElementById('ppPrinted').textContent   = printed.toLocaleString();
                document.getElementById('ppRemaining').textContent = gen.toLocaleString();
                document.getElementById('ppChipGen').textContent   = gen.toLocaleString();
                document.getElementById('ppChipDone').textContent  = printed.toLocaleString();
                document.getElementById('ppChipFail').textContent  = failed.toLocaleString();

                const bar = document.getElementById('ppBarFill');
                bar.style.width = pct + '%';

                if (d.done) {
                    clearInterval(_pollTimer);
                    bar.classList.add('done');
                    document.getElementById('ppWorking').style.display = 'none';
                    const banner = document.getElementById('ppDoneBanner');
                    banner.classList.add('active');
                    document.getElementById('ppDoneTitle').textContent =
                        failed > 0
                            ? `Done — ${printed.toLocaleString()} printed, ${failed.toLocaleString()} failed`
                            : `${printed.toLocaleString()} notices printed successfully`;
                    document.getElementById('ppDoneSub').textContent =
                        `Saved to: @(Model.RollShortCode)_@(Model.Notice)\\Batches`;
                    document.getElementById('ppCloseBtn').classList.add('active');
                    document.getElementById('ppTitle').textContent = 'Print complete';
                }
            })
            .catch(() => { /* keep polling on transient error */ });
    }

    function closePrintOverlay() {
        clearInterval(_pollTimer);
        document.getElementById('ppOverlay').classList.remove('active');
        window.location.reload();
    }
</script>
