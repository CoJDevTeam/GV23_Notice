@model GV23_Notice.Models.Workflow.ViewModels.Step3SelectVm
@using System.Globalization
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Step 3 — Processing";
    string D(DateTime d) => d.ToString("dd MMM yyyy", CultureInfo.InvariantCulture);
    var hasResults = Model.RollId != null && Model.Notice != null;
    var hasRows = hasResults && Model.Rows.Count > 0;
    var approvedRows = Model.Rows.Where(r => r.Step2Approved).ToList();
    var corrRows = Model.Rows.Where(r => r.Step2CorrectionRequested).ToList();
    var now = DateTime.Now;
}

<link href="~/css/step3/step3index.css" rel="stylesheet" />

<div class="s3i-page">

    <!-- TITLE BAR -->
    <div class="s3i-title-bar">
        <div>
            <div class="s3i-title">Step 3 — <span>Processing</span></div>
            <div class="s3i-subtitle">Select an approved workflow to begin batch creation, printing and email dispatch</div>
        </div>
        <div class="s3i-crumb">Phase <span>3 of 3</span> &nbsp;·&nbsp; Data Team</div>
    </div>

    <!-- HERO BANNER -->
    <div class="s3i-hero">
        <div class="s3i-hero-text">
            <h2>Step 3 — Data Team Processing</h2>
            <p>Select an approved workflow below. Once selected you can validate the kickoff preview, create batches of up to 500 records each, print PDFs and dispatch email notices directly to ratepayers.</p>
            <div class="s3i-hero-badges">
                <span class="s3i-badge s3i-badge-step">⚡ Phase 3 Active</span>
                <span class="s3i-badge s3i-badge-phase">📋 Kickoff → Batch → Print → Send</span>
            </div>
        </div>
        <div class="s3i-step-pips">
            <div class="s3i-pip done"></div>
            <div class="s3i-pip done"></div>
            <div class="s3i-pip active"></div>
        </div>
    </div>

    <!-- STATS — only when results are loaded -->
    @if (hasResults)
    {
        <div class="s3i-stats">
            <div class="s3i-stat gold">
                <span class="s3i-stat-lbl">Results Found</span>
                <span class="s3i-stat-num">@Model.Rows.Count</span>
                <span class="s3i-stat-sub">Matching workflows</span>
            </div>
            <div class="s3i-stat green">
                <span class="s3i-stat-lbl">Step 2 Approved</span>
                <span class="s3i-stat-num">@approvedRows.Count</span>
                <span class="s3i-stat-sub">Ready to process</span>
            </div>
            <div class="s3i-stat orange">
                <span class="s3i-stat-lbl">Correction Req.</span>
                <span class="s3i-stat-num">@corrRows.Count</span>
                <span class="s3i-stat-sub">Pending correction</span>
            </div>
            <div class="s3i-stat">
                <span class="s3i-stat-lbl">Roll</span>
                <span class="s3i-stat-num" style="font-size:20px">@(Model.Rows.FirstOrDefault()?.RollShortCode ?? "—")</span>
                <span class="s3i-stat-sub">@Model.Notice</span>
            </div>
        </div>
    }

    <!-- MAIN COLUMNS -->
    <div class="s3i-cols">

        <!-- LEFT: Filter + Results -->
        <div>
            <!-- FILTER CARD -->
            <div class="s3i-card" style="margin-bottom:16px">
                <div class="s3i-card-head">
                    <h3>🔍 Select Roll &amp; Notice Type</h3>
                </div>
                <div class="s3i-card-body">
                    <form method="get" asp-action="Index" asp-controller="Step3">
                        <div class="s3i-form-grid">
                            <div class="s3i-form-field">
                                <label class="s3i-form-label">Roll</label>
                                <select class="s3i-form-select" name="rollId">
                                    <option value="">— Select Roll —</option>
                                    @foreach (var r in Model.Rolls)
                                    {
                                        <option value="@r.Value" selected="@r.Selected">@r.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="s3i-form-field">
                                <label class="s3i-form-label">Notice Type</label>
                                <select class="s3i-form-select" name="notice">
                                    <option value="">— Select Notice —</option>
                                    @foreach (var n in Model.Notices)
                                    {
                                        <option value="@n.Value" selected="@n.Selected">@n.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="s3i-form-field">
                                <button class="s3i-btn-load" type="submit">
                                    ↻ Load Workflows
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- RESULTS -->
            @if (!hasResults)
            {
                <div class="s3i-alert info">
                    <div class="s3i-alert-icon">ℹ</div>
                    <div>Select a <strong>Roll</strong> and <strong>Notice Type</strong> above, then click <strong>Load Workflows</strong> to see approved workflows ready for Step 3 processing.</div>
                </div>
            }
            else if (!hasRows)
            {
                <div class="s3i-alert warn">
                    <div class="s3i-alert-icon">⚠</div>
                    <div>
                        <strong>No workflows found</strong> for this Roll + Notice combination.<br />
                        <span style="font-size:11px;opacity:.8;">Requirements: Step 1 Approved + WorkflowKey generated + Step 2 Approved or Correction Requested.</span>
                    </div>
                </div>
            }
            else
            {
                <div class="s3i-divider"><h3>Approved Workflows — @Model.Rows.Count found</h3></div>
                <div class="s3i-wf-grid">
                    @foreach (var r in Model.Rows)
                    {
                        var cardClass = r.Step2Approved ? "approved" : "correction";
                        var iconEmoji = r.Step2Approved ? "✓" : "✎";
                        <div class="s3i-wf-card @cardClass">
                            <div class="s3i-wf-icon @cardClass">@iconEmoji</div>
                            <div>
                                <div class="s3i-wf-name">@r.RollName</div>
                                <div class="s3i-wf-meta">
                                    <span class="s3i-wf-chip chip-notice">@r.Notice</span>
                                    <span class="s3i-wf-chip chip-mode">@r.Mode</span>
                                    <span class="s3i-wf-chip chip-ver">v@r.VersionText</span>
                                    @if (r.Step2Approved)
                                    {
                                        <span class="s3i-wf-chip chip-approved">✓ Step 2 Approved</span>
                                    }
                                    else
                                    {
                                        <span class="s3i-wf-chip chip-correction">✎ Correction Requested</span>
                                    }
                                </div>
                                <div class="s3i-wf-dates">
                                    Letter date: <strong>@D(r.LetterDate)</strong>
                                    &nbsp;·&nbsp; Step 1 approved by <strong>@r.Step1ApprovedBy</strong>
                                    @if (r.Step1ApprovedAtUtc.HasValue)
                                    {
                                        <span>on @r.Step1ApprovedAtUtc.Value.ToString("dd MMM yyyy")</span>
                                    }
                                </div>
                            </div>
                            <div class="s3i-wf-action">
                                <a class="s3i-btn-open"
                                   href="@Url.Action("Open", "Step3", new { key = r.WorkflowKey })">
                                    ▶ Open
                                </a>
                                <div class="s3i-wf-key" title="@r.WorkflowKey">@r.WorkflowKey</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- RIGHT SIDEBAR -->
        <div class="s3i-sidebar">

            <!-- Processing steps guide -->
            <div class="s3i-tip-card">
                <div class="s3i-tip-head"><h4>📍 Step 3 Process</h4></div>
                <div class="s3i-tip-body">
                    <div class="s3i-step-list">
                        <div class="s3i-step-item">
                            <div class="s3i-step-num done">✓</div>
                            <div class="s3i-step-text">
                                <div class="s3i-step-title">Select Workflow</div>
                                <div class="s3i-step-desc">Choose a Step 2-approved workflow to begin.</div>
                            </div>
                        </div>
                        <div class="s3i-step-item">
                            <div class="s3i-step-num active">2</div>
                            <div class="s3i-step-text">
                                <div class="s3i-step-title">Kickoff &amp; Preview</div>
                                <div class="s3i-step-desc">Validate PDF preview and confirm batch creation.</div>
                            </div>
                        </div>
                        <div class="s3i-step-item">
                            <div class="s3i-step-num locked">3</div>
                            <div class="s3i-step-text">
                                <div class="s3i-step-title">Create Batches</div>
                                <div class="s3i-step-desc">Assign records into batches of up to 500.</div>
                            </div>
                        </div>
                        <div class="s3i-step-item">
                            <div class="s3i-step-num locked">4</div>
                            <div class="s3i-step-text">
                                <div class="s3i-step-title">Print PDFs</div>
                                <div class="s3i-step-desc">Generate and save PDFs for each batch.</div>
                            </div>
                        </div>
                        <div class="s3i-step-item">
                            <div class="s3i-step-num locked">5</div>
                            <div class="s3i-step-text">
                                <div class="s3i-step-title">Send Email Notices</div>
                                <div class="s3i-step-desc">Dispatch emails and save .eml copies to disk.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notice types reference -->
            <div class="s3i-tip-card">
                <div class="s3i-tip-head"><h4>📑 Notice Types</h4></div>
                <div class="s3i-tip-body">
                    <div class="s3i-ntype-list">
                        @foreach (var nt in new[]{
                                                ("S49","General Valuation"),
                                                ("S51","Third Party"),
                                                ("S52","Appeal"),
                                                ("S53","MVD Outcome"),
                                                ("DJ", "Dear Johnny"),
                                                ("IN", "Invalid Notice"),
                                                ("S78","Inspection")
                                                })
                        {
                            <div class="s3i-ntype-row">
                                <span class="s3i-ntype-code">@nt.Item1</span>
                                <span class="s3i-ntype-name">@nt.Item2</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div><!-- /s3i-cols -->

</div><!-- /s3i-page -->
