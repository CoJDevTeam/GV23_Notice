@model GV23_Notice.Models.Workflow.ViewModels.Step3SelectVm
@using System.Globalization
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Step 3 — Processing";
    string D(DateTime d) => d.ToString("dd MMM yyyy", CultureInfo.InvariantCulture);

    string NoticeName(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "Section 49 — Public Inspection & Objections",
        NoticeKind.S51 => "Section 51 — Objection Decision",
        NoticeKind.S52 => "Section 52 — Appeal Notices",
        NoticeKind.S53 => "Section 53 — MVD Decision",
        NoticeKind.DJ => "Dear Johnny Notice",
        NoticeKind.IN => "Invalid Notice",
        NoticeKind.S78 => "Section 78 — Review Period",
        _ => n.ToString()
    };
    string NoticeChip(NoticeKind n) => n switch
    {
        NoticeKind.S49 => "s3i-chip-s49",
        NoticeKind.S51 => "s3i-chip-s51",
        NoticeKind.S52 => "s3i-chip-s52",
        NoticeKind.S53 => "s3i-chip-s53",
        NoticeKind.DJ => "s3i-chip-dj",
        NoticeKind.IN => "s3i-chip-in",
        NoticeKind.S78 => "s3i-chip-s78",
        _ => ""
    };

    var allRows = Model.Rows;
    var readyRows = allRows.Where(r => r.Step2Approved).ToList();
    var corrRows = allRows.Where(r => r.Step2CorrectionRequested && !r.Step2Approved).ToList();
}

<link href="~/css/step3/step3indexcss.css" rel="stylesheet" asp-append-version="true" />

<div class="s3i-page">

    <!-- Hero -->
    <div class="s3i-hero">
        <div class="s3i-hero-inner">
            <div>
                <div class="s3i-hero-eyebrow">
                    <span class="s3i-hero-dot"></span>
                    Data Team · Phase 3 of 3
                </div>
                <h1 class="s3i-hero-title">Step 3 — <em>Processing</em></h1>
                <p class="s3i-hero-sub">
                    Select an approved configuration to create batches,
                    print PDFs and send notices to ratepayers.
                </p>
            </div>
            <a class="s3i-hero-link" href="@Url.Action("SettingsLibrary", "Workflow")">
                ← Settings Library
            </a>
        </div>
    </div>

    <div class="s3i-body">

        <!-- Stats strip -->
        <div class="s3i-stats">
            <div class="s3i-stat s3i-stat-gold">
                <div class="s3i-stat-lbl">Total Workflows</div>
                <div class="s3i-stat-num">@allRows.Count</div>
                <div class="s3i-stat-sub">Approved configurations</div>
            </div>
            <div class="s3i-stat s3i-stat-green">
                <div class="s3i-stat-lbl">Ready to Process</div>
                <div class="s3i-stat-num">@readyRows.Count</div>
                <div class="s3i-stat-sub">Step 2 approved</div>
            </div>
            <div class="s3i-stat">
                <div class="s3i-stat-lbl">Corrections</div>
                <div class="s3i-stat-num">@corrRows.Count</div>
                <div class="s3i-stat-sub">Correction requested</div>
            </div>
            <div class="s3i-stat">
                <div class="s3i-stat-lbl">Notice Types</div>
                <div class="s3i-stat-num">@allRows.Select(r => r.Notice).Distinct().Count()</div>
                <div class="s3i-stat-sub">Distinct types</div>
            </div>
        </div>

        <!-- Section header -->
        <div class="s3i-sec-head">
            <div class="s3i-sec-left">
                <div class="s3i-sec-bar"></div>
                <span class="s3i-sec-title">Select a Configuration</span>
            </div>
            <span style="font-size:11.5px;color:var(--s3i-mu)">
                Click <strong>Start Processing</strong> on a row to create batches for that notice
            </span>
        </div>

        <!-- Table card -->
        <div class="s3i-card">
            <div class="s3i-card-head">
                <span class="s3i-card-title">Approved Notice Configurations</span>
                <span style="font-size:11.5px;color:var(--s3i-mu)">Sort by column · Use search to filter</span>
            </div>

            @if (!allRows.Any())
            {
                <div class="s3i-empty">
                    <div class="s3i-empty-icon">📭</div>
                    <p>
                        No approved configurations found.<br />
                        Complete Steps 1 and 2 first to create an approved workflow.
                    </p>
                    <a href="@Url.Action("Step1", "Workflow")"
                       style="display:inline-flex;align-items:center;gap:6px;margin-top:14px;
                                  font-size:13px;font-weight:700;padding:9px 18px;border-radius:8px;
                                  background:var(--s3i-black);color:#fff;text-decoration:none;">
                        Go to Step 1 →
                    </a>
                </div>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table id="s3Table" class="s3i-table" style="width:100%">
                        <thead>
                            <tr>
                                <th>Roll</th>
                                <th>Notice Type</th>
                                <th>Mode</th>
                                <th>Ver</th>
                                <th>Letter Date</th>
                                <th>Status</th>
                                <th style="width:220px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in allRows)
                            {
                                bool canStart = r.Step2Approved && r.ApprovalKey != Guid.Empty;
                                string? kickUrl = canStart
                                ? Url.Action("Step3Kickoff", "Workflow",
                                new { settingsId = r.SettingsId, key = r.ApprovalKey })
                                : null;
                                string? prevUrl = Url.Action("Step2", "Workflow",
                                new { settingsId = r.SettingsId, variant = "Default", mode = "single" });

                                <tr>
                                    <td>
                                        <div class="s3i-roll-name">@r.RollName</div>
                                        <span class="s3i-roll-code">@r.RollShortCode</span>
                                    </td>
                                    <td>
                                        <span class="s3i-notice-chip @NoticeChip(r.Notice)">@r.Notice</span>
                                        <div class="s3i-notice-name">@NoticeName(r.Notice)</div>
                                    </td>
                                    <td>
                                        <span class="s3i-status"
                                              style="background:var(--s3i-surf);color:var(--s3i-mu);border-color:var(--s3i-bord)">
                                            @r.Mode
                                        </span>
                                    </td>
                                    <td class="s3i-date">v@r.VersionText</td>
                                    <td class="s3i-date">@D(r.LetterDate)</td>
                                    <td>
                                        @if (r.Step2Approved)
                                        {
                                            <span class="s3i-status s3i-pip-ok">✓ Approved</span>
                                        }
                                        else if (r.Step2CorrectionRequested)
                                        {

                                            <span class="s3i-status s3i-pip-corr">Correction</span>
                                        }
                                        else
                                        {

                                            <span class="s3i-status" style="background:var(--s3i-surf);color:var(--s3i-mu);border-color:var(--s3i-bord)">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap">
                                            @if (canStart)
                                            {
                                                <!-- Primary: go straight to batch creation -->
                                                <a class="s3i-action s3i-action-primary" href="@kickUrl">
                                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none"
                                                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                        <polygon points="5 3 19 12 5 21 5 3" />
                                                    </svg>
                                                    Start Processing
                                                </a>
                                                <!-- Secondary: view the notice preview first -->
                                                <a class="s3i-preview-link" href="@prevUrl">
                                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none"
                                                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                    Preview
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="s3i-action s3i-action-disabled">Not Ready</span>
                                                <!-- Still allow preview even if not approved -->
                                                <a class="s3i-preview-link" href="@prevUrl">Preview</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof $.fn.DataTable === "undefined") return;
            $('#s3Table').DataTable({
                pageLength: 15,
                lengthMenu: [10, 15, 25, 50],
                order: [[4, 'desc']],
                columnDefs: [{ orderable: false, targets: 6 }],
                language: {
                    search: "",
                    searchPlaceholder: "Search workflows…",
                    lengthMenu: "Show _MENU_ rows",
                    info: "Showing _START_–_END_ of _TOTAL_",
                    infoEmpty: "No workflows found",
                    paginate: { previous: "‹", next: "›" }
                },
                dom: "<'dt-toolbar'<'dataTables_length'l><'dataTables_filter'f>>t<'row'<'col-sm-6'i><'col-sm-6'p>>"
            });
        });
    </script>
}
