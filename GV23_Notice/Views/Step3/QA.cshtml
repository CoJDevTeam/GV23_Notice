@using GV23_Notice.Domain.Workflow
@model GV23_Notice.Models.Workflow.ViewModels.NoticeQaVm

@{
    var key = Model.WorkflowKey;

    bool isTpa = Model.Notice == NoticeKind.TPA;
    bool isClaTpa = Model.Notice == NoticeKind.CLA_TPA;
    bool isDirectThirdParty = isTpa || isClaTpa;

    string noticeLabel = Model.Notice switch
    {
        NoticeKind.TPA => "Third-Party Appeal Application",
        NoticeKind.CLA_TPA => "CLA-THIRD PARTY APPLICATION NOTICE",
        _ => Model.Notice.ToString()
    };

    string referenceLabel = isClaTpa
        ? "CLA Number"
        : isTpa
            ? "Appeal Number"
            : "Objection No";

    ViewData["Title"] = isClaTpa
        ? "Step 3 — CLA QA"
        : isTpa
            ? "Step 3 — TPA QA"
            : "Step 3 — QA Printed Notices";
}

<link href="~/css/Step3/Step3KickOffCss1.css" rel="stylesheet" />

<style>
    .qa-wrap {
        padding: 24px;
        font-family: 'Poppins', sans-serif;
    }

    .qa-head {
        background: #111;
        color: #fff;
        padding: 18px 22px;
        border-radius: 14px;
        margin-bottom: 18px;
        border-bottom: 4px solid #e6b000;
    }

        .qa-head h1 {
            margin: 0;
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

    .qa-meta {
        margin-top: 8px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: .78rem;
        color: #ddd;
    }

    .qa-card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        margin-bottom: 18px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.06);
    }

    .qa-card-head {
        background: #f8f8f8;
        padding: 14px 18px;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .qa-card-head strong {
            font-size: .95rem;
        }

    .qa-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .78rem;
    }

        .qa-table th {
            background: #fafafa;
            text-align: left;
            padding: 10px;
            border-bottom: 1px solid #ddd;
            color: #555;
            text-transform: uppercase;
            letter-spacing: .04em;
            font-size: .68rem;
        }

        .qa-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            vertical-align: top;
        }

    .qa-pill {
        display: inline-block;
        padding: 4px 9px;
        border-radius: 999px;
        font-size: .68rem;
        font-weight: 700;
    }

    .qa-pass {
        background: #e8f7ee;
        color: #137a3b;
    }

    .qa-fail {
        background: #fdeaea;
        color: #b42318;
    }

    .qa-pending {
        background: #fff6d8;
        color: #8a6500;
    }

    .qa-actions {
        display: flex;
        gap: 10px;
        margin: 18px 0;
        flex-wrap: wrap;
    }

    .qa-btn {
        border: none;
        border-radius: 10px;
        padding: 10px 16px;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .qa-btn-main {
        background: #111;
        color: #fff;
    }

    .qa-btn-gold {
        background: #e6b000;
        color: #111;
    }

    .qa-btn-green {
        background: #15803d;
        color: #fff;
    }

    .qa-btn-disabled {
        background: #ccc;
        color: #666;
        cursor: not-allowed;
    }

    .qa-alert {
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-size: .8rem;
        font-weight: 600;
    }

    .qa-alert-error {
        background: #fdeaea;
        color: #b42318;
    }

    .qa-alert-success {
        background: #e8f7ee;
        color: #137a3b;
    }

    .qa-alert-info {
        background: #eef4ff;
        color: #1d4ed8;
    }

    .qa-comment {
        width: 100%;
        min-height: 80px;
        border-radius: 10px;
        border: 1px solid #ccc;
        padding: 10px;
        font-size: .82rem;
    }

    .qa-direct-note {
        background: #fff8dc;
        border: 1px solid #e8c85a;
        color: #6d5200;
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 14px;
        font-size: .8rem;
        font-weight: 600;
    }

    .qa-ref {
        font-family: 'Courier New', monospace;
        font-weight: 700;
        white-space: nowrap;
    }

    .qa-muted {
        color: #999;
    }
</style>

<div class="qa-wrap">

    <div class="qa-head">
        <h1>@(isClaTpa ? "CLA Printed Notice QA" : isTpa ? "Third-Party Appeal QA" : "QA Printed Notices")</h1>
        <div class="qa-meta">
            <span><b>Roll:</b> @Model.RollShortCode</span>
            <span><b>Notice:</b> @noticeLabel</span>
            <span><b>Version:</b> @Model.VersionText</span>
            <span><b>Printed:</b> @Model.TotalPrinted</span>
            <span><b>QA Status:</b> @Model.QaStatus</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="qa-alert qa-alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="qa-alert qa-alert-error">@TempData["Error"]</div>
    }

    @if (isClaTpa)
    {
        <div class="qa-direct-note">
            CLA QA checks the printed notice PDF, CLA number, Premise ID, property description and appeal-pack ZIP file.
        </div>
    }
    else if (isTpa)
    {
        <div class="qa-direct-note">
            TPA QA checks the printed notice PDF and required appeal record information. This workflow does not use batches.
        </div>
    }

    @if (Model.IsApproved)
    {
        <div class="qa-alert qa-alert-success">
            QA has been approved. You can now send notices.
        </div>
    }
    else if (Model.QaRunId == null)
    {
        <div class="qa-alert qa-alert-info">
            Create the QA sample before sending emails. The system will select a dynamic sample based on the notice type and available printed records.
        </div>
    }
    else if (Model.FailedItems > 0)
    {
        <div class="qa-alert qa-alert-error">
            @(isDirectThirdParty ? "QA has " + Model.FailedItems + " failed item(s). Fix the missing PDF or required files before approval." : "QA has " + Model.FailedItems + " failed item(s). Fix captured values before approval.")
        </div>
    }

    <div class="qa-actions">
        @if (Model.QaRunId == null || Model.QaStatus == "Open")
        {
            <form asp-action="CreateQA" asp-controller="Step3" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@key" />
                <button type="submit" class="qa-btn qa-btn-main">
                    Create / Recreate QA Sample
                </button>
            </form>
        }

        <a class="qa-btn qa-btn-gold"
               asp-action="Print"
               asp-controller="Step3"
               asp-route-key="@key">
            Back to Print
        </a>

        @if (Model.IsApproved)
        {
            <a class="qa-btn qa-btn-green"
                   asp-action="SendEmail"
                   asp-controller="Step3"
                   asp-route-key="@key">
                Go to Send Notice
            </a>
        }
        else
        {
            <span class="qa-btn qa-btn-disabled">
                Send Notice Locked Until QA Approval
            </span>
        }
    </div>

    @if (Model.Groups.Any())
    {
        foreach (var group in Model.Groups)
        {
            <div class="qa-card">
                <div class="qa-card-head">
                    <strong>@group.GroupLabel: @group.PropertyType</strong>
                    <span>@group.Items.Count item(s)</span>
                </div>

                <table class="qa-table">
                    <thead>
                        <tr>
                            <th>@referenceLabel</th>
                            <th>Premise ID</th>
                            <th>Property</th>
                            <th>Expected QA Check</th>

                            @if (!isDirectThirdParty)
                            {
                                <th>New Category MVD</th>
                                <th>New2</th>
                                <th>New3</th>
                            }

                            <th>Status</th>
                            <th>PDF</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in group.Items)
                        {
                            <tr>
                                <td class="qa-ref">@item.ObjectionNo</td>
                                <td>@(string.IsNullOrWhiteSpace(item.PremiseId) ? "—" : item.PremiseId)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.PropertyDesc) ? "—" : item.PropertyDesc)</td>
                                <td>
                                    <strong>@item.ExpectedCategory</strong>

                                    @if (!isDirectThirdParty && item.IsMulti)
                                    {
                                        <div style="margin-top:4px;color:#b42318;font-weight:700;">
                                            Multi must show Multiple Purposes and split categories.
                                        </div>
                                    }
                                </td>

                                @if (!isDirectThirdParty)
                                {
                                    <td>@item.NewCategoryMvd</td>
                                    <td>@item.New2CategoryMvd</td>
                                    <td>@item.New3CategoryMvd</td>
                                }

                                <td>
                                    @if (item.IsCategoryValid)
                                    {
                                        <span class="qa-pill qa-pass">Passed</span>
                                    }
                                    else
                                    {
                                        <span class="qa-pill qa-fail">Failed</span>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.QaComment))
                                    {
                                        <div style="margin-top:5px;color:#777;">
                                            @item.QaComment
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.PdfPath))
                                    {
                                        if (isDirectThirdParty)
                                        {
                                            <a class="qa-btn qa-btn-main"
                                                   target="_blank"
                                                   asp-action="OpenQaPdfByPath"
                                                   asp-controller="Step3"
                                                   asp-route-qaItemId="@item.QaItemId">
                                                View PDF
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="qa-btn qa-btn-main"
                                                   target="_blank"
                                                   asp-action="OpenPdf"
                                                   asp-controller="Step3"
                                                   asp-route-runLogId="@item.NoticeRunLogId">
                                                View PDF
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="qa-pill qa-fail">No PDF</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="qa-card">
            <div class="qa-card-head">
                <strong>@(isClaTpa ? "Approve CLA QA" : isTpa ? "Approve TPA QA" : "Approve QA")</strong>
            </div>

            <div style="padding:16px;">
                <form asp-action="ApproveQA" asp-controller="Step3" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="key" value="@key" />
                    <input type="hidden" name="qaRunId" value="@Model.QaRunId" />

                    <label style="font-size:.8rem;font-weight:700;">QA Comment</label>
                    <textarea class="qa-comment" name="comment"
                              placeholder="Optional QA comment..."></textarea>

                    <div style="margin-top:12px;">
                        @if (Model.CanApprove)
                        {
                            <button type="submit" class="qa-btn qa-btn-green">
                                @(isClaTpa ? "Approve CLA QA" : isTpa ? "Approve TPA QA" : "Approve QA")
                            </button>
                        }
                        else if (Model.IsApproved)
                        {
                            <button type="button" class="qa-btn qa-btn-disabled" disabled>
                                QA Already Approved
                            </button>
                        }
                        else
                        {
                            <button type="button" class="qa-btn qa-btn-disabled" disabled>
                                @(isDirectThirdParty
                                    ? "Cannot Approve Until Missing Files and Required Data Are Fixed"
                                    : "Cannot Approve Until Failed Items Are Fixed")
                            </button>
                        }
                    </div>
                </form>
            </div>
        </div>
    }
</div>