@model GV23_Notice.Models.Workflow.ViewModels.NoticeSendStatsVm
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Notice Send Statistics";

    var key = Model.WorkflowKey;

    bool isClaTpa = Model.Notice == NoticeKind.CLA_TPA;
    bool isTpa = Model.Notice == NoticeKind.TPA;
    bool isThirdPartyStats = isTpa || isClaTpa;

    var tpa = Model.TpaStats;

    string thirdPartyLabel = isClaTpa
        ? "CLA Third-Party Application"
        : "Third-Party Appeal";

    string thirdPartyCode = isClaTpa
        ? "CLA"
        : "TPA";
}

<link href="~/css/Step3/Step3KickOffCss1.css"
      rel="stylesheet" />

<style>
    .st-wrap {
        padding: 24px;
        font-family: 'Poppins', sans-serif;
        background: #f4f4f4;
        min-height: calc(100vh - 70px);
    }

    .st-head {
        background: #111;
        color: #fff;
        border-bottom: 4px solid #2ebd6c;
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 18px;
    }

    .st-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .st-sub {
        margin-top: 6px;
        color: #ccc;
        font-size: .76rem;
        line-height: 1.6;
    }

    .st-meta {
        margin-top: 8px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: .75rem;
        color: #ddd;
    }

        .st-meta b {
            color: #2ebd6c;
        }

    .st-alert {
        padding: 12px 14px;
        border-radius: 10px;
        margin-bottom: 14px;
        font-size: .8rem;
        font-weight: 700;
        line-height: 1.5;
    }

    .st-alert-ok {
        background: #e8f8ef;
        color: #1a6a3a;
        border: 1px solid #b2dfcc;
    }

    .st-alert-err {
        background: #fff0f0;
        color: #8a1a1a;
        border: 1px solid #f0b0b0;
    }

    .st-alert-info {
        background: #e8f0fe;
        color: #1a56c4;
        border: 1px solid #b3c8f8;
    }

    .st-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(120px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .st-card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .st-num {
        font-size: 1.8rem;
        font-weight: 900;
        color: #111;
        line-height: 1;
    }

        .st-num.green {
            color: #1a8a4a;
        }

        .st-num.red {
            color: #c0392b;
        }

        .st-num.gold {
            color: #d4a500;
        }

    .st-label {
        margin-top: 6px;
        color: #777;
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .st-panel {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        margin-bottom: 18px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .st-panel-head {
        background: #111;
        color: #fff;
        border-bottom: 3px solid #2ebd6c;
        padding: 12px 16px;
        font-size: .8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .st-panel-body {
        padding: 16px;
    }

    .st-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .st-btn {
        border: none;
        border-radius: 10px;
        padding: 10px 15px;
        text-decoration: none;
        font-size: .78rem;
        font-weight: 900;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .st-btn-dark {
        background: #111;
        color: #fff;
    }

    .st-btn-green {
        background: #1a8a4a;
        color: #fff;
    }

    .st-btn-gold {
        background: #e6b000;
        color: #111;
    }

    .st-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 10px;
        align-items: end;
    }

    .st-field label {
        display: block;
        font-size: .65rem;
        font-weight: 800;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
    }

    .st-input {
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 9px;
        padding: 10px;
        font-size: .8rem;
        box-sizing: border-box;
    }

    .st-table-wrap {
        overflow-x: auto;
    }

    .st-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .76rem;
        min-width: 900px;
    }

        .st-table th {
            background: #f7f7f7;
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid #ddd;
            font-size: .65rem;
            color: #777;
            text-transform: uppercase;
            letter-spacing: .06em;
            white-space: nowrap;
        }

        .st-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            vertical-align: top;
        }

    .st-help {
        margin-top: 5px;
        font-size: .66rem;
        color: #888;
        line-height: 1.4;
    }

    .st-quick-add {
        margin-top: 14px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .st-quick-title {
        font-size: .66rem;
        font-weight: 900;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-right: 4px;
    }

    .st-mini-btn {
        border: 1px solid #d8d8d8;
        background: #f7f7f7;
        color: #333;
        border-radius: 999px;
        padding: 7px 11px;
        font-size: .68rem;
        font-weight: 800;
        cursor: pointer;
    }

        .st-mini-btn:hover {
            background: #e8f8ef;
            border-color: #2ebd6c;
            color: #1a8a4a;
        }

    .st-tpa-card {
        display: grid;
        grid-template-columns: 64px 1fr auto;
        gap: 18px;
        align-items: center;
        padding: 22px;
    }

    .st-tpa-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: linear-gradient(135deg,#1a8a4a,#2ebd6c);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .st-tpa-title {
        font-size: 1rem;
        font-weight: 900;
        color: #111;
        margin-bottom: 5px;
    }

    .st-tpa-text {
        font-size: .76rem;
        line-height: 1.7;
        color: #666;
    }

    @@media(max-width: 1000px) {
        .st-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .st-form-grid {
            grid-template-columns: 1fr;
        }

        .st-tpa-card {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="st-wrap">

    <div class="st-head">

        <h1 class="st-title">
            @(isClaTpa
                ? "CLA Third-Party Application Statistics"
                : isTpa
                    ? "Third-Party Appeal Notice Statistics"
                    : "Notice Send Statistics")
        </h1>

        <div class="st-sub">

            @if (isThirdPartyStats)
            {
                <text>
                    @thirdPartyLabel statistics are managed per Admin.
                    Each Admin receives a dedicated workbook containing a Summary Report and Detail sheet.
                </text>
            }
            else
            {
                <text>
                    Review notice sending totals, download the general statistics workbook,
                    and send the report to configured stakeholders.
                </text>
            }
        </div>

        <div class="st-meta">
            <span>
                Roll:
                <b>@Model.RollShortCode — @Model.RollName</b>
            </span>

            <span>
                Notice:
                <b>@(isClaTpa ? "CLA-THIRD PARTY APPLICATION NOTICE" : Model.Notice.ToString())</b>
            </span>

            <span>
                Version:
                <b>@Model.VersionText</b>
            </span>

            <span>
                Last Sent:
                <b>
                    @(Model.LastSentAtUtc
                        ?.ToLocalTime()
                        .ToString("dd MMM yyyy HH:mm")
                        ?? "—")
                </b>
            </span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="st-alert st-alert-ok">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="st-alert st-alert-err">
            @TempData["Error"]
        </div>
    }

    <div class="st-actions">
        <a class="st-btn st-btn-dark"
               asp-action="SendEmail"
               asp-controller="Step3"
               asp-route-key="@key">
            Back to Send Notices
        </a>

        @if (isThirdPartyStats && tpa != null)
        {
            <form asp-controller="Step3"
                  asp-action="SendAllTpaAdminReports"
                  method="post"
                  onsubmit="return confirmThirdPartyAdminReports(this);"
                  style="margin:0;">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="key"
                       value="@key" />

                <button type="submit"
                        class="st-btn st-btn-green"
                        disabled="@(
                                            tpa.Admins.Any(x => x.HasAdminEmail)
                                                ? null
                                                : "disabled")">
                    Send All @thirdPartyCode Admin Reports
                </button>
            </form>
        }
        else if (!isThirdPartyStats)
        {
            <a class="st-btn st-btn-gold"
                   asp-action="DownloadStatsExcel"
                   asp-controller="Step3"
                   asp-route-key="@key">
                Download Excel Stats
            </a>
        }
    </div>
    @if (isThirdPartyStats && tpa != null)
    {
        <div class="st-alert st-alert-info">
            @thirdPartyCode reports are grouped by the responsible Admin.
            Each eligible Admin will receive a separate Excel workbook containing
            the Summary Report and Detail sheets.
            Admins with missing email addresses will be blocked and skipped.
        </div>

        @if (isClaTpa)
        {
            <div class="st-alert st-alert-info">
                CLA uses the same Admin report layout as TPA.
                The shared Appeal Number column contains the CLA Number for CLA records.
                VAB board-member sections remain empty where CLA records do not contain board scheduling information.
            </div>
        }

        <div class="st-grid">
            <div class="st-card">
                <div class="st-num">@tpa.TotalAdmins.ToString("N0")</div>
                <div class="st-label">Admins</div>
            </div>
            <div class="st-card">
                <div class="st-num">@tpa.TotalRecords.ToString("N0")</div>
                <div class="st-label">Total Records</div>
            </div>
            <div class="st-card">
                <div class="st-num gold">@tpa.TotalPrinted.ToString("N0")</div>
                <div class="st-label">Awaiting Send</div>
            </div>
            <div class="st-card">
                <div class="st-num green">@tpa.TotalSent.ToString("N0")</div>
                <div class="st-label">Notice Sent</div>
            </div>
            <div class="st-card">
                <div class="st-num red">@tpa.TotalFailed.ToString("N0")</div>
                <div class="st-label">Failed</div>
            </div>
            <div class="st-card">
                <div class="st-num gold">@tpa.TotalNoEmail.ToString("N0")</div>
                <div class="st-label">No Owner Email</div>
            </div>
        </div>

        @if (tpa.TotalMissingAdminEmail > 0)
        {
            <div class="st-alert st-alert-err">
                <strong>Action required:</strong>
                @tpa.TotalMissingAdminEmail Admin group(s) have no Admin email address.
                These reports will not be sent.
            </div>
        }

        <div class="st-panel">
            <div class="st-panel-head">@thirdPartyCode Statistics by Admin</div>
            <div class="st-panel-body">
                <div class="st-table-wrap">
                    <table class="st-table">
                        <thead>
                            <tr>
                                <th>Admin</th>
                                <th>Admin Email</th>
                                <th>Total</th>
                                <th>Awaiting Send</th>
                                <th>Notice Sent</th>
                                <th>Failed</th>
                                <th>No Owner Email</th>
                                <th>Status</th>
                                <th>Excel</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!tpa.Admins.Any())
                            {
                                <tr><td colspan="9">No @thirdPartyCode Admin statistics were found.</td></tr>
                            }
                            else
                            {
                                @foreach (var admin in tpa.Admins)
                                {
                                    <tr>
                                        <td>
                                            <strong>@admin.AdminName</strong>
                                            <div class="st-help">
                                                Last notice sent:
                                                @(admin.LastSentAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")
                                            </div>
                                        </td>
                                        <td>
                                            @if (admin.HasAdminEmail)
                                            {
                                                <span style="color:#1a8a4a;font-weight:800;">Ready</span>
                                                <div class="st-help">@admin.AdminEmail</div>
                                            }
                                            else
                                            {
                                                <span style="color:#c0392b;font-weight:800;">Missing Admin Email</span>
                                            }
                                        </td>
                                        <td>@admin.TotalRecords.ToString("N0")</td>
                                        <td>@admin.TotalPrinted.ToString("N0")</td>
                                        <td>@admin.TotalSent.ToString("N0")</td>
                                        <td>@admin.TotalFailed.ToString("N0")</td>
                                        <td>@admin.TotalNoEmail.ToString("N0")</td>
                                        <td>
                                            @if (!admin.HasAdminEmail)
                                            {
                                                <span style="color:#c0392b;font-weight:800;">Blocked</span>
                                            }
                                            else if (admin.TotalRecords == 0)
                                            {
                                                <span style="color:#d4a500;font-weight:800;">No Records</span>
                                            }
                                            else
                                            {
                                                <span style="color:#1a8a4a;font-weight:800;">Ready</span>
                                            }
                                        </td>
                                        <td>
                                            <a class="st-btn st-btn-gold"
                                                   asp-controller="Step3"
                                                   asp-action="DownloadTpaAdminExcel"
                                                   asp-route-key="@key"
                                                   asp-route-adminKey="@admin.AdminKey">
                                                Download
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (!isThirdPartyStats)
    {
        <div class="st-grid">
            <div class="st-card"><div class="st-num">@Model.TotalBatches.ToString("N0")</div><div class="st-label">Batches</div></div>
            <div class="st-card"><div class="st-num">@Model.TotalRecords.ToString("N0")</div><div class="st-label">Total Records</div></div>
            <div class="st-card"><div class="st-num gold">@Model.TotalPrinted.ToString("N0")</div><div class="st-label">Still Printed</div></div>
            <div class="st-card"><div class="st-num green">@Model.TotalSent.ToString("N0")</div><div class="st-label">Sent</div></div>
            <div class="st-card"><div class="st-num red">@Model.TotalFailed.ToString("N0")</div><div class="st-label">Failed</div></div>
            <div class="st-card"><div class="st-num gold">@Model.TotalNoEmail.ToString("N0")</div><div class="st-label">No Email</div></div>
        </div>

        <div class="st-panel">
            <div class="st-panel-head">Send Stats to Stakeholders</div>
            <div class="st-panel-body">
                <form asp-action="SendStatsEmail" asp-controller="Step3" method="post" id="statsEmailForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="key" value="@key" />
                    <div style="font-size:.76rem;color:#666;line-height:1.6;margin-bottom:14px;">
                        Default stakeholders are loaded from <strong>appsettings.json</strong>.
                        You can add more emails before sending. Use a comma or semicolon between emails.
                    </div>
                    <div class="st-form-grid">
                        <div class="st-field">
                            <label>To Emails</label>
                            <input class="st-input" id="toEmails" name="toEmails" value="@Model.DefaultToEmails" placeholder="senior@joburg.org.za; manager@joburg.org.za" required />
                            <div class="st-help">Main recipients. Separate additional addresses using <strong>;</strong> or <strong>,</strong>.</div>
                        </div>
                        <div class="st-field">
                            <label>CC Emails</label>
                            <input class="st-input" id="ccEmails" name="ccEmails" value="@Model.DefaultCcEmails" placeholder="Optional CC emails" />
                            <div class="st-help">Optional copied recipients.</div>
                        </div>
                        <button class="st-btn st-btn-green" type="submit">Send Stats Email</button>
                    </div>
                    <div class="st-quick-add">
                        <div class="st-quick-title">Quick Add</div>
                        <button type="button" class="st-mini-btn" onclick="addEmail('toEmails','senior.developer@joburg.org.za')">+ Senior Developer</button>
                        <button type="button" class="st-mini-btn" onclick="addEmail('toEmails','manager@joburg.org.za')">+ Manager</button>
                        <button type="button" class="st-mini-btn" onclick="addEmail('ccEmails','developer@joburg.org.za')">+ Developer CC</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="st-panel">
            <div class="st-panel-head">Batch Summary</div>
            <div class="st-panel-body">
                <div class="st-table-wrap">
                    <table class="st-table">
                        <thead><tr><th>Batch Name</th><th>Batch Date</th><th>Total</th><th>Printed</th><th>Sent</th><th>Failed</th><th>No Email</th></tr></thead>
                        <tbody>
                            @if (!Model.Batches.Any())
                            {
                                <tr><td colspan="7">No batch statistics were found.</td></tr>
                            }
                            else
                            {
                                @foreach (var b in Model.Batches)
                                {
                                    <tr>
                                        <td>@b.BatchName</td>
                                        <td>@b.BatchDate.ToString("dd MMM yyyy")</td>
                                        <td>@b.TotalRecords.ToString("N0")</td>
                                        <td>@b.Printed.ToString("N0")</td>
                                        <td>@b.Sent.ToString("N0")</td>
                                        <td>@b.Failed.ToString("N0")</td>
                                        <td>@b.NoEmail.ToString("N0")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="st-panel">
            <div class="st-panel-head">Notice Details</div>
            <div class="st-panel-body">
                <div class="st-table-wrap">
                    <table class="st-table">
                        <thead><tr><th>Batch</th><th>Reference</th><th>Premise ID</th><th>Property</th><th>Recipient</th><th>Email</th><th>Status</th><th>Error</th></tr></thead>
                        <tbody>
                            @if (!Model.Rows.Any())
                            {
                                <tr><td colspan="8">No notice records were found.</td></tr>
                            }
                            else
                            {
                                @foreach (var x in Model.Rows.Take(200))
                                {
                                    var reference = !string.IsNullOrWhiteSpace(x.ObjectionNo) ? x.ObjectionNo : x.AppealNo;
                                    <tr>
                                        <td>@x.BatchName</td>
                                        <td>@reference</td>
                                        <td>@x.PremiseId</td>
                                        <td>@x.PropertyDesc</td>
                                        <td>@x.RecipientName</td>
                                        <td>@x.RecipientEmail</td>
                                        <td>@x.Status</td>
                                        <td>@x.ErrorMessage</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.Rows.Count > 200)
                {
                    <div style="margin-top:10px;font-size:.75rem;color:#777;">Showing the first 200 records only. Download Excel for the full list.</div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="st-alert st-alert-err">
            @thirdPartyCode statistics could not be loaded. Confirm that the controller populated Model.TpaStats for this workflow.
        </div>
    }

</div>

@section Scripts {
    <script>
        function addEmail(inputId, email) {
            const input = document.getElementById(inputId);

            if (!input || !email) {
                return;
            }

            const current = input.value.trim();

            const existing = current
                .split(/[;,]/)
                .map(x => x.trim().toLowerCase())
                .filter(Boolean);

            if (existing.includes(email.toLowerCase())) {
                return;
            }

            input.value = current.length === 0
                ? email
                : current + '; ' + email;
        }

        function confirmThirdPartyAdminReports(form) {
            const eligible =
                @(tpa?.Admins.Count(x => x.HasAdminEmail) ?? 0);

            const blocked =
                @(tpa?.Admins.Count(x => !x.HasAdminEmail) ?? 0);

            const reportCode = '@thirdPartyCode';

            const message =
                'Send separate ' +
                reportCode +
                ' reports to ' +
                eligible +
                ' Admin(s)?\n\n' +
                blocked +
                ' Admin report(s) with missing email addresses will be skipped.';

            if (!window.confirm(message)) {
                return false;
            }

            const button =
                form.querySelector(
                    'button[type="submit"]');

            if (button) {
                button.disabled = true;
                button.textContent =
                    'Sending Admin Reports...';
            }

            return true;
        }
    </script>
}
