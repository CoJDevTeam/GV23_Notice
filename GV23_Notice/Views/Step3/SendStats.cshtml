@model GV23_Notice.Models.Workflow.ViewModels.NoticeSendStatsVm

@{
    ViewData["Title"] = "Notice Send Statistics";
    var key = Model.WorkflowKey;
}

<link href="~/css/Step3/Step3KickOffCss1.css" rel="stylesheet" />

<style>
    .st-wrap {
        padding: 24px;
        font-family: 'Poppins', sans-serif;
        background: #f4f4f4;
        min-height: calc(100vh - 70px);
    }

    .st-head {
        background: #111;
        color: #fff;
        border-bottom: 4px solid #2ebd6c;
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 18px;
    }

    .st-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .st-meta {
        margin-top: 8px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: .75rem;
        color: #ddd;
    }

        .st-meta b {
            color: #2ebd6c;
        }

    .st-alert {
        padding: 12px 14px;
        border-radius: 10px;
        margin-bottom: 14px;
        font-size: .8rem;
        font-weight: 700;
    }

    .st-alert-ok {
        background: #e8f8ef;
        color: #1a6a3a;
        border: 1px solid #b2dfcc;
    }

    .st-alert-err {
        background: #fff0f0;
        color: #8a1a1a;
        border: 1px solid #f0b0b0;
    }

    .st-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(120px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .st-card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .st-num {
        font-size: 1.8rem;
        font-weight: 900;
        color: #111;
        line-height: 1;
    }

        .st-num.green {
            color: #1a8a4a;
        }

        .st-num.red {
            color: #c0392b;
        }

        .st-num.gold {
            color: #d4a500;
        }

    .st-label {
        margin-top: 6px;
        color: #777;
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .st-panel {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        margin-bottom: 18px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .st-panel-head {
        background: #111;
        color: #fff;
        border-bottom: 3px solid #2ebd6c;
        padding: 12px 16px;
        font-size: .8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .st-panel-body {
        padding: 16px;
    }

    .st-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .st-btn {
        border: none;
        border-radius: 10px;
        padding: 10px 15px;
        text-decoration: none;
        font-size: .78rem;
        font-weight: 900;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .st-btn-dark {
        background: #111;
        color: #fff;
    }

    .st-btn-green {
        background: #1a8a4a;
        color: #fff;
    }

    .st-btn-gold {
        background: #e6b000;
        color: #111;
    }

    .st-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 10px;
        align-items: end;
    }

    .st-field label {
        display: block;
        font-size: .65rem;
        font-weight: 800;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
    }

    .st-input {
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 9px;
        padding: 10px;
        font-size: .8rem;
    }

    .st-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .76rem;
    }

        .st-table th {
            background: #f7f7f7;
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid #ddd;
            font-size: .65rem;
            color: #777;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .st-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }

    @@media(max-width: 1000px) {
        .st-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .st-form-grid {
            grid-template-columns: 1fr;
        }
    }

    .st-help {
        margin-top: 5px;
        font-size: .66rem;
        color: #888;
        line-height: 1.4;
    }

    .st-quick-add {
        margin-top: 14px;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
    }

    .st-quick-title {
        font-size: .66rem;
        font-weight: 900;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-right: 4px;
    }

    .st-mini-btn {
        border: 1px solid #d8d8d8;
        background: #f7f7f7;
        color: #333;
        border-radius: 999px;
        padding: 7px 11px;
        font-size: .68rem;
        font-weight: 800;
        cursor: pointer;
    }

        .st-mini-btn:hover {
            background: #e8f8ef;
            border-color: #2ebd6c;
            color: #1a8a4a;
        }
</style>

<div class="st-wrap">

    <div class="st-head">
        <h1 class="st-title">Notice Send Statistics</h1>
        <div class="st-meta">
            <span>Roll: <b>@Model.RollShortCode — @Model.RollName</b></span>
            <span>Notice: <b>@Model.Notice</b></span>
            <span>Version: <b>@Model.VersionText</b></span>
            <span>Last Sent: <b>@(Model.LastSentAtUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")</b></span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="st-alert st-alert-ok">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="st-alert st-alert-err">@TempData["Error"]</div>
    }

    <div class="st-actions">
        <a class="st-btn st-btn-dark"
               asp-action="SendEmail"
               asp-controller="Step3"
               asp-route-key="@key">
            Back to Send Notices
        </a>

        <a class="st-btn st-btn-gold"
               asp-action="DownloadStatsExcel"
               asp-controller="Step3"
               asp-route-key="@key">
            Download Excel Stats
        </a>
    </div>

    <div class="st-grid">
        <div class="st-card">
            <div class="st-num">@Model.TotalBatches</div>
            <div class="st-label">Batches</div>
        </div>

        <div class="st-card">
            <div class="st-num">@Model.TotalRecords</div>
            <div class="st-label">Total Records</div>
        </div>

        <div class="st-card">
            <div class="st-num gold">@Model.TotalPrinted</div>
            <div class="st-label">Still Printed</div>
        </div>

        <div class="st-card">
            <div class="st-num green">@Model.TotalSent</div>
            <div class="st-label">Sent</div>
        </div>

        <div class="st-card">
            <div class="st-num red">@Model.TotalFailed</div>
            <div class="st-label">Failed</div>
        </div>

        <div class="st-card">
            <div class="st-num gold">@Model.TotalNoEmail</div>
            <div class="st-label">No Email</div>
        </div>
    </div>

    <div class="st-panel">
        <div class="st-panel-head">Send Stats to Stakeholders</div>
        <div class="st-panel-body">
            <form asp-action="SendStatsEmail" asp-controller="Step3" method="post" id="statsEmailForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="key" value="@key" />

                <div style="font-size:.76rem;color:#666;line-height:1.6;margin-bottom:14px;">
                    Default stakeholders are loaded from <strong>appsettings.json</strong>.
                    You can add more emails before sending. Use comma or semicolon between emails.
                </div>

                <div class="st-form-grid">
                    <div class="st-field">
                        <label>To Emails</label>
                        <input class="st-input"
                               id="toEmails"
                               name="toEmails"
                               value="@Model.DefaultToEmails"
                               placeholder="senior@joburg.org.za; manager@joburg.org.za"
                               required />
                        <div class="st-help">
                            Main recipients. You can add more emails using <strong>;</strong> or <strong>,</strong>.
                        </div>
                    </div>

                    <div class="st-field">
                        <label>CC Emails</label>
                        <input class="st-input"
                               id="ccEmails"
                               name="ccEmails"
                               value="@Model.DefaultCcEmails"
                               placeholder="optional cc emails" />
                        <div class="st-help">
                            Optional copied recipients.
                        </div>
                    </div>

                    <button class="st-btn st-btn-green" type="submit">
                        Send Stats Email
                    </button>
                </div>

                <div class="st-quick-add">
                    <div class="st-quick-title">Quick Add</div>

                    <button type="button"
                            class="st-mini-btn"
                            onclick="addEmail('toEmails','senior.developer@joburg.org.za')">
                        + Senior Developer
                    </button>

                    <button type="button"
                            class="st-mini-btn"
                            onclick="addEmail('toEmails','manager@joburg.org.za')">
                        + Manager
                    </button>

                    <button type="button"
                            class="st-mini-btn"
                            onclick="addEmail('ccEmails','developer@joburg.org.za')">
                        + Developer CC
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="st-panel">
        <div class="st-panel-head">Batch Summary</div>
        <div class="st-panel-body">
            <table class="st-table">
                <thead>
                    <tr>
                        <th>Batch Name</th>
                        <th>Batch Date</th>
                        <th>Total</th>
                        <th>Printed</th>
                        <th>Sent</th>
                        <th>Failed</th>
                        <th>No Email</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model.Batches)
                    {
                        <tr>
                            <td>@b.BatchName</td>
                            <td>@b.BatchDate.ToString("dd MMM yyyy")</td>
                            <td>@b.TotalRecords</td>
                            <td>@b.Printed</td>
                            <td>@b.Sent</td>
                            <td>@b.Failed</td>
                            <td>@b.NoEmail</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="st-panel">
        <div class="st-panel-head">Notice Details</div>
        <div class="st-panel-body">
            <table class="st-table">
                <thead>
                    <tr>
                        <th>Batch</th>
                        <th>Reference</th>
                        <th>Premise ID</th>
                        <th>Property</th>
                        <th>Recipient</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var x in Model.Rows.Take(200))
                    {
                        var reference = !string.IsNullOrWhiteSpace(x.ObjectionNo)
                            ? x.ObjectionNo
                            : x.AppealNo;

                        <tr>
                            <td>@x.BatchName</td>
                            <td>@reference</td>
                            <td>@x.PremiseId</td>
                            <td>@x.PropertyDesc</td>
                            <td>@x.RecipientName</td>
                            <td>@x.RecipientEmail</td>
                            <td>@x.Status</td>
                            <td>@x.ErrorMessage</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.Rows.Count > 200)
            {
                <div style="margin-top:10px;font-size:.75rem;color:#777;">
                    Showing first 200 records only. Download Excel for the full list.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addEmail(inputId, email) {
            const input = document.getElementById(inputId);

            if (!input || !email) return;

            const current = input.value.trim();

            const existing = current
                .split(/[;,]/)
                .map(x => x.trim().toLowerCase())
                .filter(Boolean);

            if (existing.includes(email.toLowerCase())) {
                return;
            }

            if (current.length === 0) {
                input.value = email;
            } else {
                input.value = current + '; ' + email;
            }
        }
    </script>
}