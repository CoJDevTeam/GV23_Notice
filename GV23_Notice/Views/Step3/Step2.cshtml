        <div class="sp-meta-chip"><span class="sp-meta-lbl">Batches</span><span class="sp-meta-val">@createdBatches created</span></div>
        <div class="sp-meta-chip"><span class="sp-meta-lbl">Progress</span><span class="sp-meta-val">@progressPct%</span></div>
    </div>

    <!-- STEP BANNER -->
    <div class="sp-step-banner">
        <div class="sp-step-trail">
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Configure</div>
            <div class="sp-bc-arrow">›</div>
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Approve</div>
            <div class="sp-bc-arrow">›</div>
            <div class="sp-bc done"><div class="sp-bc-dot">✓</div>Kickoff</div>
            <div class="sp-bc-arrow">›</div>
            <div class="sp-bc active"><div class="sp-bc-dot">4</div>Print</div>
        </div>
        <div class="sp-step-label">Batch Summary &amp; Print &nbsp;·&nbsp; <span>Step 3 / Step 2</span></div>
    </div>

    <!-- BODY -->
    <div class="sp-body">

        <!-- ── LEFT: SUMMARY SIDEBAR ───────────────────────── -->
        <div class="sp-left">

            @if (TempData["Success"] != null)
            {
                <div class="sp-alert sp-alert-ok">✅ @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="sp-alert sp-alert-err">⚠ @TempData["Error"]</div>
            }

            <!-- Stats row -->
            <div class="sp-stats-row">
                <div class="sp-stat">
                    <div class="sp-stat-num gold">@createdBatches</div>
                    <div class="sp-stat-lbl">Batches Created</div>
                </div>
                <div class="sp-stat">
                    <div class="sp-stat-num">@batchSize</div>
                    <div class="sp-stat-lbl">Records / Batch</div>
                </div>
                <div class="sp-stat">
                    <div class="sp-stat-num">@createdRecords.ToString("N0")</div>
                    <div class="sp-stat-lbl">Records Batched</div>
                </div>
                <div class="sp-stat">
                    <div class="sp-stat-num @(remaining == 0 ? "green" : "")">@remaining.ToString("N0")</div>
                    <div class="sp-stat-lbl">Remaining</div>
                </div>
            </div>

            <!-- Progress -->
            <div class="sp-progress-wrap">
                <div class="sp-progress-label">
                    <span>Batch Progress</span>
                    <span style="color:@(progressPct == 100 ? "#1a8a4a" : "#E6B000");font-weight:800;">@progressPct%</span>
                </div>
                <div class="sp-progress-bar-wrap">
                    <div class="sp-progress-bar-fill"></div>
                </div>
                <div class="sp-progress-sub">
                    <span>@createdRecords.ToString("N0") of @totalPending.ToString("N0") records</span>
                    @if (remainingBatches > 0)
                    {
                        <span>~@remainingBatches batch@(remainingBatches == 1 ? "" : "es") left</span>
                    }
                    else if (allDone)
                    {
                        <span style="color:#1a8a4a;font-weight:700;">✓ Complete</span>
                    }
                </div>
            </div>

            <!-- Workflow Summary -->
            <div class="sp-card">
                <div class="sp-card-header"><span>📋</span><h4>Workflow Summary</h4></div>
                <div class="sp-card-body">
                    <div class="sp-grid-2">
                        <div class="sp-field">
                            <div class="sp-fl">Notice</div>
                            <div class="sp-fv">@Model.Notice</div>
                        </div>
                        <div class="sp-field">
                            <div class="sp-fl">Version</div>
                            <div class="sp-fv">@Model.VersionText</div>
                        </div>
                        <div class="sp-field" style="grid-column:span 2">
                            <div class="sp-fl">Letter Date</div>
                            <div class="sp-fv @(Model.LetterDate == null ? "empty" : "")">@(Model.LetterDate?.ToString("dd MMM yyyy") ?? "—")</div>
                        </div>
                        <div class="sp-field">
                            <div class="sp-fl">Objection Start</div>
                            <div class="sp-fv @(Model.ObjectionStartDate == null ? "empty" : "")">@(Model.ObjectionStartDate?.ToString("dd MMM yyyy") ?? "—")</div>
                        </div>
                        <div class="sp-field">
                            <div class="sp-fl">Objection End</div>
                            <div class="sp-fv @(Model.ObjectionEndDate == null ? "empty" : "")">@(Model.ObjectionEndDate?.ToString("dd MMM yyyy") ?? "—")</div>
                        </div>
                        @if (Model.ExtensionDate.HasValue)
                        {
                            <div class="sp-field">
                                <div class="sp-fl">Extension Date</div>
                                <div class="sp-fv">@Model.ExtensionDate.Value.ToString("dd MMM yyyy")</div>
                            </div>
                        }
                        <div class="sp-field" style="grid-column:span 2">
                            <div class="sp-fl">Financial Years</div>
                            <div class="sp-fv @(string.IsNullOrWhiteSpace(Model.FinancialYearsText) ? "empty" : "")">@(Model.FinancialYearsText ?? "—")</div>
                        </div>
                    </div>
                    <hr class="sp-divider" />
                    <div class="sp-field">
                        <div class="sp-fl">Signature</div>
                        <div class="sp-fv">
                            @if (!string.IsNullOrWhiteSpace(Model.SignaturePath))
                            {
                                <span class="sp-badge-ok">✓ Uploaded</span>
                            }
                            else
                            {
                                <span class="sp-badge-warn">⚠ Missing</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Completion banner -->
            @if (allDone)
            {
                <div class="sp-complete-banner">
                    <div class="sp-complete-icon">🎉</div>
                    <div>
                        <div class="sp-complete-title">All Records Batched</div>
                        <div class="sp-complete-sub">All @totalPending.ToString("N0") records have been assigned across @createdBatches batch@(createdBatches == 1 ? "" : "es"). You can now print each batch below.</div>
                    </div>
                </div>
            }

            <!-- Navigation: Go to Send Notices -->
            @if (createdBatches > 0)
            {
                <div style="padding:16px;">
                    <a href="@Url.Action("SendEmail", "Step3", new { key = Model.WorkflowKey })"
                       class="sp-goto-send-btn">
                        📧 Send Notices to Clients →
                    </a>
                </div>
            }

        </div><!-- /sp-left -->
        <!-- ── RIGHT: PRINT DASHBOARD ───────────────────────── -->
        <div class="sp-right">
            <div class="sp-right-header">
                <div class="sp-right-title">
                    <div class="sp-right-icon">🖨</div>
                    Batch Print Dashboard — @Model.Notice
                </div>
                <span class="sp-badge-info">@Model.Batches.Count batch@(Model.Batches.Count == 1 ? "" : "es")</span>
            </div>

            <div class="sp-right-body">
                @if (Model.Batches == null || Model.Batches.Count == 0)
                {
                    <div class="sp-empty">
                        <div class="sp-empty-icon">📦</div>
                        <div class="sp-empty-title">No Batches Created Yet</div>
                        <div class="sp-empty-sub">
                            Go back to the <strong>Step 3 Kickoff</strong> page and use the
                            <em>Start Batch</em> button to create batches. Once batches exist,
                            they will appear here ready to print.
                        </div>
                    </div>
                }
                else
                {
                    <table class="sp-batch-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Batch Code</th>
                                <th>Notice</th>
                                <th>Batch Date</th>
                                <th>Records</th>
                                <th>Created By</th>
                                <th>Created At</th>
                                <th>Status</th>
                                <th style="text-align:center;">Print</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowNum = 0;
                            }
                            @foreach (var b in Model.Batches)
                            {
                                rowNum++;
                                <tr>
                                    <td class="sp-bt-seq">@rowNum</td>
                                    <td>
                                        <span class="sp-bt-code">@b.BatchName</span>
                                        <div class="sp-bt-meta">ID: @b.BatchId</div>
                                    </td>
                                    <td><span class="sp-badge-info">@Model.Notice</span></td>
                                    <td class="sp-bt-date">@b.BatchDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span class="sp-bt-records">@b.NumberOfRecords.ToString("N0")</span>
                                    </td>
                                    <td class="sp-bt-date">@b.CreatedBy</td>
                                    <td class="sp-bt-date">@b.CreatedAtUtc.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        @if (b.IsApproved)
                                        {
                                            <span class="sp-badge-ok">✓ Approved</span>
                                        }
                                        else
                                        {
                                            <span class="sp-badge-warn">Pending</span>
                                        }
                                    </td>
                                    <td style="text-align:center;">
                                        <button type="button" class="btn-print"
                                                onclick="submitPrintBatch(@b.BatchId, '@b.BatchName', @b.NumberOfRecords, this)">
                                            🖨 Print Batch
                                        </button>
                                        <form id="printForm_@b.BatchId"
                                              action="/Step3/PrintBatch" method="post" style="display:none;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="batchId" value="@b.BatchId" />
                                            <input type="hidden" name="key" value="@Model.WorkflowKey" />
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div><!-- /sp-right -->

    </div><!-- /sp-body -->
</div><!-- /sp-fullscreen -->
<!-- ── PRINT PROGRESS OVERLAY ──────────────────────────────── -->
<div class="pp-overlay" id="ppOverlay">
    <div class="pp-modal">
        <div class="pp-header">
            <div class="pp-icon">🖨</div>
            <div>
                <div class="pp-title" id="ppTitle">Printing batch…</div>
                <div class="pp-sub" id="ppBatchName">Please wait</div>
            </div>
        </div>

        <div class="pp-bar-wrap">
            <div class="pp-bar-fill" id="ppBarFill"></div>
        </div>
        <div class="pp-pct-wrap">
            <div class="pp-pct"><span id="ppPct">0</span>%</div>
            <div class="pp-counts">
                <div>Total: <strong id="ppTotal">—</strong></div>
                <div>Printed: <strong id="ppPrinted">0</strong></div>
                <div>Remaining: <strong id="ppRemaining">—</strong></div>
            </div>
        </div>

        <div class="pp-chips">
            <div class="pp-chip">
                <div class="pp-chip-num gold" id="ppChipGen">—</div>
                <div class="pp-chip-lbl">Pending</div>
            </div>
            <div class="pp-chip">
                <div class="pp-chip-num green" id="ppChipDone">0</div>
                <div class="pp-chip-lbl">Printed</div>
            </div>
            <div class="pp-chip">
                <div class="pp-chip-num red" id="ppChipFail">0</div>
                <div class="pp-chip-lbl">Failed</div>
            </div>
        </div>

        <div class="pp-path">
            📁 Saving to: <code id="ppPath">@($"[Root]\\{Model.RollShortCode}_{Model.Notice}\\Batches\\[BatchName]\\[Property]_{Model.Notice}.pdf")</code>
        </div>

        <div class="pp-working" id="ppWorking">
            <span class="pp-pulse">⏳ Printing in progress…</span>
        </div>

        <div class="pp-done-banner" id="ppDoneBanner">
            <div class="pp-done-icon">🎉</div>
            <div>
                <div class="pp-done-title" id="ppDoneTitle">Batch printed successfully</div>
                <div class="pp-done-sub" id="ppDoneSub">All notices saved to folder</div>
            </div>
        </div>

        <button class="pp-btn" id="ppCloseBtn" onclick="closePrintOverlay()">
            ✓ Done — Close &amp; Refresh
        </button>
    </div>
</div>

<script>
    let _pollTimer = null;

    function submitPrintBatch(batchId, batchName, totalRecords, btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="sp-spin"></span> Starting…';
        showOverlay(batchId, batchName, totalRecords);
        document.getElementById('printForm_' + batchId).submit();
    }

    function showOverlay(batchId, batchName, totalRecords) {
        // Reset state
        document.getElementById('ppOverlay').classList.add('active');
        document.getElementById('ppTitle').textContent      = 'Printing batch…';
        document.getElementById('ppBatchName').textContent  = batchName;
        document.getElementById('ppTotal').textContent      = totalRecords.toLocaleString();
        document.getElementById('ppRemaining').textContent  = totalRecords.toLocaleString();
        document.getElementById('ppChipGen').textContent    = totalRecords.toLocaleString();
        document.getElementById('ppChipDone').textContent   = '0';
        document.getElementById('ppChipFail').textContent   = '0';
        document.getElementById('ppPrinted').textContent    = '0';
        document.getElementById('ppPct').textContent        = '0';
        document.getElementById('ppBarFill').style.width    = '0%';
        document.getElementById('ppBarFill').classList.remove('done');
        document.getElementById('ppWorking').style.display  = '';
        document.getElementById('ppDoneBanner').classList.remove('active');
        document.getElementById('ppCloseBtn').classList.remove('active');
        document.getElementById('ppPath').textContent =
            `[Root]\\@(Model.RollShortCode)_@(Model.Notice)\\Batches\\${batchName}\\[Property]_@(Model.Notice).pdf`;

        // Start polling
        clearInterval(_pollTimer);
        _pollTimer = setInterval(() => pollProgress(batchId), 600);
    }

    function pollProgress(batchId) {
        fetch('/Step3/PrintProgress?batchId=' + batchId)
            .then(r => r.json())
            .then(d => {
                const total   = d.total   || 0;
                const printed = d.printed || 0;
                const failed  = d.failed  || 0;
                const gen     = d.generated || 0;
                const pct     = total > 0 ? Math.round((printed + failed) * 100 / total) : 0;

                document.getElementById('ppPct').textContent      = pct;
                document.getElementById('ppTotal').textContent    = total.toLocaleString();
                document.getElementById('ppPrinted').textContent  = printed.toLocaleString();
                document.getElementById('ppRemaining').textContent = gen.toLocaleString();
                document.getElementById('ppChipGen').textContent  = gen.toLocaleString();
                document.getElementById('ppChipDone').textContent = printed.toLocaleString();
                document.getElementById('ppChipFail').textContent = failed.toLocaleString();

                const bar = document.getElementById('ppBarFill');
                bar.style.width = pct + '%';

                if (d.done) {
                    clearInterval(_pollTimer);
                    bar.classList.add('done');
                    document.getElementById('ppWorking').style.display = 'none';
                    document.getElementById('ppDoneBanner').classList.add('active');
                    document.getElementById('ppDoneTitle').textContent =
                        failed > 0
                            ? `Done — ${printed.toLocaleString()} printed, ${failed.toLocaleString()} failed`
                            : `${printed.toLocaleString()} notices printed successfully`;
                    document.getElementById('ppDoneSub').textContent =
                        `Saved to @(Model.RollShortCode)_@(Model.Notice)\\Batches`;
                    document.getElementById('ppTitle').textContent    = 'Print complete';
                    document.getElementById('ppCloseBtn').classList.add('active');
                }
            })
            .catch(() => { /* keep polling on transient network error */ });
    }

    function closePrintOverlay() {
        clearInterval(_pollTimer);
        document.getElementById('ppOverlay').classList.remove('active');
        window.location.reload();
    }
</script>
