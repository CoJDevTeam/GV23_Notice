@model GV23_Notice.Models.Workflow.ViewModels.Step3Step2Vm
@using System.Globalization
@using GV23_Notice.Domain.Workflow

@{
    ViewData["Title"] = "Step 3 — Batch Summary & Print";

    var batchSize = Model.BatchSize <= 0 ? 500 : Model.BatchSize;
    var totalPending = Math.Max(0, Model.TotalPendingRecords);
    var createdBatches = Math.Max(0, Model.BatchesCreatedCount);
    var createdRecords = Math.Max(0, Model.TotalRecordsInCreatedBatches);
    var remaining = Math.Max(0, totalPending - createdRecords);
    var remainingBatches = remaining == 0 ? 0 : (int)Math.Ceiling(remaining / (decimal)batchSize);
    var progressPct = totalPending == 0 ? 0 : (int)Math.Round((createdRecords * 100m) / totalPending);
    progressPct = Math.Clamp(progressPct, 0, 100);

    bool allDone = remaining == 0 && createdBatches > 0;
}

