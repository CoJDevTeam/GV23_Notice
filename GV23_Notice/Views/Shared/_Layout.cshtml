@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@inject IAuthorizationService AuthorizationService

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var canWorkflowAdmin = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminCreateApprove")).Succeeded;
    var canSearchLibrary = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminSearchDownload")).Succeeded;
    var canStep3 = (await AuthorizationService.AuthorizeAsync(User, "DataTeamCreateBatchPrint")).Succeeded;

    var fullName = User.FindFirst("FullName")?.Value
        ?? User.Identity?.Name
        ?? "User";

    var shortName = fullName.Contains("\\")
        ? fullName.Split('\\').Last()
        : fullName;

    var roleName = User.FindFirst(ClaimTypes.Role)?.Value ?? "";

    string IsActive(string targetController, string? targetAction = null)
    {
        var controllerMatch = string.Equals(controller, targetController, StringComparison.OrdinalIgnoreCase);
        var actionMatch = string.IsNullOrWhiteSpace(targetAction)
            || string.Equals(action, targetAction, StringComparison.OrdinalIgnoreCase);

        return controllerMatch && actionMatch ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VNS</title>
    <script type="importmap"></script>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GV23_Notice.styles.css" asp-append-version="true" />
    <link href="~/css/layoutcss.css" rel="stylesheet" />
</head>
<body>

    <!-- ═══════════════ NAV ═══════════════ -->
    <nav class="gv-navbar">
        <a class="gv-brand" asp-controller="Home" asp-action="Index">
            <span class="gv-brand-badge">VNS</span>
            <span class="gv-brand-title">Notice System</span>
        </a>

        <button class="gv-toggler"
                type="button"
                onclick="this.nextElementSibling.classList.toggle('open')"
                aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>

        <div class="gv-nav-wrap">
            <ul class="gv-nav">
                <li>
                    <a asp-controller="Home"
                       asp-action="Index"
                       class="@IsActive("Home", "Index")">
                        ⌂ Home
                    </a>
                </li>

                @if (canWorkflowAdmin)
                {
                    <li>
                        <a asp-controller="Workflow"
                           asp-action="Step1"
                           class="@IsActive("Workflow", "Step1")">
                            ⚙ Workflow
                        </a>
                    </li>
                }

                @if (canSearchLibrary)
                {
                    <li>
                        <a asp-controller="Workflow"
                           asp-action="SettingsLibrary"
                           class="@IsActive("Workflow", "SettingsLibrary")">
                            📚 Settings Library
                        </a>
                    </li>

                    <li>
                        <a asp-controller="NoticeSearch"
                           asp-action="Index"
                           class="@IsActive("NoticeSearch", "Index")">
                            🔎 Search
                        </a>
                    </li>
                }

                @if (canStep3)
                {
                    <li>
                        <a asp-controller="Step3"
                           asp-action="Index"
                           class="@IsActive("Step3", "Index")">
                            ▶ Step 3
                        </a>
                    </li>
                }

                <li class="nav-divider"></li>

                <li>
                    <a asp-controller="Home"
                       asp-action="Privacy"
                       class="@IsActive("Home", "Privacy")">
                        Privacy
                    </a>
                </li>
            </ul>

            <div class="gv-user" title="@fullName">
                <div class="gv-user-dot"></div>
                <div class="gv-user-meta">
                    <span>Hello, <strong>@shortName</strong></span>
                    @if (!string.IsNullOrWhiteSpace(roleName))
                    {
                        <small class="gv-user-role">@roleName</small>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══════════════ BODY ═══════════════ -->
    <main class="gv-content">
        @RenderBody()
    </main>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="gv-footer">
        <div class="gv-footer-left">
            <span class="gv-footer-badge">VNS</span>
            <span class="gv-footer-copy">&copy; 2026 <span>Valuation Notice System</span></span>
        </div>
        <div class="gv-footer-links">
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>