@model GV23_Notice.Models.Stats.NoticeStatsDashboardVm

@{
    ViewData["Title"] = "Notice Stats";
}

<style>
    .stats-wrap {
        padding: 24px;
        background: #f4f4f4;
        min-height: calc(100vh - 70px);
        font-family: 'Poppins', sans-serif;
    }

    .stats-head {
        background: #111;
        color: #fff;
        border-bottom: 4px solid #2ebd6c;
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 18px;
    }

    .stats-title {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .stats-sub {
        margin-top: 6px;
        color: #ccc;
        font-size: .78rem;
    }

    .stats-filter {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .stats-filter-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(160px, 1fr));
        gap: 12px;
    }

    .field label {
        display: block;
        font-size: .65rem;
        font-weight: 900;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
    }

    .input {
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 9px;
        padding: 9px 10px;
        font-size: .78rem;
    }

    .stats-actions {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        flex-wrap: wrap;
    }

    .btn-dark,
    .btn-green,
    .btn-light {
        border: none;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: .75rem;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-dark {
        background: #111;
        color: #fff;
    }

    .btn-green {
        background: #1a8a4a;
        color: #fff;
    }

    .btn-light {
        background: #eee;
        color: #111;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(7, minmax(110px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .num {
        font-size: 1.7rem;
        font-weight: 900;
        color: #111;
        line-height: 1;
    }

    .num.green {
        color: #1a8a4a;
    }

    .num.red {
        color: #c0392b;
    }

    .num.gold {
        color: #d4a500;
    }

    .label {
        margin-top: 6px;
        font-size: .65rem;
        color: #777;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: .06em;
    }

    .panel {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .panel-head {
        background: #111;
        color: #fff;
        border-bottom: 3px solid #2ebd6c;
        padding: 12px 16px;
        font-size: .8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        font-size: .75rem;
    }

    .table th {
        background: #f7f7f7;
        padding: 10px;
        text-align: left;
        border-bottom: 1px solid #ddd;
        color: #777;
        font-size: .65rem;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .table td {
        padding: 10px;
        border-bottom: 1px solid #eee;
        vertical-align: top;
    }

    .pill {
        display: inline-flex;
        border-radius: 999px;
        padding: 4px 8px;
        font-size: .65rem;
        font-weight: 900;
        background: #eee;
        color: #333;
    }

    .pill-green {
        background: #e8f8ef;
        color: #1a6a3a;
    }

    .pill-red {
        background: #fff0f0;
        color: #8a1a1a;
    }

    .pill-gold {
        background: #fff8d9;
        color: #8a6a00;
    }

    @@media(max-width: 1200px) {
        .stats-filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .stats-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="stats-wrap">

    <div class="stats-head">
        <h1 class="stats-title">Notice Stats</h1>
        <div class="stats-sub">
            View batches, sent notices, failed emails, no-email records and printed notices across all rolls.
        </div>
    </div>

    <form class="stats-filter" method="get" asp-controller="Stats" asp-action="Index">
        <div class="stats-filter-grid">
            <div class="field">
                <label>Roll</label>
                <select class="input" asp-for="Filter.RollId" asp-items="Model.RollOptions"></select>
            </div>

            <div class="field">
                <label>Notice</label>
                <select class="input" asp-for="Filter.Notice" asp-items="Model.NoticeOptions"></select>
            </div>

            <div class="field">
                <label>Status</label>
                <select class="input" asp-for="Filter.Status" asp-items="Model.StatusOptions"></select>
            </div>

            <div class="field">
                <label>Batch Name</label>
                <input class="input" asp-for="Filter.BatchName" placeholder="Batch name" />
            </div>

            <div class="field">
                <label>Reference No</label>
                <input class="input" asp-for="Filter.ReferenceNo" placeholder="Objection / Appeal / Premise" />
            </div>

            <div class="field">
                <label>Recipient Email</label>
                <input class="input" asp-for="Filter.RecipientEmail" placeholder="client@email.com" />
            </div>

            <div class="field">
                <label>Date From</label>
                <input class="input" asp-for="Filter.DateFrom" type="date" />
            </div>

            <div class="field">
                <label>Date To</label>
                <input class="input" asp-for="Filter.DateTo" type="date" />
            </div>
        </div>

        <div class="stats-actions">
            <button class="btn-green" type="submit">Apply Filters</button>
            <a class="btn-light" asp-controller="Stats" asp-action="Index">Clear</a>
        </div>
    </form>

    <div class="stats-cards">
        <div class="card">
            <div class="num">@Model.TotalBatches</div>
            <div class="label">Batches</div>
        </div>

        <div class="card">
            <div class="num">@Model.TotalRecords</div>
            <div class="label">Records</div>
        </div>

        <div class="card">
            <div class="num">@Model.TotalGenerated</div>
            <div class="label">Generated</div>
        </div>

        <div class="card">
            <div class="num gold">@Model.TotalPrinted</div>
            <div class="label">Printed</div>
        </div>

        <div class="card">
            <div class="num green">@Model.TotalSent</div>
            <div class="label">Sent</div>
        </div>

        <div class="card">
            <div class="num red">@Model.TotalFailed</div>
            <div class="label">Failed</div>
        </div>

        <div class="card">
            <div class="num gold">@Model.TotalNoEmail</div>
            <div class="label">No Email</div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-head">Batch Stats</div>

        <table class="table">
            <thead>
                <tr>
                    <th>Roll</th>
                    <th>Notice</th>
                    <th>Batch</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Printed</th>
                    <th>Sent</th>
                    <th>Failed</th>
                    <th>No Email</th>
                    <th>Last Sent</th>
                    <th>Sent By</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Batches.Any())
                {
                    <tr>
                        <td colspan="12">No stats found for the selected filters.</td>
                    </tr>
                }
                else
                {
                    foreach (var b in Model.Batches)
                    {
                        <tr>
                            <td>
                                <strong>@b.RollShortCode</strong><br />
                                <span style="color:#777;">@b.RollName</span>
                            </td>
                            <td>
                                <span class="pill">@b.Notice</span><br />
                                <span style="color:#777;">@b.VersionText</span>
                            </td>
                            <td>@b.BatchName</td>
                            <td>@b.BatchDate.ToString("dd MMM yyyy")</td>
                            <td>@b.TotalRecords</td>
                            <td><span class="pill pill-gold">@b.Printed</span></td>
                            <td><span class="pill pill-green">@b.Sent</span></td>
                            <td><span class="pill pill-red">@b.Failed</span></td>
                            <td><span class="pill pill-gold">@b.NoEmail</span></td>
                            <td>@(b.LastSentAtUtc?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                            <td>@(b.SentBy ?? "—")</td>
                            <td>
                                <a class="btn-dark"
                                       asp-controller="Stats"
                                       asp-action="Details"
                                       asp-route-batchId="@b.BatchId">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>