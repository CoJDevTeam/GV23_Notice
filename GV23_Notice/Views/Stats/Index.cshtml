@model GV23_Notice.Models.Stats.NoticeStatsDashboardVm

@{
    ViewData["Title"] = Model.IsTpa
        ? "Third-Party Appeal Notice Statistics"
        : "Notice Statistics";

    var tpa = Model.TpaStats;
}

<style>
    .stats-wrap {
        padding: 24px;
        background: #f4f4f4;
        min-height: calc(100vh - 70px);
        font-family: 'Poppins', sans-serif;
    }

    .stats-head {
        background: #111;
        color: #fff;
        border-bottom: 4px solid #2ebd6c;
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 18px;
    }

    .stats-title {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .stats-sub {
        margin-top: 6px;
        color: #ccc;
        font-size: .78rem;
        line-height: 1.6;
    }

    .stats-meta {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px 18px;
        color: #ddd;
        font-size: .72rem;
    }

        .stats-meta strong {
            color: #2ebd6c;
        }

    .stats-alert {
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 16px;
        font-size: .76rem;
        font-weight: 700;
        line-height: 1.6;
    }

    .stats-alert-error {
        background: #fff0f0;
        border: 1px solid #efb5b5;
        color: #8a1a1a;
    }

    .stats-alert-success {
        background: #e8f8ef;
        border: 1px solid #b2dfcc;
        color: #1a6a3a;
    }

    .stats-alert-info {
        background: #e8f0fe;
        border: 1px solid #b3c8f8;
        color: #1a56c4;
    }

    .stats-filter {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .stats-filter-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(160px, 1fr));
        gap: 12px;
    }

    .field label {
        display: block;
        font-size: .65rem;
        font-weight: 900;
        color: #777;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 5px;
    }

    .input {
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 9px;
        padding: 9px 10px;
        font-size: .78rem;
        background: #fff;
    }

    .stats-actions {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        flex-wrap: wrap;
    }

    .btn-dark,
    .btn-green,
    .btn-light,
    .btn-disabled {
        border: none;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: .75rem;
        font-weight: 900;
        text-decoration: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .btn-dark {
        background: #111;
        color: #fff;
    }

    .btn-green {
        background: #1a8a4a;
        color: #fff;
    }

    .btn-light {
        background: #eee;
        color: #111;
    }

    .btn-disabled {
        background: #e5e5e5;
        color: #999;
        cursor: not-allowed;
    }

    .admin-actions {
        display: flex;
        flex-direction: column;
        gap: 7px;
        min-width: 145px;
    }

        .admin-actions form {
            margin: 0;
        }

        .admin-actions .btn-green,
        .admin-actions .btn-dark,
        .admin-actions .btn-disabled {
            width: 100%;
            box-sizing: border-box;
        }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(7, minmax(110px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

        .stats-cards.tpa-cards {
            grid-template-columns: repeat(6, minmax(110px, 1fr));
        }

    .card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 14px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .num {
        font-size: 1.7rem;
        font-weight: 900;
        color: #111;
        line-height: 1;
    }

        .num.green {
            color: #1a8a4a;
        }

        .num.red {
            color: #c0392b;
        }

        .num.gold {
            color: #d4a500;
        }

    .label {
        margin-top: 6px;
        font-size: .65rem;
        color: #777;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: .06em;
    }

    .panel {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
        margin-bottom: 18px;
    }

    .panel-head {
        background: #111;
        color: #fff;
        border-bottom: 3px solid #2ebd6c;
        padding: 12px 16px;
        font-size: .8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .panel-head-count {
        color: #2ebd6c;
        font-size: .7rem;
        white-space: nowrap;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        font-size: .75rem;
    }

        .table.tpa-table {
            min-width: 1220px;
        }

        .table.normal-table {
            min-width: 1120px;
        }

        .table th {
            background: #f7f7f7;
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid #ddd;
            color: #777;
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            white-space: nowrap;
        }

        .table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            vertical-align: top;
        }

        .table tbody tr:hover {
            background: #f7fff9;
        }

    .pill {
        display: inline-flex;
        border-radius: 999px;
        padding: 4px 8px;
        font-size: .65rem;
        font-weight: 900;
        background: #eee;
        color: #333;
        white-space: nowrap;
    }

    .pill-green {
        background: #e8f8ef;
        color: #1a6a3a;
    }

    .pill-red {
        background: #fff0f0;
        color: #8a1a1a;
    }

    .pill-gold {
        background: #fff8d9;
        color: #8a6a00;
    }

    .pill-blue {
        background: #e8f0fe;
        color: #1a56c4;
    }

    .muted {
        color: #777;
        font-size: .68rem;
        line-height: 1.5;
    }

    .email-text {
        color: #555;
        font-size: .68rem;
        line-height: 1.5;
        word-break: break-word;
        max-width: 280px;
    }

    .empty-row {
        padding: 24px !important;
        color: #777;
        text-align: center;
    }

    @@media(max-width: 1200px) {
        .stats-filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .stats-cards,
        .stats-cards.tpa-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media(max-width: 650px) {
        .stats-wrap {
            padding: 14px;
        }

        .stats-filter-grid {
            grid-template-columns: 1fr;
        }

        .stats-cards,
        .stats-cards.tpa-cards {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="stats-wrap">

    <div class="stats-head">
        <h1 class="stats-title">
            @(Model.IsTpa
                ? "Third-Party Appeal Notice Statistics"
                : "Notice Statistics")
        </h1>

        <div class="stats-sub">
            @if (Model.IsTpa)
            {
                <text>
                    View Third-Party Appeal notice statistics grouped by the responsible Admin.
                    Admin and valuer recipient information is prepared for the report and email phases.
                </text>
            }
            else
            {
                <text>
                    View batches, sent notices, failed emails, no-email records and printed notices across all rolls.
                </text>
            }
        </div>

        @if (Model.IsTpa && tpa != null)
        {
            <div class="stats-meta">
                <span>
                    Roll:
                    <strong>@tpa.RollShortCode — @tpa.RollName</strong>
                </span>

                <span>
                    Period:
                    <strong>@tpa.ValuationPeriod</strong>
                </span>

                <span>
                    Version:
                    <strong>@tpa.VersionText</strong>
                </span>

                <span>
                    Last Notice Sent:
                    <strong>
                        @(tpa.LastSentAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "—")
                    </strong>
                </span>

                <span>
                    Sent By:
                    <strong>@(tpa.LastSentBy ?? "—")</strong>
                </span>
            </div>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="stats-alert stats-alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="stats-alert stats-alert-error">
            @TempData["Error"]
        </div>
    }

    @if (Model.IsTpa && tpa == null)
    {
        <div class="stats-alert stats-alert-error">
            TPA statistics could not be loaded. Confirm that the workflow key was supplied.
        </div>
    }

    @if (Model.IsTpa && tpa != null && tpa.TotalMissingAdminEmail > 0)
    {
        <div class="stats-alert stats-alert-error">
            <strong>Action required:</strong>
            @tpa.TotalMissingAdminEmail Admin group(s) have no Admin email address.
            These reports must remain blocked until the Admin email is corrected.
        </div>
    }

    @if (Model.IsTpa && tpa != null)
    {
        <div class="stats-alert stats-alert-info">
            <strong>TPA Admin reporting:</strong>
            Each Admin receives one workbook. The Admin email is used in To,
            while @tpa.ValuationEnquiriesEmail and the related valuer email address(es) are included in CC.
            The workbook and email copy are saved as evidence, and every send attempt is audited.
        </div>
    }

    <form class="stats-filter"
          method="get"
          asp-controller="Stats"
          asp-action="Index">

        @if (Model.WorkflowKey.HasValue)
        {
            <input type="hidden"
                   asp-for="Filter.WorkflowKey" />
        }

        <div class="stats-filter-grid">
            <div class="field">
                <label>Roll</label>
                <select class="input"
                        asp-for="Filter.RollId"
                        asp-items="Model.RollOptions">
                </select>
            </div>

            <div class="field">
                <label>Notice</label>
                <select class="input"
                        asp-for="Filter.Notice"
                        asp-items="Model.NoticeOptions">
                </select>
            </div>

            <div class="field">
                <label>Status</label>
                <select class="input"
                        asp-for="Filter.Status"
                        asp-items="Model.StatusOptions">
                </select>
            </div>

            @if (!Model.IsTpa)
            {
                <div class="field">
                    <label>Batch Name</label>
                    <input class="input"
                           asp-for="Filter.BatchName"
                           placeholder="Batch name" />
                </div>
            }

            <div class="field">
                <label>Reference No</label>
                <input class="input"
                       asp-for="Filter.ReferenceNo"
                       placeholder="Objection / Appeal / Premise" />
            </div>

            <div class="field">
                <label>
                    @(Model.IsTpa
                        ? "Admin / Valuer Email"
                        : "Recipient Email")
                </label>

                <input class="input"
                       asp-for="Filter.RecipientEmail"
                       placeholder="email@joburg.org.za" />
            </div>

            <div class="field">
                <label>Date From</label>
                <input class="input"
                       asp-for="Filter.DateFrom"
                       type="date" />
            </div>

            <div class="field">
                <label>Date To</label>
                <input class="input"
                       asp-for="Filter.DateTo"
                       type="date" />
            </div>
        </div>

        <div class="stats-actions">
            <button class="btn-green"
                    type="submit">
                Apply Filters
            </button>

            @if (Model.IsTpa && Model.WorkflowKey.HasValue)
            {
                <a class="btn-light"
                       asp-controller="Stats"
                       asp-action="Index"
                       asp-route-notice="TPA"
                       asp-route-workflowKey="@Model.WorkflowKey">
                    Clear
                </a>
            }
            else
            {
                <a class="btn-light"
                       asp-controller="Stats"
                       asp-action="Index">
                    Clear
                </a>
            }

            @if (Model.IsTpa && Model.WorkflowKey.HasValue)
            {
                <a class="btn-dark"
                       asp-controller="Step3"
                       asp-action="SendEmail"
                       asp-route-key="@Model.WorkflowKey">
                    Back to Send Notices
                </a>

                <button type="button"
                        class="btn-disabled"
                        disabled>
                    Send All Admin Reports — Phase 3
                </button>
            }
        </div>
    </form>

    <div class="stats-cards @(Model.IsTpa ? "tpa-cards" : "")">

        <div class="card">
            <div class="num">
                @Model.TotalBatches.ToString("N0")
            </div>

            <div class="label">
                @(Model.IsTpa ? "Admins" : "Batches")
            </div>
        </div>

        <div class="card">
            <div class="num">
                @Model.TotalRecords.ToString("N0")
            </div>

            <div class="label">
                @(Model.IsTpa ? "TPA Records" : "Records")
            </div>
        </div>

        @if (!Model.IsTpa)
        {
            <div class="card">
                <div class="num">
                    @Model.TotalGenerated.ToString("N0")
                </div>

                <div class="label">
                    Generated
                </div>
            </div>
        }

        <div class="card">
            <div class="num gold">
                @Model.TotalPrinted.ToString("N0")
            </div>

            <div class="label">
                @(Model.IsTpa
                    ? "Awaiting Send"
                    : "Printed")
            </div>
        </div>

        <div class="card">
            <div class="num green">
                @Model.TotalSent.ToString("N0")
            </div>

            <div class="label">
                @(Model.IsTpa
                    ? "Notice Sent"
                    : "Sent")
            </div>
        </div>

        <div class="card">
            <div class="num red">
                @Model.TotalFailed.ToString("N0")
            </div>

            <div class="label">
                Failed
            </div>
        </div>

        <div class="card">
            <div class="num gold">
                @Model.TotalNoEmail.ToString("N0")
            </div>

            <div class="label">
                @(Model.IsTpa
                    ? "No Owner Email"
                    : "No Email")
            </div>
        </div>
    </div>

    @if (Model.IsTpa && tpa != null)
    {
        <div class="panel">
            <div class="panel-head">
                <span>TPA Statistics by Admin</span>

                <span class="panel-head-count">
                    @tpa.Admins.Count.ToString("N0")
                    Admin group@(tpa.Admins.Count == 1 ? "" : "s")
                </span>
            </div>

            <div class="table-wrap">
                <table class="table tpa-table">
                    <thead>
                        <tr>
                            <th>Admin</th>
                            <th>Pre-populated To</th>
                            <th>Pre-populated CC</th>
                            <th>Total</th>
                            <th>Awaiting Send</th>
                            <th>Notice Sent</th>
                            <th>Failed</th>
                            <th>No Owner Email</th>
                            <th>Report Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!tpa.Admins.Any())
                        {
                            <tr>
                                <td colspan="10"
                                    class="empty-row">
                                    No TPA statistics were found for this workflow.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var admin in tpa.Admins)
                            {
                                <tr>
                                    <td>
                                        <strong>@admin.AdminName</strong>

                                        <div class="muted">
                                            Last notice sent:
                                            @(admin.LastSentAt
                                                ?.ToLocalTime()
                                                .ToString("dd MMM yyyy HH:mm")
                                                ?? "—")
                                        </div>

                                        <div class="muted">
                                            Sent by:
                                            @(admin.LastSentBy ?? "—")
                                        </div>
                                    </td>

                                    <td>
                                        @if (admin.HasAdminEmail)
                                        {
                                            <span class="pill pill-green">
                                                Admin Email Ready
                                            </span>

                                            <div class="email-text">
                                                @admin.AdminEmail
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="pill pill-red">
                                                Missing Admin Email
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="email-text">
                                            @if (string.IsNullOrWhiteSpace(admin.DefaultCcEmails))
                                            {
                                                <span>—</span>
                                            }
                                            else
                                            {
                                                @admin.DefaultCcEmails
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        <strong>
                                            @admin.TotalRecords.ToString("N0")
                                        </strong>
                                    </td>

                                    <td>
                                        <span class="pill pill-gold">
                                            @admin.TotalPrinted.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="pill pill-green">
                                            @admin.TotalSent.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        @if (admin.TotalFailed > 0)
                                        {
                                            <span class="pill pill-red">
                                                @admin.TotalFailed.ToString("N0")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="muted">0</span>
                                        }
                                    </td>

                                    <td>
                                        @if (admin.TotalNoEmail > 0)
                                        {
                                            <span class="pill pill-gold">
                                                @admin.TotalNoEmail.ToString("N0")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="muted">0</span>
                                        }
                                    </td>

                                    <td>
                                        @if (!admin.HasAdminEmail)
                                        {
                                            <span class="pill pill-red">
                                                Blocked
                                            </span>
                                        }
                                        else if (admin.TotalSent == 0)
                                        {
                                            <span class="pill pill-gold">
                                                No Sent Notices Yet
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="pill pill-blue">
                                                Ready for Report
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="admin-actions">
                                            <a class="btn-dark"
                                                   asp-controller="Stats"
                                                   asp-action="DownloadTpaAdminExcel"
                                                   asp-route-key="@Model.WorkflowKey"
                                                   asp-route-adminKey="@admin.AdminKey">
                                                Download Excel
                                            </a>

                                            @if (admin.HasAdminEmail)
                                            {
                                                <form asp-controller="Stats"
                                                      asp-action="SendTpaAdminReport"
                                                      method="post"
                                                      onsubmit="return confirmAdminTpaSend('@admin.AdminName');">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="key"
                                                           value="@Model.WorkflowKey" />

                                                    <input type="hidden"
                                                           name="adminKey"
                                                           value="@admin.AdminKey" />

                                                    <button type="submit"
                                                            class="btn-green">
                                                        Send This Admin
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn-disabled"
                                                        disabled>
                                                    Send Blocked
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="panel">
            <div class="panel-head">
                <span>Batch Statistics</span>

                <span class="panel-head-count">
                    @Model.Batches.Count.ToString("N0")
                    batch@(Model.Batches.Count == 1 ? "" : "es")
                </span>
            </div>

            <div class="table-wrap">
                <table class="table normal-table">
                    <thead>
                        <tr>
                            <th>Roll</th>
                            <th>Notice</th>
                            <th>Batch</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Printed</th>
                            <th>Sent</th>
                            <th>Failed</th>
                            <th>No Email</th>
                            <th>Last Sent</th>
                            <th>Sent By</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Batches.Any())
                        {
                            <tr>
                                <td colspan="12"
                                    class="empty-row">
                                    No statistics were found for the selected filters.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var b in Model.Batches)
                            {
                                <tr>
                                    <td>
                                        <strong>@b.RollShortCode</strong>

                                        <div class="muted">
                                            @b.RollName
                                        </div>
                                    </td>

                                    <td>
                                        <span class="pill">
                                            @b.Notice
                                        </span>

                                        <div class="muted">
                                            @b.VersionText
                                        </div>
                                    </td>

                                    <td>
                                        @b.BatchName
                                    </td>

                                    <td>
                                        @b.BatchDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @b.TotalRecords.ToString("N0")
                                    </td>

                                    <td>
                                        <span class="pill pill-gold">
                                            @b.Printed.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="pill pill-green">
                                            @b.Sent.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="pill pill-red">
                                            @b.Failed.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="pill pill-gold">
                                            @b.NoEmail.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        @(b.LastSentAtUtc
                                            ?.ToLocalTime()
                                            .ToString("dd MMM yyyy HH:mm")
                                            ?? "—")
                                    </td>

                                    <td>
                                        @(b.SentBy ?? "—")
                                    </td>

                                    <td>
                                        <a class="btn-dark"
                                               asp-controller="Stats"
                                               asp-action="Details"
                                               asp-route-batchId="@b.BatchId">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>


@section Scripts {
    <script>
        function confirmAdminTpaSend(adminName) {
            return window.confirm(
                'Send the TPA statistics report to ' +
                adminName +
                '?\n\nThe Excel workbook and .eml email copy will be saved as evidence.'
            );
        }

        function confirmBulkTpaSend(form) {
            const eligible = @(tpa?.Admins.Count(x => x.HasAdminEmail) ?? 0);
            const blocked = @(tpa?.Admins.Count(x => !x.HasAdminEmail) ?? 0);

            const message =
                'You are about to send TPA reports to ' +
                eligible +
                ' Admin(s).\n\n' +
                blocked +
                ' Admin report(s) with missing email addresses will be skipped.\n\n' +
                'The Excel workbooks and .eml email copies will be saved as evidence. Continue?';

            if (!window.confirm(message)) {
                return false;
            }

            const button = form.querySelector('button[type="submit"]');

            if (button) {
                button.disabled = true;
                button.textContent = 'Sending Admin Reports...';
            }

            return true;
        }
    </script>
}
