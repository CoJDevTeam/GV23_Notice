@model GV23_Notice.Models.Workflow.ViewModels.ThirdPartyAppealStatsVm

@{
    ViewData["Title"] = "Third-Party Appeal Statistics";
    var key = Model.WorkflowKey;
}

<link href="~/css/Step3/Step3KickOffCss1.css"
      rel="stylesheet" />

<style>
    .ts-wrap {
        padding: 24px;
        font-family: 'Poppins', sans-serif;
        background: #f4f4f4;
        min-height: calc(100vh - 70px);
    }

    .ts-head {
        background: #111;
        color: #fff;
        border-bottom: 4px solid #2ebd6c;
        border-radius: 14px;
        padding: 18px 22px;
        margin-bottom: 18px;
    }

    .ts-title {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .ts-meta {
        margin-top: 8px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: .75rem;
        color: #ddd;
    }

        .ts-meta b {
            color: #2ebd6c;
        }

    .ts-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .ts-btn {
        border: none;
        border-radius: 10px;
        padding: 10px 15px;
        text-decoration: none;
        font-size: .75rem;
        font-weight: 900;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .ts-btn-dark {
        background: #111;
        color: #fff;
    }

    .ts-btn-green {
        background: #1a8a4a;
        color: #fff;
    }

    .ts-btn-gold {
        background: #e6b000;
        color: #111;
    }

    .ts-btn-muted {
        background: #e9e9e9;
        color: #888;
        cursor: not-allowed;
    }

    .ts-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(120px, 1fr));
        gap: 12px;
        margin-bottom: 18px;
    }

    .ts-card {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .05);
    }

    .ts-num {
        font-size: 1.8rem;
        font-weight: 900;
        color: #111;
        line-height: 1;
    }

        .ts-num.green {
            color: #1a8a4a;
        }

        .ts-num.red {
            color: #c0392b;
        }

        .ts-num.gold {
            color: #d4a500;
        }

    .ts-label {
        margin-top: 6px;
        color: #777;
        font-size: .65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .ts-panel {
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 14px;
        margin-bottom: 18px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, .05);
    }

    .ts-panel-head {
        background: #111;
        color: #fff;
        border-bottom: 3px solid #2ebd6c;
        padding: 12px 16px;
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

    .ts-panel-body {
        padding: 16px;
    }

    .ts-table-wrap {
        overflow: auto;
    }

    .ts-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .74rem;
        min-width: 1100px;
    }

        .ts-table th {
            background: #f7f7f7;
            padding: 10px;
            text-align: left;
            border-bottom: 1px solid #ddd;
            font-size: .62rem;
            color: #777;
            text-transform: uppercase;
            letter-spacing: .06em;
            white-space: nowrap;
        }

        .ts-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
            vertical-align: top;
        }

    .ts-admin {
        font-weight: 900;
        color: #111;
    }

    .ts-email {
        margin-top: 3px;
        color: #555;
        font-size: .68rem;
        word-break: break-all;
    }

    .ts-cc {
        max-width: 280px;
        color: #666;
        font-size: .68rem;
        line-height: 1.45;
        word-break: break-word;
    }

    .ts-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 3px 8px;
        font-size: .62rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .ts-ok {
        background: #e8f8ef;
        color: #1a8a4a;
        border: 1px solid #b2dfcc;
    }

    .ts-warn {
        background: #fff3d6;
        color: #a96600;
        border: 1px solid #f0d078;
    }

    .ts-err {
        background: #fff0f0;
        color: #a12626;
        border: 1px solid #efb5b5;
    }

    .ts-info {
        background: #e8f0fe;
        color: #1a56c4;
        border: 1px solid #b3c8f8;
    }

    .ts-zero {
        color: #bbb;
    }

    .ts-empty {
        padding: 50px 20px;
        text-align: center;
        color: #777;
    }

    .ts-phase {
        background: #fff8dc;
        border: 1px solid #ecd98d;
        color: #725800;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 18px;
        font-size: .75rem;
        line-height: 1.6;
    }

    @@media(max-width: 1100px) {
        .ts-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media(max-width: 700px) {
        .ts-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="ts-wrap">

    <div class="ts-head">
        <h1 class="ts-title">
            Third-Party Appeal Notice Statistics
        </h1>

        <div class="ts-meta">
            <span>
                Roll:
                <b>
                    @Model.RollShortCode —
                    @Model.RollName
                </b>
            </span>

            <span>
                Period:
                <b>@Model.ValuationPeriod</b>
            </span>

            <span>
                Version:
                <b>@Model.VersionText</b>
            </span>

            <span>
                Last Notice Sent:
                <b>
                    @(Model.LastSentAt?.ToString(
                        "dd MMM yyyy HH:mm") ?? "—")
                </b>
            </span>

            <span>
                Sent By:
                <b>@(Model.LastSentBy ?? "—")</b>
            </span>
        </div>
    </div>

    <div class="ts-actions">
        <a class="ts-btn ts-btn-dark"
               asp-controller="Step3"
               asp-action="SendEmail"
               asp-route-key="@key">
            ← Back to Send Notices
        </a>

        <button type="button"
                class="ts-btn ts-btn-muted"
                disabled>
            Download Admin Excel — Phase 2
        </button>

        <button type="button"
                class="ts-btn ts-btn-muted"
                disabled>
            Send All Admin Reports — Phase 3
        </button>
    </div>

    <div class="ts-phase">
        <strong>Phase 1:</strong>

        TPA records are grouped by Admin.

        Recipient and CC values are pre-populated from
        <strong>AdminEmail</strong>,
        <strong>Valuer_Email</strong>, and
        <strong>
            @Model.ValuationEnquiriesEmail
        </strong>.

        Excel generation, evidence copies, email sending,
        and audit logging will use this foundation.
    </div>

    <div class="ts-grid">
        <div class="ts-card">
            <div class="ts-num">
                @Model.TotalAdmins.ToString("N0")
            </div>

            <div class="ts-label">
                Admins
            </div>
        </div>

        <div class="ts-card">
            <div class="ts-num">
                @Model.TotalRecords.ToString("N0")
            </div>

            <div class="ts-label">
                Total TPA Records
            </div>
        </div>

        <div class="ts-card">
            <div class="ts-num gold">
                @Model.TotalPrinted.ToString("N0")
            </div>

            <div class="ts-label">
                Awaiting Send
            </div>
        </div>

        <div class="ts-card">
            <div class="ts-num green">
                @Model.TotalSent.ToString("N0")
            </div>

            <div class="ts-label">
                Notice Sent
            </div>
        </div>

        <div class="ts-card">
            <div class="ts-num red">
                @Model.TotalFailed.ToString("N0")
            </div>

            <div class="ts-label">
                Email Failed
            </div>
        </div>

        <div class="ts-card">
            <div class="ts-num gold">
                @Model.TotalNoEmail.ToString("N0")
            </div>

            <div class="ts-label">
                No Owner Email
            </div>
        </div>
    </div>

    @if (Model.TotalMissingAdminEmail > 0)
    {
        <div class="ts-phase"
             style="
            background:#fff0f0;
            border-color:#efb5b5;
            color:#8a1a1a;">

            <strong>Action required:</strong>

            @Model.TotalMissingAdminEmail
            Admin group(s) have no Admin email address.

            Their reports must not be sent until the
            Admin email is corrected.
        </div>
    }

    <div class="ts-panel">
        <div class="ts-panel-head">
            <span>
                Admin Report Summary
            </span>

            <span>
                @Model.Admins.Count
                group@(Model.Admins.Count == 1
                                    ? ""
                                    : "s")
            </span>
        </div>

        <div class="ts-panel-body">

            @if (!Model.Admins.Any())
            {
                <div class="ts-empty">
                    No printed or sent Third-Party Appeal
                    notices were found for this workflow.
                </div>
            }
            else
            {
                <div class="ts-table-wrap">
                    <table class="ts-table">
                        <thead>
                            <tr>
                                <th>Admin</th>
                                <th>Pre-populated To</th>
                                <th>Pre-populated CC</th>
                                <th>Total</th>
                                <th>Awaiting Send</th>
                                <th>Sent</th>
                                <th>Failed</th>
                                <th>No Owner Email</th>
                                <th>Report Readiness</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var admin in Model.Admins)
                            {
                                <tr>
                                    <td>
                                        <div class="ts-admin">
                                            @admin.AdminName
                                        </div>

                                        <div class="ts-email">
                                            Last sent:
                                            @(admin.LastSentAt
                                                ?.ToString(
                                                    "dd MMM yyyy HH:mm")
                                                ?? "—")
                                        </div>
                                    </td>

                                    <td>
                                        @if (admin.HasAdminEmail)
                                        {
                                            <span class="ts-badge ts-ok">
                                                Admin Email Ready
                                            </span>

                                            <div class="ts-email">
                                                @admin.AdminEmail
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="ts-badge ts-err">
                                                Missing Admin Email
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="ts-cc">
                                            @admin.DefaultCcEmails
                                        </div>
                                    </td>

                                    <td>
                                        <strong>
                                            @admin.TotalRecords.ToString("N0")
                                        </strong>
                                    </td>

                                    <td>
                                        @admin.TotalPrinted.ToString("N0")
                                    </td>

                                    <td>
                                        <span class="ts-badge ts-ok">
                                            @admin.TotalSent.ToString("N0")
                                        </span>
                                    </td>

                                    <td>
                                        @if (admin.TotalFailed > 0)
                                        {
                                            <span class="ts-badge ts-err">
                                                @admin.TotalFailed.ToString("N0")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="ts-zero">
                                                0
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (admin.TotalNoEmail > 0)
                                        {
                                            <span class="ts-badge ts-warn">
                                                @admin.TotalNoEmail.ToString("N0")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="ts-zero">
                                                0
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (!admin.HasAdminEmail)
                                        {
                                            <span class="ts-badge ts-err">
                                                Blocked
                                            </span>
                                        }
                                        else if (admin.TotalSent == 0)
                                        {
                                            <span class="ts-badge ts-warn">
                                                No Sent Notices Yet
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="ts-badge ts-info">
                                                Ready for Excel
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <button type="button"
                                                class="ts-btn ts-btn-muted"
                                                disabled>
                                            Build Report
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>

</div>