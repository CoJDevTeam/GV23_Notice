@model GV23_Notice.Models.Workflow.ViewModels.HomeIndexVm
@using GV23_Notice.Domain.Workflow
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "Dashboard — GV23 Notice Management";
    var now = DateTime.Now;

    var canWorkflowAdmin = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminCreateApprove")).Succeeded;
    var canSearchLibrary = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminSearchDownload")).Succeeded;
    var canStep3 = (await AuthorizationService.AuthorizeAsync(User, "DataTeamCreateBatchPrint")).Succeeded;

    var displayName = User.FindFirst("FullName")?.Value
        ?? User.Identity?.Name?.Split('\\').Last()
        ?? "User";

    var roleName = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}

<link href="~/css/homeindexcss.css" rel="stylesheet" />

<div class="hd-page">

    <!-- TITLE BAR -->
    <div class="hd-title-bar">
        <div>
            <div class="hd-title">VNS-Valuation Notice System <span>Dashboard</span></div>
            <div class="hd-subtitle">City of Johannesburg — Valuation Services Department</div>
            <div style="margin-top:6px;font-size:12px;color:#5f6b7a;">
             
            </div>
        </div>

        <div class="hd-date-pill">
            <span>@now.ToString("dd MMM yyyy")</span> &nbsp;·&nbsp; @now.ToString("HH:mm")
        </div>
    </div>

    <!-- HERO -->
    <div class="hd-hero">
        <div class="hd-hero-text">
            <h2>Valuation Notice System</h2>
            <p>
                Valuation cycle processing — bulk generation, print, and dispatch of statutory notices for
                Section 49, 51, 52, 53, Dear Johnny, Invalid, Appeal Decision notice workflows.
            </p>
            <div class="hd-hero-badges">
                <span class="hd-badge hd-badge-live"><span class="hd-hero-pulse"></span> System Active</span>
                <span class="hd-badge hd-badge-cycle">2026 Valuation Period</span>
                <span class="hd-badge hd-badge-user">👤 @displayName</span>
                @if (!string.IsNullOrWhiteSpace(roleName))
                {
                    <span class="hd-badge">@roleName</span>
                }
            </div>
        </div>

        <div class="hd-hero-right">
            @if (canStep3)
            {
                <a class="hd-go-btn" asp-controller="Step3" asp-action="Index">
                    ▶ Go to Step 3 Processing
                </a>
            }

            @if (canSearchLibrary)
            {
                <a class="hd-go-btn" asp-controller="NoticeSearch" asp-action="Index">
                     Search Notice
                </a>
            }

            @if (canWorkflowAdmin)
            {
                <a class="hd-go-btn-sec" asp-controller="Workflow" asp-action="Step1">
                    ⚙ Workflow Admin
                </a>
            }
        </div>
    </div>

    <!-- STATS STRIP -->
    <div class="hd-stats">
        <div class="hd-stat gold">
            <span class="hd-stat-lbl">Active Rolls</span>
            <span class="hd-stat-num">@Model.ActiveRolls</span>
            <span class="hd-stat-sub">Registered in system</span>
        </div>
        <div class="hd-stat">
            <span class="hd-stat-lbl">Total Workflows</span>
            <span class="hd-stat-num">@Model.TotalWorkflows</span>
            <span class="hd-stat-sub">@Model.Step1Approved approved at Step 1</span>
        </div>
        <div class="hd-stat">
            <span class="hd-stat-lbl">Pending Step 2</span>
            <span class="hd-stat-num">@Model.PendingStep2</span>
            <span class="hd-stat-sub">Awaiting Step 2 approval</span>
        </div>
        <div class="hd-stat green">
            <span class="hd-stat-lbl">Step 2 Approved</span>
            <span class="hd-stat-num">@Model.Step2Approved</span>
            <span class="hd-stat-sub">Ready for Step 3</span>
        </div>
        <div class="hd-stat green">
            <span class="hd-stat-lbl">Notices Sent</span>
            <span class="hd-stat-num">@Model.TotalSent.ToString("N0")</span>
            <span class="hd-stat-sub">@Model.TotalBatches batch@(Model.TotalBatches == 1 ? "" : "es") created</span>
        </div>
    </div>

    <!-- MAIN BODY -->
    <div class="hd-cols">

        <!-- LEFT: Recent Workflows Table -->
        <div class="hd-card">
            <div class="hd-card-head">
                <h3>📋 Recent Workflows</h3>
                <span class="hd-count-chip">@Model.RecentWorkflows.Count</span>
            </div>

            <div style="overflow-x:auto">
                @if (Model.RecentWorkflows.Count == 0)
                {
                    <div class="hd-empty">
                        <div class="hd-empty-icon">📭</div>
                        No workflows yet.
                        @if (canWorkflowAdmin)
                        {
                            <span> Go to Workflow Admin to create one.</span>
                        }
                    </div>
                }
                else
                {
                    <table class="hd-wf-table">
                        <thead>
                            <tr>
                                <th>Roll / Workflow</th>
                                <th>Notice</th>
                                <th>Letter Date</th>
                                <th>Status</th>
                                <th style="text-align:center">Sent</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.RecentWorkflows)
                            {
                                <tr>
                                    <td>
                                        <div class="hd-wf-name">@w.RollName</div>
                                        <div class="hd-wf-meta">
                                            <span class="hd-roll-code">@w.RollShortCode</span>
                                            &nbsp;v@w.Version
                                        </div>
                                    </td>
                                    <td><span class="hd-notice-chip">@w.Notice</span></td>
                                    <td style="font-size:11.5px;color:#666;white-space:nowrap">
                                        @w.LetterDate.ToString("dd MMM yyyy")
                                    </td>
                                    <td>
                                        @if (w.IsStep2Approved && w.HasWorkflowKey)
                                        {
                                            <span class="hd-status-pip hd-pip-s3">⚡ Step 3 Ready</span>
                                        }
                                        else if (w.IsStep2Approved)
                                        {
                                            <span class="hd-status-pip hd-pip-s2ok">✓ Step 2 Done</span>
                                        }
                                        else if (w.IsApproved)
                                        {
                                            <span class="hd-status-pip hd-pip-s1ok">● Step 1 Approved</span>
                                        }
                                        else if (w.IsConfirmed)
                                        {
                                            <span class="hd-status-pip hd-pip-draft">✎ Step 1 Confirmed</span>
                                        }
                                        else
                                        {
                                            <span class="hd-status-pip hd-pip-draft">Draft</span>
                                        }
                                    </td>
                                    <td style="text-align:center">
                                        <span class="hd-sent-num @(w.SentCount == 0 ? "zero" : "")">
                                            @w.SentCount.ToString("N0")
                                        </span>
                                    </td>
                                    <td>
                                        @if (w.IsStep2Approved && w.WorkflowKey.HasValue && canStep3)
                                        {
                                            <a class="hd-wf-link"
                                               asp-controller="Step3"
                                               asp-action="Kickoff"
                                               asp-route-key="@w.WorkflowKey">
                                                Open →
                                            </a>
                                        }
                                        else if (w.IsApproved && canWorkflowAdmin)
                                        {
                                            <a class="hd-wf-link"
                                               asp-controller="Workflow"
                                               asp-action="Step2"
                                               asp-route-settingsId="@w.Id">
                                                Review
                                            </a>
                                        }
                                        else if (canSearchLibrary)
                                        {
                                            <a class="hd-wf-link"
                                               asp-controller="Workflow"
                                               asp-action="SettingsLibrary">
                                                View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="no-link">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- RIGHT -->
        <div style="display:flex;flex-direction:column;gap:16px;">

            <!-- Workflow Phases -->
            <div class="hd-card">
                <div class="hd-card-head">
                    <h3>🔁 Workflow Phases</h3>
                </div>
                <div class="hd-card-body" style="padding:16px">
                    <div class="hd-phases">

                        @if (canWorkflowAdmin)
                        {
                            <a class="hd-phase done" asp-controller="Workflow" asp-action="Step1">
                                <div class="hd-phase-num">1</div>
                                <div class="hd-phase-info">
                                    <div class="hd-phase-title">Phase 1 — Setup & Config</div>
                                    <div class="hd-phase-desc">Define roll, notice type, dates, signatures and approval chain.</div>
                                </div>
                                <div class="hd-phase-tag tag-done">Access</div>
                            </a>

                            <a class="hd-phase done" asp-controller="Workflow" asp-action="Step2">
                                <div class="hd-phase-num">2</div>
                                <div class="hd-phase-info">
                                    <div class="hd-phase-title">Phase 2 — Review & Approval</div>
                                    <div class="hd-phase-desc">Data check, correction tickets, Step 2 sign-off.</div>
                                </div>
                                <div class="hd-phase-tag tag-done">Access</div>
                            </a>
                        }

                        @if (canStep3)
                        {
                            <a class="hd-phase active" asp-controller="Step3" asp-action="Index">
                                <div class="hd-phase-num">3</div>
                                <div class="hd-phase-info">
                                    <div class="hd-phase-title">Phase 3 — Processing</div>
                                    <div class="hd-phase-desc">Batch creation, PDF print, and email dispatch to ratepayers.</div>
                                </div>
                                <div class="hd-phase-tag tag-current">Access</div>
                            </a>
                        }

                        @if (!canWorkflowAdmin && !canStep3)
                        {
                            <div class="hd-empty" style="margin:0;">
                                <div class="hd-empty-icon">🔒</div>
                                No workflow phases are assigned to your role.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Notice Types -->
            <div class="hd-card">
                <div class="hd-card-head">
                    <h3>📑 Notice Types</h3>
                </div>
                <div class="hd-card-body" style="padding:14px">
                    <div class="hd-types-grid">
                        @foreach (var nt in new[]
                                                {
                                                ("S49","Section 49"),
                                                ("S51","Section 51"),
                                                ("S52","Section 52"),
                                                ("S53","Section 53"),
                                                ("DJ","Dear Johnny"),
                                                ("IN","Invalid"),
                                                ("AD","Appeal Decision")
                                                })
                        {
                            <div class="hd-ntype">
                                <div class="hd-ntype-code">@nt.Item1</div>
                                <div class="hd-ntype-name">@nt.Item2</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- QUICK ACTIONS -->
    <div class="hd-section-hdr"><h3>Quick Access</h3></div>
    <div class="hd-actions">

        @if (canStep3)
        {
            <a class="hd-action primary" asp-controller="Step3" asp-action="Index">
                <div class="hd-action-icon">▶</div>
                <div class="hd-action-label">Step 3 Processing</div>
                <div class="hd-action-sub">Select an approved workflow to create batches, print PDFs, and send notice emails to ratepayers.</div>
                <div class="hd-action-cta">Go to Step 3 →</div>
            </a>
        }

        @if (canWorkflowAdmin)
        {
            <a class="hd-action" asp-controller="Workflow" asp-action="Step1">
                <div class="hd-action-icon">⚙️</div>
                <div class="hd-action-label">Workflow Administration</div>
                <div class="hd-action-sub">Create or manage workflows — assign rolls, notice types, letter dates, and valuation period settings.</div>
                <div class="hd-action-cta">Open Admin →</div>
            </a>
        }

        @if (canSearchLibrary)
        {
            <a class="hd-action green-action" asp-controller="Workflow" asp-action="SettingsLibrary">
                <div class="hd-action-icon">📚</div>
                <div class="hd-action-label">Settings Library</div>
                <div class="hd-action-sub">View all notice configurations, valuation periods, and roll registry definitions in one place.</div>
                <div class="hd-action-cta">Open Library →</div>
            </a>
        }

    </div>

</div>