@model GV23_Notice.Models.Workflow.ViewModels.HomeIndexVm
@using GV23_Notice.Domain.Workflow
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService

@{
    ViewData["Title"] = "VNS — Dashboard";
    var now = DateTime.Now;

    var canAdmin = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminCreateApprove")).Succeeded;
    var canSearch = (await AuthorizationService.AuthorizeAsync(User, "ValuationAdminSearchDownload")).Succeeded;
    var canStep3 = (await AuthorizationService.AuthorizeAsync(User, "DataTeamCreateBatchPrint")).Succeeded;

    string PipelineClass(int step)
    {
        if (step == 1) return canAdmin ? "pip-accessible" : "pip-locked";
        if (step == 2) return canAdmin ? "pip-accessible" : "pip-locked";
        return canStep3 ? "pip-active" : "pip-locked";
    }
}

<link href="~/css/homeindexcss1.css" rel="stylesheet" />

<div class="vns-root">

    <!-- ══ STATS STRIP ══════════════════════════════════════════════ -->
    <section class="vns-stats-strip" id="vns-stats">
        <div class="vns-stat-card" style="--i:0">
            <div class="vns-stat-icon">⬡</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.ActiveRolls">0</div>
                <div class="vns-stat-lbl">Active Rolls</div>
            </div>
        </div>
        <div class="vns-stat-card" style="--i:1">
            <div class="vns-stat-icon">⊞</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.TotalWorkflows">0</div>
                <div class="vns-stat-lbl">Total Workflows</div>
            </div>
        </div>
        <div class="vns-stat-card vns-stat-amber" style="--i:2">
            <div class="vns-stat-icon">◎</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.PendingStep2">0</div>
                <div class="vns-stat-lbl">Pending Step 2</div>
            </div>
        </div>
        <div class="vns-stat-card vns-stat-green" style="--i:3">
            <div class="vns-stat-icon">✦</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.Step2Approved">0</div>
                <div class="vns-stat-lbl">Step 2 Approved</div>
            </div>
        </div>
        <div class="vns-stat-card vns-stat-blue" style="--i:4">
            <div class="vns-stat-icon">⬛</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.TotalBatches">0</div>
                <div class="vns-stat-lbl">Total Batches</div>
            </div>
        </div>
        <div class="vns-stat-card vns-stat-gold" style="--i:5">
            <div class="vns-stat-icon">✉</div>
            <div class="vns-stat-body">
                <div class="vns-stat-num" data-target="@Model.TotalSent">0</div>
                <div class="vns-stat-lbl">Notices Sent</div>
            </div>
        </div>
    </section>

    <!-- ══ MAIN GRID ════════════════════════════════════════════════ -->
    <main class="vns-main">

        <!-- LEFT COLUMN: Recent Workflows -->
        <div class="vns-panel vns-panel-wide" style="--pi:0">
            <div class="vns-panel-header">
                <div class="vns-panel-title">
                    <span class="vns-panel-icon">◫</span>
                    Recent Workflows
                </div>
                <div class="vns-chip">@Model.RecentWorkflows.Count</div>
            </div>

            @if (Model.RecentWorkflows.Count == 0)
            {
                <div class="vns-empty">
                    <div class="vns-empty-glyph">□</div>
                    <div>No workflows created yet.</div>
                    @if (canAdmin)
                    {
                        <a asp-controller="Workflow" asp-action="Step1" class="vns-empty-cta">
                            Create First Workflow →
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="vns-table-wrap">
                    <table class="vns-table">
                        <thead>
                            <tr>
                                <th>Roll</th>
                                <th>Notice</th>
                                <th>Letter Date</th>
                                <th>Status</th>
                                <th class="ta-r">Sent</th>
                                <th class="ta-r">Batches</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.RecentWorkflows)
                            {
                                <tr class="vns-row">
                                    <td>
                                        <div class="vns-roll-name">@w.RollName</div>
                                        <div class="vns-roll-meta">
                                            <span class="vns-code-chip">@w.RollShortCode</span>
                                            <span>v@w.Version</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="vns-notice-tag vns-notice-@w.Notice.ToString().ToLower()">
                                            @w.Notice
                                        </span>
                                    </td>
                                    <td class="vns-date-cell">@w.LetterDate.ToString("dd MMM yy")</td>
                                    <td>
                                        @if (w.IsStep2Approved && w.HasWorkflowKey)
                                        {
                                            <span class="vns-status vns-s-ready">⚡ Step 3 Ready</span>
                                        }
                                        else if (w.IsStep2Approved)
                                        {
                                            <span class="vns-status vns-s-s2">✓ Step 2 Done</span>
                                        }
                                        else if (w.IsApproved)
                                        {
                                            <span class="vns-status vns-s-s1">● Step 1 Approved</span>
                                        }
                                        else if (w.IsConfirmed)
                                        {
                                            <span class="vns-status vns-s-draft">✎ Confirmed</span>
                                        }
                                        else
                                        {
                                            <span class="vns-status vns-s-draft">Draft</span>
                                        }
                                    </td>
                                    <td class="ta-r vns-num-cell">
                                        <span class="@(w.SentCount == 0 ? "vns-zero" : "vns-num")">
                                            @w.SentCount.ToString("N0")
                                        </span>
                                    </td>
                                    <td class="ta-r vns-num-cell">
                                        <span class="@(w.BatchCount == 0 ? "vns-zero" : "vns-num")">
                                            @w.BatchCount
                                        </span>
                                    </td>
                                    <td>
                                        @if (w.IsStep2Approved && w.WorkflowKey.HasValue && canStep3)
                                        {
                                            <a class="vns-row-btn vns-row-btn-primary"
                                               asp-controller="Step3" asp-action="Kickoff"
                                               asp-route-key="@w.WorkflowKey">Open</a>
                                        }
                                        else if (w.IsApproved && canAdmin)
                                        {
                                            <a class="vns-row-btn"
                                               asp-controller="Workflow" asp-action="Step2"
                                               asp-route-settingsId="@w.Id">Review</a>
                                        }
                                        else if (canSearch)
                                        {
                                            <a class="vns-row-btn"
                                               asp-controller="Workflow" asp-action="SettingsLibrary">View</a>
                                        }
                                        else
                                        {

                                            <span class="vns-dash">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- RIGHT COLUMN -->
        <div class="vns-right-col">

            <!-- Workflow Pipeline -->
            <div class="vns-panel" style="--pi:1">
                <div class="vns-panel-header">
                    <div class="vns-panel-title">
                        <span class="vns-panel-icon">⇢</span>
                        Workflow Pipeline
                    </div>
                </div>
                <div class="vns-pipeline">
                    <div class="vns-pip-step @PipelineClass(1)">
                        <div class="vns-pip-number">01</div>
                        <div class="vns-pip-content">
                            <div class="vns-pip-title">Setup & Configuration</div>
                            <div class="vns-pip-desc">Roll, notice type, dates, signatures</div>
                        </div>
                        @if (canAdmin)
                        {
                            <a class="vns-pip-btn" asp-controller="Workflow" asp-action="Step1">Go</a>
                        }
                    </div>
                    <div class="vns-pip-connector"></div>
                    <div class="vns-pip-step @PipelineClass(2)">
                        <div class="vns-pip-number">02</div>
                        <div class="vns-pip-content">
                            <div class="vns-pip-title">Review & Approval</div>
                            <div class="vns-pip-desc">Data check, correction tickets, sign-off</div>
                        </div>
                        @if (canAdmin)
                        {
                            <a class="vns-pip-btn" asp-controller="Workflow" asp-action="Step2">Go</a>
                        }
                    </div>
                    <div class="vns-pip-connector"></div>
                    <div class="vns-pip-step @PipelineClass(3)">
                        <div class="vns-pip-number">03</div>
                        <div class="vns-pip-content">
                            <div class="vns-pip-title">Batch Processing</div>
                            <div class="vns-pip-desc">Create batches, print PDFs, dispatch emails</div>
                        </div>
                        @if (canStep3)
                        {
                            <a class="vns-pip-btn vns-pip-btn-gold" asp-controller="Step3" asp-action="Index">Go</a>
                        }
                    </div>
                </div>
            </div>

            <!-- Notice Types Grid -->
            <div class="vns-panel" style="--pi:2">
                <div class="vns-panel-header">
                    <div class="vns-panel-title">
                        <span class="vns-panel-icon">⊡</span>
                        Notice Types
                    </div>
                </div>
                <div class="vns-notice-grid">
                    @foreach (var (code, label, desc) in new[]
                                        {
                                        ("S49","Section 49","Public inspection & objections"),
                                        ("S51","Section 51","Objection decision notice"),
                                        ("S52","Section 52","Appeal decision / review"),
                                        ("S53","Section 53","Appeal period notice"),
                                        ("DJ","Dear Johnny","Invalid objector address"),
                                        ("IN","Invalid","Invalid objection / omission"),
                                        ("AD","Appeal Dec.","Appeal decision dispatch"),
                                        })
                    {
                        <div class="vns-ntype vns-ntype-@code.ToLower()">
                            <div class="vns-ntype-code">@code</div>
                            <div class="vns-ntype-label">@label</div>
                            <div class="vns-ntype-desc">@desc</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>

    <!-- ══ QUICK ACTIONS ════════════════════════════════════════════ -->
    <section class="vns-actions-section">
        <div class="vns-section-title">Quick Access</div>
        <div class="vns-actions">

            @if (canStep3)
            {
                <a class="vns-action vns-action-primary" asp-controller="Step3" asp-action="Index" style="--ai:0">
                    <div class="vns-action-glyph">▶</div>
                    <div class="vns-action-body">
                        <div class="vns-action-title">Step 3 Processing</div>
                        <div class="vns-action-desc">Create batches, generate PDFs and dispatch notice emails to ratepayers.</div>
                    </div>
                    <div class="vns-action-arrow">→</div>
                </a>
            }

            @if (canAdmin)
            {
                <a class="vns-action" asp-controller="Workflow" asp-action="Step1" style="--ai:1">
                    <div class="vns-action-glyph">⚙</div>
                    <div class="vns-action-body">
                        <div class="vns-action-title">Workflow Administration</div>
                        <div class="vns-action-desc">Create workflows, assign rolls, notice types, letter dates and approval chain.</div>
                    </div>
                    <div class="vns-action-arrow">→</div>
                </a>
            }

            @if (canSearch)
            {
                <a class="vns-action" asp-controller="NoticeSearch" asp-action="Index" style="--ai:2">
                    <div class="vns-action-glyph">⌕</div>
                    <div class="vns-action-body">
                        <div class="vns-action-title">Notice Search</div>
                        <div class="vns-action-desc">Search, preview and download generated notice PDFs across all rolls.</div>
                    </div>
                    <div class="vns-action-arrow">→</div>
                </a>

                <a class="vns-action" asp-controller="Workflow" asp-action="SettingsLibrary" style="--ai:3">
                    <div class="vns-action-glyph">◫</div>
                    <div class="vns-action-body">
                        <div class="vns-action-title">Settings Library</div>
                        <div class="vns-action-desc">Browse all notice configurations, valuation periods and roll registry.</div>
                    </div>
                    <div class="vns-action-arrow">→</div>
                </a>
            }
        </div>
    </section>

</div>

<script>
    // Clock provided by _Layout

    // Animated stat counters
    document.querySelectorAll('.vns-stat-num[data-target]').forEach(el => {
        const target = parseInt(el.dataset.target, 10);
        if (isNaN(target) || target === 0) { el.textContent = '0'; return; }
        const duration = 900;
        const start = performance.now();
        function tick(now) {
            const pct = Math.min((now - start) / duration, 1);
            const ease = 1 - Math.pow(1 - pct, 3);
            el.textContent = Math.round(ease * target).toLocaleString();
            if (pct < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
    });
</script>
