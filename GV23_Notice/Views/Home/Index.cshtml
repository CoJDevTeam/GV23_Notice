@model GV23_Notice.Models.Workflow.ViewModels.HomeIndexVm
@using GV23_Notice.Domain.Workflow
@{
    ViewData["Title"] = "Dashboard";
    var now = DateTime.Now;

    // Group recent workflows by notice type for tab stats
    var byNotice = Model.RecentWorkflows
        .GroupBy(w => w.Notice.ToString())
        .ToDictionary(g => g.Key, g => g.ToList());

    // Notice type definitions
    var noticeTypes = new[]
    {
        ("S49","Section 49","Public Inspection"),
        ("S51","Section 51","Objection Decision"),
        ("S52","Section 52","Appeal Notice"),
        ("S53","Section 53","MVD Decision"),
        ("DJ", "Dear Johnny","Acknowledgement"),
        ("IN", "Invalid",   "Invalid Notice"),
        ("S78","Section 78","Query Notice"),
    };

    // Chart data — sent count per notice type
    var chartLabels = string.Join(",", noticeTypes.Select(n =>
        $"'{n.Item1}'"));
    var chartSent = string.Join(",", noticeTypes.Select(n =>
        Model.RecentWorkflows
             .Where(w => w.Notice.ToString() == n.Item1)
             .Sum(w => w.SentCount)));
    var chartBatches = string.Join(",", noticeTypes.Select(n =>
        Model.RecentWorkflows
             .Where(w => w.Notice.ToString() == n.Item1)
             .Sum(w => w.BatchCount)));
}
<link href="~/css/home/homeindexcss.css" rel="stylesheet" />

<div class="hm-root">

    <!-- ── HERO ──────────────────────────────────────────────────────── -->
    <div class="hm-hero">
        <div class="hm-hero-inner">
            <div class="hm-hero-left">
                <div class="hm-hero-eyebrow">
                    <span class="hm-hero-eyebrow-dot"></span>
                    City of Johannesburg — Valuation Services
                </div>
                <h1 class="hm-hero-title">
                    Notice Management <em>Dashboard</em>
                </h1>
                <p class="hm-hero-sub">
                    GV23 statutory notice processing — bulk generation, print and dispatch
                    of Section 49, 51, 52, 53, Dear Johnny, Invalid and S78 notices.
                </p>
                <div class="hm-hero-badges">
                    <span class="hm-badge hm-badge-live">
                        <span class="hm-pulse"></span> System Active
                    </span>
                    <span class="hm-badge hm-badge-cycle">2026 Valuation Period</span>
                  @*   <span class="hm-badge hm-badge-user">
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                        @User.Identity?.Name?.Split('\\').Last()
                    </span> *@
                </div>
            </div>
            <div class="hm-hero-right">
                <a class="hm-hero-btn hm-btn-gold" asp-controller="Step3" asp-action="Index">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                    Step 3 Processing
                </a>
                <a class="hm-hero-btn hm-btn-outline" asp-controller="Workflow" asp-action="Step1">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" /></svg>
                    Step 1 Configure Date
                </a>
               @*  <div class="hm-hero-datepill">
                    @now.ToString("dddd, dd MMMM yyyy") &nbsp;·&nbsp; @now.ToString("HH:mm")
                </div> *@
            </div>
        </div>
    </div>

    <div class="hm-body">

        <!-- ── STAT STRIP ─────────────────────────────────────────────── -->
        <div class="hm-stats" style="margin-top:28px">
            <div class="hm-stat hm-stat-gold">
                <div class="hm-stat-lbl">Active Rolls</div>
                <div class="hm-stat-num">@Model.ActiveRolls</div>
                <div class="hm-stat-sub">Registered in system</div>
            </div>
            <div class="hm-stat">
                <div class="hm-stat-lbl">Total Workflows</div>
                <div class="hm-stat-num">@Model.TotalWorkflows</div>
                <div class="hm-stat-sub">@Model.Step1Approved approved Step 1</div>
            </div>
            <div class="hm-stat">
                <div class="hm-stat-lbl">Batches Created</div>
                <div class="hm-stat-num">@Model.TotalBatches</div>
                <div class="hm-stat-sub">@Model.TotalPrinted PDFs printed</div>
            </div>
            <div class="hm-stat hm-stat-green">
                <div class="hm-stat-lbl">Notices Sent</div>
                <div class="hm-stat-num">@Model.TotalSent.ToString("N0")</div>
                <div class="hm-stat-sub">Email + print dispatched</div>
            </div>
            <div class="hm-stat">
                <div class="hm-stat-lbl">Step 2 Approved</div>
                <div class="hm-stat-num">@Model.Step2Approved</div>
                <div class="hm-stat-sub">Ready for Step 3</div>
            </div>
        </div>

        <!-- ── NOTICE TABS ────────────────────────────────────────────── -->
        <div class="hm-sec-head">
            <div class="hm-sec-bar"></div>
            <span class="hm-sec-title">Notice Overview by Type</span>
        </div>

        <!-- Tab buttons -->
        <div class="hm-tabs">
            <button class="hm-tab on" onclick="switchTab('all',this)">
                All Notices
                <span class="hm-tab-count">@Model.RecentWorkflows.Count</span>
            </button>
            @foreach (var nt in noticeTypes)
            {
                var cnt = Model.RecentWorkflows.Count(w => w.Notice.ToString() == nt.Item1);
                <button class="hm-tab" onclick="switchTab('@nt.Item1.ToLower()',this)">
                    @nt.Item1
                    @if (cnt > 0)
                    {
                        <span class="hm-tab-count">@cnt</span>
                    }
                </button>
            }
        </div>

        <!-- TAB PANEL: Overview with Chart -->
        <div class="hm-tab-panel on" id="panel-all">
            <div class="hm-overview-grid">
                <div class="hm-chart-area">
                    <div class="hm-chart-title">Notices Sent by Type</div>
                    <div class="hm-chart-wrap">
                        <canvas id="noticeChart"></canvas>
                    </div>
                </div>
                <div class="hm-sidebar-stats">
                    <div class="hm-mini-stat hm-mini-stat-gold">
                        <div class="hm-mini-stat-lbl">Total Sent</div>
                        <div class="hm-mini-stat-num">@Model.TotalSent.ToString("N0")</div>
                    </div>
                    <div class="hm-mini-stat">
                        <div class="hm-mini-stat-lbl">Workflows</div>
                        <div class="hm-mini-stat-num">@Model.TotalWorkflows</div>
                    </div>
                    <div class="hm-mini-stat hm-mini-stat-green">
                        <div class="hm-mini-stat-lbl">Batches</div>
                        <div class="hm-mini-stat-num">@Model.TotalBatches</div>
                    </div>
                    <div class="hm-mini-stat">
                        <div class="hm-mini-stat-lbl">Printed</div>
                        <div class="hm-mini-stat-num">@Model.TotalPrinted.ToString("N0")</div>
                    </div>
                </div>
            </div>

            <!-- Full workflow table in All tab -->
            <div style="border-top:1px solid var(--border)">
                @if (!Model.RecentWorkflows.Any())
                {
                    <div class="hm-empty">
                        <div class="hm-empty-icon">📭</div>
                        No workflows yet. Go to Workflow Admin to create one.
                    </div>
                }
                else
                {
                    @await Html.PartialAsync("_WorkflowTable", Model.RecentWorkflows)
                }
            </div>
        </div>

        <!-- TAB PANELS: Per notice type -->
        @foreach (var nt in noticeTypes)
        {
            var code = nt.Item1;
            var rows = Model.RecentWorkflows.Where(w => w.Notice.ToString() == code).ToList();
            var sentTotal = rows.Sum(w => w.SentCount);
            <div class="hm-tab-panel" id="panel-@code.ToLower()">
                <div class="hm-ntable-header">
                    <div>
                        <div class="hm-ntable-head-title">@nt.Item2</div>
                        <div class="hm-ntable-head-desc">@nt.Item3 — @rows.Count workflow@(rows.Count == 1 ? "" : "s")</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px">
                        <span class="hm-nt-chip hm-chip-@code.ToLower()">@code</span>
                        @if (sentTotal > 0)
                        {
                            <span style="font-size:12px;font-weight:700;color:#16a34a">@sentTotal.ToString("N0") sent</span>
                        }
                    </div>
                </div>
                @if (!rows.Any())
                {
                    <div class="hm-empty">
                        <div class="hm-empty-icon">📭</div>
                        No @nt.Item1 workflows found.
                    </div>
                }
                else
                {
                    @await Html.PartialAsync("_WorkflowTable", rows)
                }
            </div>
        }

        <!-- ── BOTTOM ROW ──────────────────────────────────────────────── -->
        <div class="hm-bottom" style="margin-top:28px">

            <!-- Workflow Phases -->
            <div class="hm-card">
                <div class="hm-card-head">
                    <span class="hm-card-head-title">Workflow Phases</span>
                </div>
                <div class="hm-card-body">
                    <a class="hm-phase done" asp-controller="Workflow" asp-action="Step1">
                        <div class="hm-phase-num">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <div>
                            <div class="hm-phase-title">Step 1 — Configure Dates</div>
                            <div class="hm-phase-desc">Define roll, notice type, letter dates, valuation period and signatures.</div>
                        </div>
                        <div class="hm-phase-tag hm-tag-done">Configure</div>
                    </a>
                    <a class="hm-phase done" asp-controller="Workflow" asp-action="Step2">
                        <div class="hm-phase-num">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <div>
                            <div class="hm-phase-title">Step 2 — Preview &amp; Approve</div>
                            <div class="hm-phase-desc">Review email and notice previews, then start Step 3 processing.</div>
                        </div>
                        <div class="hm-phase-tag hm-tag-done">Preview</div>
                    </a>
                    <a class="hm-phase active" asp-controller="Step3" asp-action="Index">
                        <div class="hm-phase-num">3</div>
                        <div>
                            <div class="hm-phase-title">Step 3 — Processing</div>
                            <div class="hm-phase-desc">3.1 Create Batches → 3.2 Print PDFs → 3.3 Send Notices</div>
                        </div>
                        <div class="hm-phase-tag hm-tag-current">Active</div>
                    </a>
                </div>
            </div>

            <!-- Notice types grid -->
            <div class="hm-card">
                <div class="hm-card-head">
                    <span class="hm-card-head-title">Notice Types</span>
                </div>
                <div class="hm-card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
                    @foreach (var nt in noticeTypes)
                    {
                        var cnt2 = Model.RecentWorkflows.Count(w => w.Notice.ToString() == nt.Item1);
                        <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px;cursor:pointer"
                             onclick="switchTabById('@nt.Item1.ToLower()')">
                            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                                <span class="hm-nt-chip hm-chip-@nt.Item1.ToLower()">@nt.Item1</span>
                                @if (cnt2 > 0)
                                {
                                    <span style="font-size:11px;font-weight:700;color:var(--mu)">@cnt2</span>
                                }
                            </div>
                            <div style="font-size:11.5px;font-weight:600;color:var(--tx)">@nt.Item2</div>
                            <div style="font-size:10.5px;color:var(--mu)">@nt.Item3</div>
                        </div>
                    }
                </div>
            </div>
        </div>

      @*   <!-- ── QUICK ACTIONS ──────────────────────────────────────────── -->
        <div class="hm-sec-head" style="margin-top:28px">
            <div class="hm-sec-bar"></div>
            <span class="hm-sec-title">Quick Access</span>
        </div>
        <div class="hm-actions">
            <a class="hm-action hm-action-gold" asp-controller="Step3" asp-action="Index">
                <div class="hm-action-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                </div>
                <div class="hm-action-label">Step 3 Processing</div>
                <div class="hm-action-sub">Create batches, print PDFs, and send notice emails to ratepayers for approved workflows.</div>
                <div class="hm-action-cta">Go to Step 3 →</div>
            </a>
            <a class="hm-action" asp-controller="Workflow" asp-action="Step1">
                <div class="hm-action-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" /></svg>
                </div>
                <div class="hm-action-label">Workflow Admin</div>
                <div class="hm-action-sub">Create and manage workflows — assign rolls, notice types, letter dates and valuation period settings.</div>
                <div class="hm-action-cta">Open Admin →</div>
            </a>
            <a class="hm-action" asp-controller="Workflow" asp-action="SettingsLibrary">
                <div class="hm-action-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" /></svg>
                </div>
                <div class="hm-action-label">Settings Library</div>
                <div class="hm-action-sub">View all notice configurations, valuation periods, and roll registry definitions in one place.</div>
                <div class="hm-action-cta">Open Library →</div>
            </a>
        </div>
 *@
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        // ── Tab switching ──────────────────────────────────────────────────────
        function switchTab(id, btn) {
            document.querySelectorAll('.hm-tab').forEach(t => t.classList.remove('on'));
            document.querySelectorAll('.hm-tab-panel').forEach(p => p.classList.remove('on'));
            if (btn) btn.classList.add('on');
            var panel = document.getElementById('panel-' + id);
            if (panel) panel.classList.add('on');
        }
        function switchTabById(id) {
            var tabs = document.querySelectorAll('.hm-tab');
            var labels = ['all','s49','s51','s52','s53','dj','in','s78'];
            var idx = labels.indexOf(id);
            if (idx >= 0 && tabs[idx]) switchTab(id, tabs[idx]);
        }

        // ── Chart ──────────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function() {
            var ctx = document.getElementById('noticeChart');
            if (!ctx) return;

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(chartLabels)],
                    datasets: [
                        {
                            label: 'Notices Sent',
                            data: [@chartSent],
                            backgroundColor: 'rgba(230,176,0,0.85)',
                            borderColor: '#c9980a',
                            borderWidth: 1.5,
                            borderRadius: 6,
                        },
                        {
                            label: 'Batches',
                            data: [@chartBatches],
                            backgroundColor: 'rgba(10,10,10,0.08)',
                            borderColor: 'rgba(10,10,10,0.2)',
                            borderWidth: 1.5,
                            borderRadius: 6,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                font: { family: 'Poppins', size: 11, weight: '600' },
                                color: '#0a0a0a',
                                boxWidth: 12, boxHeight: 12,
                                padding: 16
                            }
                        },
                        tooltip: {
                            backgroundColor: '#0a0a0a',
                            titleFont: { family: 'Poppins', size: 12, weight: '700' },
                            bodyFont:  { family: 'Poppins', size: 11 },
                            padding: 12, cornerRadius: 8
                        }
                    },
                    scales: {
                        x: {
                            ticks: { font: { family: 'Poppins', size: 11, weight: '600' }, color: '#0a0a0a' },
                            grid: { display: false }
                        },
                        y: {
                            ticks: { font: { family: 'Poppins', size: 11 }, color: '#7a7a7a' },
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            beginAtZero: true
                        }
                    }
                }
            });
        });
    </script>
}
